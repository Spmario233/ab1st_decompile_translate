@@選択=SELBTN(@selbtn_s_3,
	神とのコンタクト,
	天使の特殊能力,
	パソコンゲーム
)@selbtn_log
IF(@選択==0){		// (神とのコンタクト/天使の特殊能力/パソコンゲーム) 神とのコンタクト

	【@音無】「恐らくだが…神とのコンタクト」R
	
	@bs(yr0309_06)
	KOE(020001592,002)【@ゆり】「へぇー。それは新しい見解ね」R
	【@音無】「ゆりはどう思っているんだ？」R
	
	@bs(yr0408_09)
	KOE(020001594,002)【@ゆり】「確信がないことは誰にも言えないわ。もし間違っていたら、戦線のみんなを振り回してしまうことになるから」R
	俺だけに答えさせて、なんだかずるく思う。R
	ただ、俺の考えとゆりの考えは違っているようだ。R
	
	@bgm_stop(3000)
	
	@bs(yr0509)
	KOE(020001919,002)【@ゆり＿重複】「あなたはまだまだ新米なんだから、幹部のみんなに追いつくぐらい、体力作りと銃の練習に努めなさい」R
	それ以上は何も話してくれないようだった。R
	;;本部を後にするしかなった…。R
	GOTO #AP_OWARI

}ELSEIF(@選択==2){		// (神とのコンタクト/天使の特殊能力/パソコンゲーム) パソコンゲーム
	
	【@音無】「パソコンゲーム」R
	
	@bs(yr0308_06)
	KOE(020001934,002)【@ゆり】「あら？　あたしの勘がここに来て、狂ったのかしら…」R
	どうやら、期待を裏切ったようだ。R
	【@音無】「違ったのか？」R
	
	@bs(yr0110)
	KOE(020001937,002)【@ゆり】「あたしの予想ではね」R
	【@音無】「あれはパソコンゲームだったはずだ」R
	
	@bs(yr0107_06)
	KOE(020001939,002)【@ゆり】「はいはい、それは忘れろー、忘れろー」R
	なんて扱いだ…。R
	
	@bgm_stop(3000)
	
	@bs(yr0509)
	KOE(020001919,002)【@ゆり＿重複】「あなたはまだまだ新米なんだから、幹部のみんなに追いつくぐらい、体力作りと銃の練習に努めなさい」R
	それ以上は何も話してくれないようだった。R
	;;俺は本部を後にした。R
	GOTO #AP_OWARI

}
