	//【@音無】「なぜ野田がぁぁーーー！！」R
	@face(nd0106)
	//KOE(001103451,011)【@野田】「なぜ俺があぁぁーーー！？」R
	//KOE(001103451,011)【@音無・@野田】「なぜ野田／俺があぁぁーーー！？」R
	//KOE(001103451,011)【２人】「なぜ野田／俺があぁぁーーー！？」R

	multi_msg KOE(001103451,011)【２人】
	【@音無】「なぜ野田がぁぁーーー！！」nl next_msg
	【@野田】「なぜ俺があぁぁーーー！？」R
	script.set_message_speed_default

	@bf(yr0306)
	KOE(001103453,002)【@ゆり】「あら、音無くんまで、反応するとは、思いもしなかったわ」R

	IF(@音無をゼウスと呼ぶ){
		【@音無】「今の俺はゼウスですが、何か？」R
	}elseif(@音無を日向markⅡと呼ぶ){
		【@音無】「今の俺は日向"mark"Ⅱですが、何か？」R
	}else{
		goto #LABEL01			// k-takahashi 引っかからなかったあだ名は下抜けるとまずいので飛ばします
	}

	IF(@ゆりただのエロ少年にイラっとする==1||@ゆりただのエロ少年にイラっとする２==1){

		@bs(yr0207_05@14)
		KOE(001103473,002)【@ゆり】「またイラッとするのが来たぁーーー！！」R

		@ゆりただのエロ少年にイラっとする３=1

		IF(@音無をゼウスと呼ぶ==1){

			;;【@音無】「え？」R			// ■■■■ 音無の発言であってる？（西

			@bs(yr0608)		//流れで変えたかったので変なところに入れます（あまの）
			
			GOTO #YURIEETO

		}elseif( @音無を日向markⅡと呼ぶ ){
			goto #MARK2		// k-takahashi ↓すっぽ抜け軽減のためmark2とelse追加します
		}

	}else{	// IF(@ゆりただのエロ少年にイラっとする==0&&@ゆりただのエロ少年にイラっとする２==0){

		@bs(yr0307)
		KOE(001103487,002)【@ゆり】「は？　なにそれ？」R
		【@音無】「俺のニックネーム」R

		IF(@音無をゼウスと呼ぶ){

			@bs(yr0108)		//流れで変えたかったので変なところに入れます（あまの）
			
			#YURIEETO
			
			KOE(001103493,002)【@ゆり】「えーと…もう一度聞かせてくれる？」R
			【@音無】「今の俺はゼウスですが、何か？」R
			
			@bs(yr0205)
			@横揺れ_弱
			
			KOE(001103495,002)【@ゆり】「ゼウスって、ギリシア神話の最高神だろぉーー！！　居たら、敵だろぉーーー！！」R
			
			@bs_add(hn0308, 4)
			KOE(001103496,010)【@日向】「ええっ、そんな奴の名前だったのかよ…」R
			【@音無】「ああ…いい気になっていた…すまん…」R
			
			@bs(hn0109)
			KOE(001103498,010)【@日向】「だよな…じゃあ、ええと…なんて呼べばいい？」R
			俺を見て、訊いてくる。R

			@@選択=SELBTN(@selbtn_s_2,
				音無,
				糞虫
			)@selbtn_log
			IF(@選択==0){		// (音無/糞虫) 音無

				【@音無】「ふつーに音無で…」R
				@bs(hn0102)
				KOE(001103508,010)【@日向】「よし、じゃ、これまで通りだ」R
				【@音無】「ああ、すまなかった…」R
				@bs(hn0104)
				KOE(001103510,010)【@日向】「いいよ。気にすんな」R

				@音無をゼウスと呼ぶ=0
				@今あだ名である=0

				@音無_呼び方 = @音無と呼ぶ		// （西

			}else{	//if(@選択==1){		// (音無/糞虫) 糞虫
				
				【@音無】「日向が知らないからって、ゼウスと呼ばせ続けてしまった…」R		// ■■■■「日向」のみでいいか要確認（西
				【@音無】「罪滅ぼしの意味も含めて、糞虫と呼んでくれないか…」R
				
				@bs(hn0306)
				KOE(001103521,010)【@日向】「はぁーーっ！？」R
				【@音無】「音無、糞虫、ほら、イントネーションも同じだ」R
				
				@bs_add(bs1_oy0107, 4)
				KOE(001103523,014)【大山】「音無くん、そこまで自虐的にならなくてもいいと思うよっ！？」R
				【@音無】「いいや。そう呼んでくれないと、これから先、戦線メンバーとしてやっていける気がしない…」R

				@bs(hn0409)
				KOE(001103525,010)【@日向】「くっ…」R
				【@音無】「頼む、日向っ！！　お前だけでもいいからそう呼んでくれ！」R	// ■■■■「日向」のみでいいか要確認（西　
				
				@bs(hn0205)
				KOE(001103527,010)【@日向】「ちっ…わかったよ、そう呼んでやるよ、糞虫っ」R

				@音無_呼び方 = @糞虫と呼ぶ		// （西

				@音無をゼウスと呼ぶ=0
				@今あだ名である=1
				@音無を糞虫と呼ぶ=1

				【@音無】「ありがたい！」R
				
				@音無称号(@糞虫と呼ぶ)
				@実績チェック

			}		// (音無/糞虫) 選択肢処理のケツ

		}elseif(@音無を日向markⅡと呼ぶ){
			
			#MARK2
			
			@bs(bs2_yr0205)
			@横揺れ_弱
			KOE(001103540,002)【@ゆり】「日向"mark"Ⅱってなんだー！！　お前は音無だろぉーー！！」R
			【@音無】「ええとそれは、襲名や、弟子入り的な…」R
			
			@bs(bs3_yr0207_05)
			@横揺れ_弱
			
