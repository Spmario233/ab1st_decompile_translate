		case (@４日目_午後)   @マップ選択_日付表示 = 04  @マップ選択_時間帯表示 = @午後
		case (@５日目_午前)   @マップ選択_日付表示 = 05  @マップ選択_時間帯表示 = @午前
		case (@５日目_午後)   @マップ選択_日付表示 = 05  @マップ選択_時間帯表示 = @午後
		case (@６日目_午前)   @マップ選択_日付表示 = 06  @マップ選択_時間帯表示 = @午前
		case (@６日目_午後)   @マップ選択_日付表示 = 06  @マップ選択_時間帯表示 = @午後
//		case (@７日目_午前)   
		case (@７日目_午後)   @マップ選択_日付表示 = 07  @マップ選択_時間帯表示 = @午後
		case (@８日目_午前)   @マップ選択_日付表示 = 08  @マップ選択_時間帯表示 = @午前
		case (@８日目_午後)   @マップ選択_日付表示 = 08  @マップ選択_時間帯表示 = @午後
		case (@９日目_午前)   @マップ選択_日付表示 = 09  @マップ選択_時間帯表示 = @午前
//		case (@９日目_午後)   
//		case (@１０日目_午前) 
//		case (@１０日目_午後) 
//		case (@１１日目_午前) 
//		case (@１１日目_午後) 
//		case (@１２日目_午前) 
//		case (@１２日目_午後) 
//		case (@１３日目_午前) 
//		case (@１３日目_午後) 
//		case (@１４日目_午前) 
//		case (@１４日目_午後) 
//		case (@１５日目_午前) 
		case (@１５日目_午後) @マップ選択_日付表示 = 15  @マップ選択_時間帯表示 = @午後
//		case (@１６日目_午前) 
//		case (@１６日目_午後) 
//		case (@１７日目_午前) 
		case (@１７日目_午後) @マップ選択_日付表示 = 17  @マップ選択_時間帯表示 = @午後
//		case (@１８日目_午前) 
//		case (@１８日目_午後) 
		case (@１９日目_午前) @マップ選択_日付表示 = 19  @マップ選択_時間帯表示 = @午前
		case (@１９日目_午後) @マップ選択_日付表示 = 19  @マップ選択_時間帯表示 = @午後
//		case (@２０日目_午前) 
		case (@２０日目_午後) @マップ選択_日付表示 = 20  @マップ選択_時間帯表示 = @午後
//		case (@２１日目_午前) 
//		case (@２１日目_午後) 
		case (@２２日目_午前) @マップ選択_日付表示 = 22  @マップ選択_時間帯表示 = @午前
		case (@２２日目_午後) @マップ選択_日付表示 = 22  @マップ選択_時間帯表示 = @午後
		case (@２３日目_午前) @マップ選択_日付表示 = 23  @マップ選択_時間帯表示 = @午前
		case (@２３日目_午後) @マップ選択_日付表示 = 23  @マップ選択_時間帯表示 = @午後
		case (@２４日目_午前) @マップ選択_日付表示 = 24  @マップ選択_時間帯表示 = @午前
		case (@２４日目_午後) @マップ選択_日付表示 = 24  @マップ選択_時間帯表示 = @午後
		case (@２５日目_午前) @マップ選択_日付表示 = 25  @マップ選択_時間帯表示 = @午前
		case (@２５日目_午後) @マップ選択_日付表示 = 25  @マップ選択_時間帯表示 = @午後
	}

	// デバッグ用
	$_K[20] = "◆マップ選択_【"
	$_K[20] += math.tostr_zero(@マップ選択_日付表示, 2)
	$_K[20] += "日目"
	    if (@マップ選択_時間帯表示 == @午前) { $_K[21] = "午前】_"}
	elseif (@マップ選択_時間帯表示 == @午後) { $_K[21] = "午後】_"}
}


// ----------------------------------------------------------------------------------------
// マウスボタン入力判定
// ----------------------------------------------------------------------------------------
command $MsBtnInputDecide
{
	// マウスボタン入力判定
	if (input.decide.is_up == @On)	{
		if (@MSCHK != @MSBTN_NONE){
			if (@MSCHK != @MSCHK_PREV)	{
				@se_play(000)
			}
			@MSBTN_STATE = @MSBTN_TOUCH
		}
		else	{
			@MSBTN_STATE = @MSBTN_NORMAL
		}
	}
	elseif (input.decide.is_down == @On)	{
		if (@MS_STATE_PREV != @MSBTN_INIT)	{
			if ((@MSCHK == @MS_STATE_PREV) && (@MSCHK != @MSBTN_NONE))	{
				if (@MSCHK != @MSCHK_PREV)	{
					@se_play(000)
				}
				@MSBTN_STATE = @MSBTN_PUSH
			}
			else	{
				@MSBTN_STATE = @MSBTN_NORMAL
			}
		}
		else	{
			@MSBTN_STATE = @MSBTN_PUSH
			@MS_STATE = @MSCHK
		}
	}
	if (input.cancel.on_down_up == @On)	{
		input.clear
		// 右クリックメニュー開く
	}
	elseif (input.decide.on_down_up == @On)	{
		if (@MS_STATE_PREV != @MSBTN_INIT){
			if ((@MSCHK == @MS_STATE_PREV) && (@MSCHK != @MSBTN_NONE))	{
				@MSBTN_STATE = @MSBTN_TOUCH
				@MSBTN_RESULT = @DECIDE
			}
			else{
				@MSBTN_STATE = @MSBTN_NORMAL
			}
			@MS_STATE = @MSBTN_INIT
		}
		input.clear
	}
}
