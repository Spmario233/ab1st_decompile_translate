	@b.obj[@ObjMapMenu00].@cd[_ObjMapSelBtn10b].create(@図書館ボタン下地,     @図書館マップ,     @図書館マップＸ,     @図書館マップＹ)		// 図書館
	@b.obj[@ObjMapMenu00].@cd[_ObjMapSelBtn11b].create(@大食堂ボタン下地,     @大食堂マップ,     @大食堂マップＸ,     @大食堂マップＹ)		// 大食堂
	@b.obj[@ObjMapMenu00].@cd[_ObjMapSelBtn12b].create(@保健室ボタン下地,     @保健室マップ,     @保健室マップＸ,     @保健室マップＹ)		// 保健室
	@b.obj[@ObjMapMenu00].@cd[_ObjMapSelBtn13b].create(@ガルデモボタン下地,   @ガルデモマップ,   @ガルデモマップＸ,   @ガルデモマップＹ)	// ガルデモ（軽音楽部）
	@b.obj[@ObjMapMenu00].@cd[_ObjMapSelBtn14b].create(@大山ボタン下地,       @大山マップ,       @大山マップＸ,       @大山マップＹ)		// 大山
	@b.obj[@ObjMapMenu00].@cd[_ObjMapSelBtn15b].create(@松下スリムボタン下地, @松下スリムマップ, @松下スリムマップＸ, @松下スリムマップＹ)	// 松下スリム
	@b.obj[@ObjMapMenu00].@cd[_ObjMapSelBtn01b].tr = 1
	@b.obj[@ObjMapMenu00].@cd[_ObjMapSelBtn02b].tr = 1
	@b.obj[@ObjMapMenu00].@cd[_ObjMapSelBtn03b].tr = 1
	@b.obj[@ObjMapMenu00].@cd[_ObjMapSelBtn04b].tr = 1
	@b.obj[@ObjMapMenu00].@cd[_ObjMapSelBtn05b].tr = 1
	@b.obj[@ObjMapMenu00].@cd[_ObjMapSelBtn06b].tr = 1
	@b.obj[@ObjMapMenu00].@cd[_ObjMapSelBtn07b].tr = 1
	@b.obj[@ObjMapMenu00].@cd[_ObjMapSelBtn08b].tr = 1
	@b.obj[@ObjMapMenu00].@cd[_ObjMapSelBtn09b].tr = 1
	@b.obj[@ObjMapMenu00].@cd[_ObjMapSelBtn10b].tr = 1
	@b.obj[@ObjMapMenu00].@cd[_ObjMapSelBtn11b].tr = 1
	@b.obj[@ObjMapMenu00].@cd[_ObjMapSelBtn12b].tr = 1
	@b.obj[@ObjMapMenu00].@cd[_ObjMapSelBtn13b].tr = 1
	@b.obj[@ObjMapMenu00].@cd[_ObjMapSelBtn14b].tr = 1
	@b.obj[@ObjMapMenu00].@cd[_ObjMapSelBtn15b].tr = 1

	// キャラボタン[名前]
	@b.obj[@ObjMapMenu00].@cd[_ObjMapSelCName01].create(sys_mp_selcname01,  @ゆりマップ,       @ゆりマップＸ,       @ゆりマップＹ       + @ゆりマップＹ補正)			// ゆり
	@b.obj[@ObjMapMenu00].@cd[_ObjMapSelCName02].create(sys_mp_selcname02a, @かなでマップ,     @かなでマップＸ,     @かなでマップＹ     + @かなでマップＹ補正)			// かなで
	@b.obj[@ObjMapMenu00].@cd[_ObjMapSelCName03].create(sys_mp_selcname03,  @岩沢マップ,       @岩沢マップＸ,       @岩沢マップＹ       + @岩沢マップＹ補正)			// 岩沢
	@b.obj[@ObjMapMenu00].@cd[_ObjMapSelCName04].create(sys_mp_selcname04,  @ユイマップ,       @ユイマップＸ,       @ユイマップＹ       + @ユイマップＹ補正)			// ユイ
	@b.obj[@ObjMapMenu00].@cd[_ObjMapSelCName05].create(sys_mp_selcname05,  @松下マップ,       @松下マップＸ,       @松下マップＹ       + @松下マップＹ補正)			// 松下
	@b.obj[@ObjMapMenu00].@cd[_ObjMapSelCName06].create(sys_mp_selcname06a, @日向マップ,       @日向マップＸ,       @日向マップＹ       + @日向マップＹ補正)			// 日向
	@b.obj[@ObjMapMenu00].@cd[_ObjMapSelCName07].create(sys_mp_selcname07,  @ひさ子マップ,     @ひさ子マップＸ,     @ひさ子マップＹ     + @ひさ子マップＹ補正)			// ひさ子
	@b.obj[@ObjMapMenu00].@cd[_ObjMapSelCName08].create(sys_mp_selcname08a, @野田マップ,       @野田マップＸ,       @野田マップＹ       + @野田マップＹ補正)			// 野田
	@b.obj[@ObjMapMenu00].@cd[_ObjMapSelCName09].create(sys_mp_selcname09,  @ＴＫマップ,       @ＴＫマップＸ,       @ＴＫマップＹ       + @ＴＫマップＹ補正)			// ＴＫ
	@b.obj[@ObjMapMenu00].@cd[_ObjMapSelCName10].create(sys_mp_selcname10,  @図書館マップ,     @図書館マップＸ,     @図書館マップＹ     + @図書館マップＹ補正)			// 図書館
	@b.obj[@ObjMapMenu00].@cd[_ObjMapSelCName11].create(sys_mp_selcname10,  @大食堂マップ,     @大食堂マップＸ,     @大食堂マップＹ     + @大食堂マップＹ補正)			// 大食堂
	@b.obj[@ObjMapMenu00].@cd[_ObjMapSelCName12].create(sys_mp_selcname10,  @保健室マップ,     @保健室マップＸ,     @保健室マップＹ     + @保健室マップＹ補正)			// 保健室
	@b.obj[@ObjMapMenu00].@cd[_ObjMapSelCName13].create(sys_mp_selcname10,  @ガルデモマップ,   @ガルデモマップＸ,   @ガルデモマップＹ   + @ガルデモマップＹ補正)		// ガルデモ（軽音楽部）
	@b.obj[@ObjMapMenu00].@cd[_ObjMapSelCName14].create(sys_mp_selcname11,  @大山マップ,       @大山マップＸ,       @大山マップＹ       + @大山マップＹ補正)			// 大山
	if (@マップ選択_日付 != @２０日目_午後)	{
		@b.obj[@ObjMapMenu00].@cd[_ObjMapSelCName15].create(sys_mp_selcname05,  @松下スリムマップ, @松下スリムマップＸ, @松下スリムマップＹ + @松下スリムマップＹ補正)	// 松下スリム
	}
	else	{
		@b.obj[@ObjMapMenu00].@cd[_ObjMapSelCName15].create(sys_mp_selcname10,  @松下スリムマップ, @松下スリムマップＸ, @松下スリムマップＹ + @松下スリムマップＹ補正)	// 松下スリム／[！]マークを表示
	}

	// 現在のキャラの呼び方を参照
	$map_name_state


return




// ----------------------------------------------------------------------------------------
// 現在のキャラの呼び方を参照
// ----------------------------------------------------------------------------------------
command $map_name_state
{
	// かなでの呼び方でボタン名を変更する
	switch (@天使_呼び方)	{
		case (0) @b.obj[@ObjMapMenu00].@cd[_ObjMapSelCName02].create(sys_mp_selcname02b, @かなでマップ, @かなでマップＸ, @かなでマップＹ + @かなでマップＹ補正)
		case (1) @b.obj[@ObjMapMenu00].@cd[_ObjMapSelCName02].create(sys_mp_selcname02a, @かなでマップ, @かなでマップＸ, @かなでマップＹ + @かなでマップＹ補正)

	}
	// 日向の呼び方でボタン名を変更する
	switch (@日向_呼び方)	{
		case (0) @b.obj[@ObjMapMenu00].@cd[_ObjMapSelCName06].create(sys_mp_selcname06a, @日向マップ, @日向マップＸ, @日向マップＹ)
		case (2) @b.obj[@ObjMapMenu00].@cd[_ObjMapSelCName06].create(sys_mp_selcname06b, @日向マップ, @日向マップＸ, @日向マップＹ)
		case (3) @b.obj[@ObjMapMenu00].@cd[_ObjMapSelCName06].create(sys_mp_selcname06c, @日向マップ, @日向マップＸ, @日向マップＹ)
		case (4) @b.obj[@ObjMapMenu00].@cd[_ObjMapSelCName06].create(sys_mp_selcname06d, @日向マップ, @日向マップＸ, @日向マップＹ)
		case (5) @b.obj[@ObjMapMenu00].@cd[_ObjMapSelCName06].create(sys_mp_selcname06e, @日向マップ, @日向マップＸ, @日向マップＹ)
	}
	// 野田の呼び方でボタン名を変更する
	switch (@野田_呼び方)	{
		case (0) @b.obj[@ObjMapMenu00].@cd[_ObjMapSelCName08].create(sys_mp_selcname08a, @野田マップ, @野田マップＸ, @野田マップＹ + @野田マップＹ補正)
		case (2) @b.obj[@ObjMapMenu00].@cd[_ObjMapSelCName08].create(sys_mp_selcname08b, @野田マップ, @野田マップＸ, @野田マップＹ + @野田マップＹ補正)
	}
}


// ----------------------------------------------------------------------------------------
// キャラ出現条件／場所を参照
// ----------------------------------------------------------------------------------------
command $map_chara_spot
{

	// 初期化
	@マップ選択初期化
	@マップボタン初期設定

/*******************************************************************
// デバック用ここから
********************************************************************/
//@マップ選択_日付 = @２２日目_午後
//@松下山ごもりに = 1
//@松下がスリムになった = 1
//@松下と稽古手応え掴む = 1
// 岩沢
//@岩沢ルートに入った = 1
//@岩沢消えなかった = 1
//@岩沢とひさ子に会わない約束した = 0
//@岩沢と個人的に会えなくなる = 0

// ひさ子
//@岩沢からバンメン紹介受けている = 1
//@岩沢とひさ子に会わない約束した = 0
//@ひさ子の生前聞けず気落ちしたまま = 0
//@ひさ子ともう会えない = 0
//@ひさ子に嫌われる = 0



//@０１日ひとりで行動 = 1
//@藤巻と大山ルームメイトになった = 1

//
//// 図書館
//@図書館マップ = @On
//@図書館マップ居場所 = @マップ_図書館
//
//// 大食堂
//@大食堂マップ = @On
//@大食堂マップ居場所 = @マップ_大食堂
//
//
//// ユイ
//@ユイマップ = @On
//@ユイマップ居場所 = @マップ_駐車場
//
//// 日向
////@日向マップ = @On
////@日向マップ居場所 = @マップ_野球場
//
//// 野田
//@野田マップ = @On
//@野田マップ居場所 = @マップ_第二連絡橋下_河原
//
//// かなで
//@かなでマップ = @On
//@かなでマップ居場所 = @マップ_学習棟Ｂ棟_教室


//@マップ選択_日付 = @２３日目_午前
//@制御１ = 1
//@制御２ = 1
//@制御３ = 1
//@制御４ = 1
//@制御５ = 1

//@days=4
//@マップ選択_日付 = @４日目_午後
//@岩沢からバンメン紹介受けている = 1
//@ひさ子ともう会えない = 0
//@マップ選択_日付 = @２日目_午前
//@天使が催眠術の本探す = 1

/*******************************************************************
// デバック用ここまで
********************************************************************/

	switch (@マップ選択_日付)	{
		// -------------------------------------------------------------------------------------
		case (@１日目_午後)
		// -------------------------------------------------------------------------------------
			// ゆり
     	    //if (@０１日ひとりで行動 == 0) {
     	    	@ゆりマップ = @On
     	    	@ゆりマップ居場所 = @マップ_戦線本部
     	    //}

			// 岩沢
			@岩沢マップ = @On
			@岩沢マップ居場所 = @マップ_学習棟Ａ棟_空き教室

			// 松下
			@松下マップ = @On
			@松下マップ居場所 = @マップ_体育館裏

			// 大山
			if ((@０１日ひとりで行動 == 1) && (@藤巻と大山ルームメイトになった == 1))	{
				@大山マップ = @On
				@大山マップ居場所 = @マップ_男子寮
			}

		// -------------------------------------------------------------------------------------
		case (@２日目_午前)
		// -------------------------------------------------------------------------------------
			// ゆり
			@ゆりマップ = @On
			@ゆりマップ居場所 = @マップ_戦線本部

			// 岩沢
			@岩沢マップ = @On
			@岩沢マップ居場所 = @マップ_学習棟Ａ棟_空き教室

			// 松下
			@松下マップ = @On
			@松下マップ居場所 = @マップ_体育館裏

			// 野田
			@野田マップ = @On
			@野田マップ居場所 = @マップ_第二連絡橋下_河原

		// -------------------------------------------------------------------------------------
		case (@２日目_午後)
		// -------------------------------------------------------------------------------------
			// ゆり
			if (@０２日ゆりに会った == 0)	{
				@ゆりマップ = @On
				@ゆりマップ居場所 = @マップ_戦線本部
			}

			// 岩沢
			if (@岩沢ＭＡＰ非表示 == 0){
				@岩沢マップ = @On
				@岩沢マップ居場所 = @マップ_学習棟Ａ棟_空き教室
			}

			// 松下
			@松下マップ = @On
			@松下マップ居場所 = @マップ_体育館裏

			// 野田
			if (@２日野田と会った == 0)	{
				@野田マップ = @On
				@野田マップ居場所 = @マップ_第二連絡橋下_河原
			}

			// ひさ子
			if (@岩沢からバンメン紹介受けている == 1) {
				@ひさ子マップ = @On
				@ひさ子マップ居場所 = @マップ_学習棟Ａ棟_空き教室
				@ひさ子ボタン = sys_mp_selbtn02
				@ひさ子ボタン下地 = sys_mp_selbtn02b
				@ひさ子マップＹ補正 = 41
			}

			// ユイ▼▼▼▼▼▼▼▼▼▼▼	体験版専用
			;;if(@trial_check()){		//体験版のみ
			;;	@ユイマップ = @On
			;;	@ユイマップ居場所 = @マップ_駐車場
			;;}
			// ユイ▲▲▲▲▲▲▲▲▲▲▲	体験版専用


		// -------------------------------------------------------------------------------------
		case (@３日目_午前)
		// -------------------------------------------------------------------------------------

			// ゆり
			@ゆりマップ = @On
			@ゆりマップ居場所 = @マップ_戦線本部

			// 岩沢
			if (@岩沢ＭＡＰ非表示 == 0) {
				@岩沢マップ = @On
				@岩沢マップ居場所 = @マップ_学習棟Ａ棟_空き教室
			}

			// 松下
			@松下マップ = @On
			@松下マップ居場所 = @マップ_体育館裏

			// 野田
			IF(@野田との訓練全身刻まれた０１==1 || 	@野田と会った回数<=1){
				@野田マップ = @On
				@野田マップ居場所 = @マップ_第二連絡橋下_河原
    		}

		// -------------------------------------------------------------------------------------
		case (@３日目_午後)
		// -------------------------------------------------------------------------------------
			// ゆり
			if (@０３日ゆりに会った == 0)	{
				@ゆりマップ = @On
				@ゆりマップ居場所 = @マップ_戦線本部
			}

			// ユイ
			@ユイマップ = @On
			@ユイマップ居場所 = @マップ_駐車場

			// 野田
			if (@３日野田と会った == 0 && (@野田との訓練全身刻まれた０１==1 || 	@野田と会った回数<=1)){
				@野田マップ = @On
				@野田マップ居場所 = @マップ_第二連絡橋下_河原
			}

			// ひさ子
			if (@岩沢からバンメン紹介受けている == 1)	{
				@ひさ子マップ = @On
				@ひさ子マップ居場所 = @マップ_学習棟Ａ棟_廊下
				@ひさ子ボタン = sys_mp_selbtn04
				@ひさ子ボタン下地 = sys_mp_selbtn04b
				@ひさ子マップＹ補正 = 41
			}

		// -------------------------------------------------------------------------------------
		case (@４日目_午前)
		// -------------------------------------------------------------------------------------
			// ゆり
