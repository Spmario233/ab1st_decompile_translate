#z00

#inc_start

	#property	$no_x
	#property	$no_y

	#define		@DispChaNo		$disp_cha_no
	#property	$disp_cha_no : int

	#define		@DispPlaceNo	$disp_place_no
	#property	$disp_place_no : int

	#define		@SelChaDisp		$sel_cha_disp
	#property	$sel_cha_disp : int

	#property	$mt_silhouette : int

#inc_end


// 出現しないキャラクターボタンの座標
$no_x = -2000
$no_y = -2000



// ---------------------------------------------------------------------
// マップ選択画面
// ---------------------------------------------------------------------

savepoint

close

// マップ選択開始
@マップ選択 = @On

// 日付を参照
@マップ選択_日付 = L[0]

// オブジェクトの初期化
gosub #ObjInit00

// マップ画面データ構築
gosub #ObjConstruct

// 誰も選択できない場合アイキャッチを表示してマップ選択を抜ける
if (@キャラクター出現人数 == 0)	{
	// 誰にも合わなかった場合、行動を初期化
	@自由行動誰 = -1
	if(@場所選択アイキャッチ抑制==0){
		@アイキャッチフェード
	}
	@場所選択アイキャッチ抑制=0
	@force_fade(bg_kuro, 2)		// k-takahashi 強制フェードに変更します
	return
}

@bgm_play(m302)		;;日常曲（昼の行動時）

// 一時的に「キーで早送りを止める機能」を無効にする
script.set_stop_skip_by_key_disable

@場所選択アイキャッチ抑制=0

// バックログに選択肢マーカーを挿入する
@選択肢マーカー

// マップ画面表示
$wipe(3)


// マップ画面表示
//gosub #ObjDisp

// マップ画面実行
//gosub #MapMenuPut


	// マウス初期化
	//@MouseBtnInit(@MsCheck,@MsCheckPreview,@MsState,@MsStatePreview,@MsBtnState,@MenuSel)
	@MouseBtnInit
	while (1)	{ // 0

		@MSCHK_PREV = @MSCHK
		@MSCHK = @MSBTN_NONE
		@MS_STATE_PREV = @MS_STATE

		// 初期化処理（キーが放されていたら状態を初期化する）
		if (input.decide.is_up == @On)	{
			@MS_STATE = @MSBTN_INIT
			@S_CTL_BAR_ACTIVE      = @Off
			@S_CTL_BAR_CTLACTIVE   = @Off
			@S_CTL_BAR_CTLPOS_PREV = @Init
		}

		@if_pixel_(@Off, @Off,  0, @ObjMapMenu00, _ObjMapSelBtn01b, 1, 0, 0)		// ゆり
		@if_pixel_(@Off, @Off,  1, @ObjMapMenu00, _ObjMapSelBtn02b, 1, 0, 0)		// かなで
		@if_pixel_(@Off, @Off,  2, @ObjMapMenu00, _ObjMapSelBtn03b, 1, 0, 0)		// 岩沢
		@if_pixel_(@Off, @Off,  3, @ObjMapMenu00, _ObjMapSelBtn04b, 1, 0, 0)		// ユイ
		@if_pixel_(@Off, @Off,  4, @ObjMapMenu00, _ObjMapSelBtn05b, 1, 0, 0)		// 松下
		@if_pixel_(@Off, @Off,  5, @ObjMapMenu00, _ObjMapSelBtn06b, 1, 0, 0)		// 日向
		@if_pixel_(@Off, @Off,  6, @ObjMapMenu00, _ObjMapSelBtn07b, 1, 0, 0)		// ひさ子
		@if_pixel_(@Off, @Off,  7, @ObjMapMenu00, _ObjMapSelBtn08b, 1, 0, 0)		// 野田
		@if_pixel_(@Off, @Off,  8, @ObjMapMenu00, _ObjMapSelBtn09b, 1, 0, 0)		// ＴＫ
		@if_pixel_(@Off, @Off,  9, @ObjMapMenu00, _ObjMapSelBtn10b, 1, 0, 0)		// 図書館
		@if_pixel_(@Off, @Off, 10, @ObjMapMenu00, _ObjMapSelBtn11b, 1, 0, 0)		// 大食堂
		@if_pixel_(@Off, @Off, 11, @ObjMapMenu00, _ObjMapSelBtn12b, 1, 0, 0)		// 保健室
		@if_pixel_(@Off, @Off, 12, @ObjMapMenu00, _ObjMapSelBtn13b, 1, 0, 0)		// ガルデモ（軽音楽部）
		@if_pixel_(@Off, @Off, 13, @ObjMapMenu00, _ObjMapSelBtn14b, 1, 0, 0)		// ガルデモ（軽音楽部）
		@if_pixel_(@Off, @Off, 14, @ObjMapMenu00, _ObjMapSelBtn15b, 1, 0, 0)		// 松下スリム

		// マウスボタン入力判定
		$MsBtnInputDecide
		if ($break_switch == @On)	{
			$break_switch = @Off
			break
		}

		// 状態セット
		@MsStateSet(0, 14)

		// マウスボタン状態
		@f.obj[@ObjMapMenu00].@cd[_ObjMapSelBtn01].patno = $obj_btn_state[0]
		@f.obj[@ObjMapMenu00].@cd[_ObjMapSelBtn02].patno = $obj_btn_state[1]
		@f.obj[@ObjMapMenu00].@cd[_ObjMapSelBtn03].patno = $obj_btn_state[2]
		@f.obj[@ObjMapMenu00].@cd[_ObjMapSelBtn04].patno = $obj_btn_state[3]
		@f.obj[@ObjMapMenu00].@cd[_ObjMapSelBtn05].patno = $obj_btn_state[4]
		@f.obj[@ObjMapMenu00].@cd[_ObjMapSelBtn06].patno = $obj_btn_state[5]
		@f.obj[@ObjMapMenu00].@cd[_ObjMapSelBtn07].patno = $obj_btn_state[6]
		@f.obj[@ObjMapMenu00].@cd[_ObjMapSelBtn08].patno = $obj_btn_state[7]
		@f.obj[@ObjMapMenu00].@cd[_ObjMapSelBtn09].patno = $obj_btn_state[8]
		@f.obj[@ObjMapMenu00].@cd[_ObjMapSelBtn10].patno = $obj_btn_state[9]
		@f.obj[@ObjMapMenu00].@cd[_ObjMapSelBtn11].patno = $obj_btn_state[10]
		@f.obj[@ObjMapMenu00].@cd[_ObjMapSelBtn12].patno = $obj_btn_state[11]
		@f.obj[@ObjMapMenu00].@cd[_ObjMapSelBtn13].patno = $obj_btn_state[12]
		@f.obj[@ObjMapMenu00].@cd[_ObjMapSelBtn14].patno = $obj_btn_state[13]
		@f.obj[@ObjMapMenu00].@cd[_ObjMapSelBtn15].patno = $obj_btn_state[14]

		@f.obj[@ObjMapMenu00].@cd[_ObjMapSelCName01].patno = $obj_btn_state[0]
		@f.obj[@ObjMapMenu00].@cd[_ObjMapSelCName02].patno = $obj_btn_state[1]
		@f.obj[@ObjMapMenu00].@cd[_ObjMapSelCName03].patno = $obj_btn_state[2]
		@f.obj[@ObjMapMenu00].@cd[_ObjMapSelCName04].patno = $obj_btn_state[3]
		@f.obj[@ObjMapMenu00].@cd[_ObjMapSelCName05].patno = $obj_btn_state[4]
		@f.obj[@ObjMapMenu00].@cd[_ObjMapSelCName06].patno = $obj_btn_state[5]
		@f.obj[@ObjMapMenu00].@cd[_ObjMapSelCName07].patno = $obj_btn_state[6]
		@f.obj[@ObjMapMenu00].@cd[_ObjMapSelCName08].patno = $obj_btn_state[7]
		@f.obj[@ObjMapMenu00].@cd[_ObjMapSelCName09].patno = $obj_btn_state[8]
		@f.obj[@ObjMapMenu00].@cd[_ObjMapSelCName10].patno = $obj_btn_state[9]
		@f.obj[@ObjMapMenu00].@cd[_ObjMapSelCName11].patno = $obj_btn_state[10]
		@f.obj[@ObjMapMenu00].@cd[_ObjMapSelCName12].patno = $obj_btn_state[11]
		@f.obj[@ObjMapMenu00].@cd[_ObjMapSelCName13].patno = $obj_btn_state[12]
		@f.obj[@ObjMapMenu00].@cd[_ObjMapSelCName14].patno = $obj_btn_state[13]
		@f.obj[@ObjMapMenu00].@cd[_ObjMapSelCName15].patno = $obj_btn_state[14]

		// フォーカス状態
		if ($obj_btn_state[0] > 0)	{
			// ゆり
			@DispChaNo = 1
			if (@ゆりマップ居場所 == @マップ_戦線本部)	{
				@DispPlaceNo = 1
				// デバッグ用
				$_K[22] = "【ゆり】_【戦線本部】"
			}
		}
		elseif ($obj_btn_state[1] > 0)	{
			// かなで
			@DispChaNo = 2
			if (@かなでマップ居場所 == @マップ_学習棟Ｂ棟_教室)	{
				@DispPlaceNo = 2
				// デバッグ用
				$_K[22] = "【かなで】_【学習棟Ｂ棟_教室】"
			}
			elseif (@かなでマップ居場所 == @マップ_学習棟Ｂ棟_廊下)	{
				@DispPlaceNo = 3
				// デバッグ用
				$_K[22] = "【かなで】_【学習棟Ｂ棟_廊下】"
			}
			elseif (@かなでマップ居場所 == @マップ_学習棟Ａ棟_廊下)	{
				@DispPlaceNo = 4
				// デバッグ用
				$_K[22] = "【かなで】_【学習棟Ａ棟_廊下】"
			}
		}
		elseif ($obj_btn_state[2] > 0)	{
			// 岩沢
			@DispChaNo = 3
			if (@岩沢マップ居場所 == @マップ_学習棟Ａ棟_空き教室)	{
				@DispPlaceNo = 6
				// デバッグ用
				$_K[22] = "【岩沢】_【学習棟Ａ棟_空き教室】"
			}
		}
		elseif ($obj_btn_state[3] > 0)	{
			// ユイ
			@DispChaNo = 4
			if (@ユイマップ居場所 == @マップ_駐車場)	{
				@DispPlaceNo = 5
				// デバッグ用
				$_K[22] = "【ユイ】_【駐車場】"
			}
			elseif (@ユイマップ居場所 == @マップ_学習棟Ｂ棟_廊下)	{
				@DispPlaceNo = 3
				// デバッグ用
				$_K[22] = "【ユイ】_【学習棟Ｂ棟_廊下】"
			}
		}
		elseif ($obj_btn_state[4] > 0)	{
			// 松下
			@DispChaNo = 5
			if (@松下マップ居場所 == @マップ_体育館裏)	{
				@DispPlaceNo = 7
				// デバッグ用
				$_K[22] = "【松下】_【体育館裏】"
			}
		}
		elseif ($obj_btn_state[5] > 0)	{
			// 日向
			@DispChaNo = 6
			if (@日向マップ居場所 == @マップ_野球場)	{
				@DispPlaceNo = 8
				// デバッグ用
				$_K[22] = "【日向】_【野球場】"
			}
		}
		elseif ($obj_btn_state[6] > 0)	{
			// ひさ子
			@DispChaNo = 7
			if (@ひさ子マップ居場所 == @マップ_学習棟Ａ棟_空き教室)	{
				@DispPlaceNo = 6
			}
			// 特例処置１※マップ上では空き教室
			if (@ひさ子マップ居場所 == @マップ_学習棟Ａ棟_廊下)	{
				@DispPlaceNo = 6
			}
			// 特例処置２※マップ上では空き教室
			if (@ひさ子マップ居場所  == @マップ_学習棟Ａ棟_空き教室_４日目_午後)	{
				@DispPlaceNo = 6
			}
			// デバッグ用
			$_K[22] = "【ひさ子】_【学習棟Ａ棟_空き教室】"
		}
		elseif ($obj_btn_state[7] > 0)	{
			// 野田
			@DispChaNo = 8
			if (@野田マップ居場所 == @マップ_第二連絡橋下_河原)	{
				@DispPlaceNo = 9
				// デバッグ用
				$_K[22] = "【野田】_【第二連絡橋下_河原】"
			}
		}
		elseif ($obj_btn_state[8] > 0)	{
			// ＴＫ
			@DispChaNo = 9
			if (@ＴＫマップ居場所 == @マップ_学習棟Ｂ棟_廊下)	{
				@DispPlaceNo = 4
				// デバッグ用
				$_K[22] = "【ＴＫ】_【学習棟Ｂ棟_廊下】"
			}
		}
		elseif ($obj_btn_state[9] > 0)	{
			// 図書館
			@DispChaNo = 0
			if (@図書館マップ居場所 == @マップ_図書館)	{
				@DispPlaceNo = 11
				// デバッグ用
				$_K[22] = "【図書館】"
			}
		}
		elseif ($obj_btn_state[10] > 0)	{
			// 大食堂
			@DispChaNo = 0
			if (@大食堂マップ居場所 == @マップ_大食堂)	{
				@DispPlaceNo = 10
				// デバッグ用
				$_K[22] = "【大食堂】"
			}
		}
		elseif ($obj_btn_state[11] > 0)	{
			// 保健室
			@DispChaNo = 0
			if (@保健室マップ居場所 == @マップ_保健室)	{
				@DispPlaceNo = 12
				// デバッグ用
				$_K[22] = "【保健室】"
			}
		}
		elseif ($obj_btn_state[12] > 0)	{
			// ガルデモ（軽音楽部）
			@DispChaNo = 0
			if (@ガルデモマップ居場所 == @マップ_学習棟Ａ棟_空き教室)	{
				@DispPlaceNo = 6
				// デバッグ用
				$_K[22] = "【ガルデモ】_【学習棟Ａ棟_空き教室】"
			}
		}
		elseif ($obj_btn_state[13] > 0)	{
			// 大山
			@DispChaNo = 10
			if (@大山マップ居場所 == @マップ_男子寮)	{
				@DispPlaceNo = 13
				// デバッグ用
				$_K[22] = "【大山】_【男子寮】"
			}
		}
		elseif ($obj_btn_state[14] > 0)	{
			// 松下スリム
			if ($mt_silhouette == @Off)	{
				@DispChaNo = 11
			}
			// スリム化初登場時はシルエットにする
			else	{
				@DispChaNo = 12
			}
			if (@松下スリムマップ居場所 == @マップ_体育館裏)	{
				@DispPlaceNo = 7
				// デバッグ用
				$_K[22] = "【松下スリム】_【体育館裏】"
			}
		}
		else	{
			// クリア
			@DispChaNo = 0
			@DispPlaceNo = 0
		}

		if (@DispChaNo != 0)	{
			if (@SelChaDisp == @Off)	{
				@f.obj[@ObjMapMenu00].@cd[_ObjMapSelCha01].x_rep_eve[0].set(0, 500, 0, 2)
				@f.obj[@ObjMapMenu00].@cd[_ObjMapSelCha01].tr_eve.set(255, 500, 0, 2)
				@SelChaDisp = @On
			}
		}
		else	{
			if (@SelChaDisp == @On)	{
				@f.obj[@ObjMapMenu00].@cd[_ObjMapSelCha01].x_rep[0] = 100
				@f.obj[@ObjMapMenu00].@cd[_ObjMapSelCha01].tr = 0
				@SelChaDisp = @Off
			}
		}
		@f.obj[@ObjMapMenu00].@cd[_ObjMapSelCha01].patno = @DispChaNo
		@f.obj[@ObjMapMenu00].@cd[_ObjMapSelSpot01].patno = @DispPlaceNo

		// 状態表示
		input.next
		disp

		// 結果
		if (@MSBTN_RESULT == @DECIDE)	{
			@MSBTN_RESULT = @INIT
			@se_play(001)
			switch (@MSCHK)	{
				case (0)
					// ゆり
					@自由行動誰 = @ゆり番号
				case (1)
					// かなで
					@自由行動誰 = @天使番号
				case (2)
					// 岩沢
					@自由行動誰 = @岩沢番号
				case (3)
					// ユイ
					@自由行動誰 = @ユイ番号
				case (4)
					// 松下
					@自由行動誰 = @松下番号
				case (5)
					// 日向
					@自由行動誰 = @日向番号
				case (6)
					// ひさ子
					@自由行動誰 = @ひさ子番号
				case (7)
					// 野田
					@自由行動誰 = @野田番号
				case (8)
					// ＴＫ
					@自由行動誰 = @ＴＫ番号
				case (9)
					// 図書館
					@自由行動誰 = @図書館番号
				case (10)
					// 大食堂
					@自由行動誰 = @大食堂番号
				case (11)
					// 保健室
					@自由行動誰 = @保健室番号
				case (12)
					// ガルデモ（軽音楽部）
					@自由行動誰 = @軽音学部番号
				case (13)
					// 大山
					@自由行動誰 = @大山番号
				case (14)
					// 松下スリム
					@自由行動誰 = @松下スリム番号
			}
			// デバッグ
			system.debug_write_log($_K[20] + $_K[21] + $_K[22])
			break
		}
	}

selpoint

// マップ選択終了
@マップ選択 = @Off

@force_fade(bg_kuro)	// k-takahashi 強制フェードに変更します
;@fade(bg_kuro)

// 無効にした「キーで早送りを止める機能」を解除する
script.set_stop_skip_by_key_enable

return



/********************************************************
*オブジェクトの初期化                                   *
*********************************************************/
#ObjInit00

	@b.obj[@ObjMapMenu00].init
	@b.obj[@ObjMapMenu00].disp = @On
	@b.obj[@ObjMapMenu00].@cd.resize(100)

return


/********************************************************
*システムメニューデータ構築                             *
*********************************************************/
#ObjConstruct

	// クリア
	@DispChaNo   = @Init
	@DispPlaceNo = @Init
	@SelChaDisp  = @Init
	// スリム化初登場時はシルエットにする
	$mt_silhouette = @Off

	// キャラ出現条件／場所を参照
	$map_chara_spot

	// キャラボタンの座標を参照	※ボタンが重ならないように調整
	$map_chara_pos

	// 現在のエピソードと日付を参照
	$map_day_state

	// 背景
	@b.obj[@ObjMapMenu00].@cd[_ObjMapBg01].create(sys_mp_bg00, @On)
	@b.obj[@ObjMapMenu00].@cd[_ObjMapBg02].create(sys_mp_bg01, @On, 1280-376, 0)
	@b.obj[@ObjMapMenu00].@cd[_ObjMapBg03].create(sys_mp_bg02, @On, 1280-376, 0)
	@b.obj[@ObjMapMenu00].@cd[_ObjMapBg04].create(sys_mp_bg03, @On, 1280-376, 0)
	@b.obj[@ObjMapMenu00].@cd[_ObjMapBg05].create(sys_mp_bg04, @On, 1280-376, 0)

	// 日付判定
	switch (@Days)	{
		case (0)			// マップ選択無し
		case (1)  L[0] = 0	// EPISODE.01 Departure
		case (2)  L[0] = 1	// EPISODE.02 Guild
		case (3)  L[0] = 2	// EPISODE.03 My Song
		case (4)  L[0] = 2	// 
		case (5)  L[0] = 2	// 
		case (6)  L[0] = 3	// EPISODE.04 Day Game
		case (7)  L[0] = 3	// 
		case (8)  L[0] = 4	// EPISODE.05 Favorite Flavor
		case (9)  L[0] = 4	// 
		case (10) L[0] = 4	// 
		case (11) L[0] = 4	// 
		case (12) L[0] = 4	// 
		case (13) L[0] = 4	// 
		case (14) L[0] = 4	// 
		case (15) L[0] = 4	// 
		case (16) L[0] = 4	// 
		case (17) L[0] = 4	// 
		case (18) L[0] = 5	// EPISODE.06 Family Affair
		case (19) L[0] = 5	// 
		case (20) L[0] = 5	// 
		case (21) L[0] = 5	// 
		case (22) L[0] = 6	// EPISODE.07 Alive
		case (23) L[0] = 7	// EPISODE.08 Dancer in the Dark
		case (24) L[0] = 7	// EPISODE.08 Dancer in the Dark
	}
	@b.obj[@ObjMapMenu00].@cd[_ObjMapBg03].patno = L[0]
	@b.obj[@ObjMapMenu00].@cd[_ObjMapBg04].patno = @マップ選択_日付表示
	@b.obj[@ObjMapMenu00].@cd[_ObjMapBg05].patno = @マップ選択_時間帯表示

	// フォーカス情報
	@b.obj[@ObjMapMenu00].@cd[_ObjMapSelSpot01].create(sys_mp_spot00, @On, 0, 720-183)
	@b.obj[@ObjMapMenu00].@cd[_ObjMapSelCha01].create(sys_mp_cha00, @On, 0, 720-450)
	@b.obj[@ObjMapMenu00].@cd[_ObjMapSelCha01].x_rep.resize(2)
	@b.obj[@ObjMapMenu00].@cd[_ObjMapSelCha01].x_rep[0] = 100
	@b.obj[@ObjMapMenu00].@cd[_ObjMapSelCha01].tr = 0

	// キャラボタン[下地]
	@b.obj[@ObjMapMenu00].@cd[_ObjMapSelBtn01].create(@ゆりボタン,       @ゆりマップ,       @ゆりマップＸ,       @ゆりマップＹ)				// ゆり
	@b.obj[@ObjMapMenu00].@cd[_ObjMapSelBtn02].create(@かなでボタン,     @かなでマップ,     @かなでマップＸ,     @かなでマップＹ)			// かなで
