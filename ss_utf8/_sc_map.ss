			// ユイ
			if (@ユイ遭遇フラグ != 0)	{
				@ユイマップ = @On
				@ユイマップ居場所 = @マップ_学習棟Ｂ棟_廊下
				@ユイボタン = sys_mp_selbtn02
				@ユイボタン下地 = sys_mp_selbtn02b
				@ユイマップＹ補正 = 41
			}

			// 松下
//			if ((@松下遭遇フラグ <= 4) || (@松下遭遇フラグ == 9))	{
			if ((@松下遭遇フラグ >= 5) && (@松下山ごもりに == 0) && (@松下遭遇フラグ != 9))	{		//５回以上で山ごもりしてない、ただし、９回目はパス
				@松下マップ = @On
				@松下マップ居場所 = @マップ_体育館裏
			}

			// 松下スリム
			if (@松下山ごもりに == 1)	{
				// スリム化初登場時はシルエットにする
				$mt_silhouette = @On
				@松下スリムマップ = @On
				@松下スリムマップ居場所 = @マップ_体育館裏
			}

			// 野田
			if (@野田と友達になる == @On && (@野田を振った == 0) && (@野田ともう訓練しない == 0)) {
				@野田マップ = @On
				@野田マップ居場所 = @マップ_第二連絡橋下_河原
			}

			// 軽音楽部 ※ガルデモが練習している空き教室
//			if (@ひさ子に嫌われる == 0)	{
//				@ガルデモマップ = @On
//				@ガルデモマップ居場所 = @マップ_学習棟Ａ棟_空き教室
//			}

		// -------------------------------------------------------------------------------------
		case (@２２日目_午前)
		// -------------------------------------------------------------------------------------
			// 岩沢
			if (@岩沢ＭＡＰ非表示 == 0) {
				@岩沢マップ = @On
				@岩沢マップ居場所 = @マップ_学習棟Ａ棟_空き教室
			}

			// ユイ
			if (@ユイ遭遇フラグ != 0)	{
				@ユイマップ = @On
				@ユイマップ居場所 = @マップ_学習棟Ｂ棟_廊下
				@ユイボタン = sys_mp_selbtn02
				@ユイボタン下地 = sys_mp_selbtn02b
				@ユイマップＹ補正 = 41
			}

			// 松下
			if ((@松下遭遇フラグ >= 5) && (@松下山ごもりに == 0) && (@松下遭遇フラグ != 9))	{		//５回以上で山ごもりしてない、ただし、９回目はパス
			//if ((@松下遭遇フラグ <= 4) || (@松下遭遇フラグ == 9))	{
				@松下マップ = @On
				@松下マップ居場所 = @マップ_体育館裏
			}

			// 松下スリム
			if (@松下がスリムになった == 1)	{
				@松下スリムマップ = @On
				@松下スリムマップ居場所 = @マップ_体育館裏
			}

			// 野田
			if (@野田と友達になる == @On && (@野田を振った == 0) && (@野田ともう訓練しない == 0)) {
				@野田マップ = @On
				@野田マップ居場所 = @マップ_第二連絡橋下_河原
			}

		// -------------------------------------------------------------------------------------
		case (@２２日目_午後)
		// -------------------------------------------------------------------------------------
			// 岩沢
			if (@岩沢ＭＡＰ非表示 == 0) {
				@岩沢マップ = @On
				@岩沢マップ居場所 = @マップ_学習棟Ａ棟_空き教室
			}

			// ユイ
			if (@ユイ遭遇フラグ != 0)	{
				@ユイマップ = @On
				@ユイマップ居場所 = @マップ_駐車場
			}

			// 松下
			if ((@松下山ごもりに == 0) && (@松下と稽古手応え掴む == 1)) {
				@松下マップ = @On
				@松下マップ居場所 = @マップ_体育館裏
			}

			// 松下スリム
			if ((@松下がスリムになった == 1) && (@松下と稽古手応え掴む == 1)) {
				@松下スリムマップ = @On
				@松下スリムマップ居場所 = @マップ_体育館裏
			}

		// -------------------------------------------------------------------------------------
		case (@２４日目_午前)
		// -------------------------------------------------------------------------------------
			// 岩沢
			if (@岩沢ＭＡＰ非表示 == 0) {
				@岩沢マップ = @On
				@岩沢マップ居場所 = @マップ_学習棟Ａ棟_空き教室
			}

			// 松下
			if (@松下遭遇フラグ == 10)	{		//スリムかどうかは飛び先で分かれている。
				if (@松下がスリムになった == 1) {
					@松下スリムマップ = @On
					@松下スリムマップ居場所 = @マップ_体育館裏
				}
				else	{
					@松下マップ = @On
					@松下マップ居場所 = @マップ_体育館裏
				}
			}

			// 野田
//			if (@野田と友達になる == @On && (@野田を振った == 0) && (@野田ともう訓練しない == 0)) {
//				@野田マップ = @On
//				@野田マップ居場所 = @マップ_第二連絡橋下_河原
//			}

			// 保健室
			@保健室マップ = @On
			@保健室マップ居場所 = @マップ_保健室

		// -------------------------------------------------------------------------------------
//		case (@２３日目_午後)
		// -------------------------------------------------------------------------------------
			// 岩沢
//			if (@岩沢とひさ子に会わない約束した == 0) {
//				@岩沢マップ = @On
//				@岩沢マップ居場所 = @マップ_学習棟Ａ棟_空き教室
//			}

			// 松下
//			@松下マップ = @On
//			@松下マップ居場所 = @マップ_体育館裏
	}

	// 仕様変更に対応する為、キャラごとにオブジェクトを持たせて判定
	// 出現しない場合は表示しない


	// 全ての日割り判定のあとに以下の判定をするので、判定結果を上書きできます。強い。（西
	// OFFにしても指定座標に存在するので、座標も指定しないとダメでした by uta

	// 岩沢
	if (@岩沢消えた == 1)						{		@岩沢マップ = @Off	@岩沢マップ居場所 = @マップ_出現しない	}
	if (@岩沢とひさ子に会わない約束した == 1)	{		@岩沢マップ = @Off	@岩沢マップ居場所 =	@マップ_出現しない	}
	if (@岩沢と個人的に会えなくなる == 1)		{		@岩沢マップ = @Off	@岩沢マップ居場所 =	@マップ_出現しない	}

	// ひさ子
	if (@岩沢とひさ子に会わない約束した == 1)	{		@ひさ子マップ = @Off	@ひさ子マップ居場所 = @マップ_出現しない	}
	if (@ひさ子の生前聞けず気落ちしたまま == 1) {		@ひさ子マップ = @Off	@ひさ子マップ居場所 = @マップ_出現しない	}
	if (@ひさ子ともう会えない == 1)				{		@ひさ子マップ = @Off	@ひさ子マップ居場所 = @マップ_出現しない	}

	// 松下
	if (@松下とはもう会いに行かない == 1 ){		@松下マップ = @Off	@松下マップ居場所 = @マップ_出現しない		}

	// ここまで。

}


// ----------------------------------------------------------------------------------------
// キャラボタンの座標を参照
