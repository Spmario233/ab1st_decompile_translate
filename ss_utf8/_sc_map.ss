	@b.obj[@ObjMapMenu00].@cd[_ObjMapSelBtn04].create(@ユイボタン,       @ユイマップ,       @ユイマップＸ,       @ユイマップＹ)				// ユイ
	@b.obj[@ObjMapMenu00].@cd[_ObjMapSelBtn05].create(@松下ボタン,       @松下マップ,       @松下マップＸ,       @松下マップＹ)				// 松下
	@b.obj[@ObjMapMenu00].@cd[_ObjMapSelBtn06].create(@日向ボタン,       @日向マップ,       @日向マップＸ,       @日向マップＹ)				// 日向
