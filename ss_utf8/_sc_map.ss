		case (@マップ_学習棟Ａ棟_空き教室) @ひさ子マップＸ = 474   @ひさ子マップＹ = 233
		case (@マップ_駐車場)              
		case (@マップ_学習棟Ｂ棟_廊下)     
		case (@マップ_体育館裏)            
		case (@マップ_野球場)              
		case (@マップ_第二連絡橋下_河原)   
		case (@マップ_大食堂)              
		case (@マップ_図書館)              
		case (@マップ_保健室)              
		case (@マップ_出現しない)          @ひさ子マップＸ = $no_x @ひさ子マップＹ = $no_x
		case (@マップ_学習棟Ａ棟_空き教室_４日目_午後)	@ひさ子マップＸ = 380  @ひさ子マップＹ = 110
	}

	// ----------------------------------------------------------------------------------------
	// 野田
	// ----------------------------------------------------------------------------------------
	switch (@野田マップ居場所)	{
		case (@マップ_戦線本部)            
		case (@マップ_学習棟Ｂ棟_教室)     
		case (@マップ_学習棟Ａ棟_廊下)     
		case (@マップ_学習棟Ａ棟_空き教室) 
