command $map_chara_pos
{

	// ----------------------------------------------------------------------------------------
	// ゆり
	// ----------------------------------------------------------------------------------------
	switch (@ゆりマップ居場所)	{
		case (@マップ_戦線本部)            @ゆりマップＸ = 590  @ゆりマップＹ = 100
		case (@マップ_学習棟Ｂ棟_教室)     
		case (@マップ_学習棟Ａ棟_廊下)     
		case (@マップ_学習棟Ａ棟_空き教室) 
		case (@マップ_駐車場)              
		case (@マップ_学習棟Ｂ棟_廊下)     
		case (@マップ_体育館裏)            
		case (@マップ_野球場)              
		case (@マップ_第二連絡橋下_河原)   
		case (@マップ_大食堂)              
		case (@マップ_図書館)              
		case (@マップ_保健室)              
