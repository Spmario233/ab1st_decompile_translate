		case (@マップ_第二連絡橋下_河原)   
		case (@マップ_大食堂)              
		case (@マップ_図書館)              @図書館マップＸ = 458   @図書館マップＹ = 340
		case (@マップ_保健室)              
		case (@マップ_出現しない)          @図書館マップＸ = $no_x @図書館マップＹ = $no_x
	}

	// ----------------------------------------------------------------------------------------
	// 大食堂 ※イベント
	// ----------------------------------------------------------------------------------------
	switch (@大食堂マップ居場所)	{
		case (@マップ_戦線本部)            
		case (@マップ_学習棟Ｂ棟_教室)     
		case (@マップ_学習棟Ａ棟_廊下)     
		case (@マップ_学習棟Ａ棟_空き教室) 
		case (@マップ_駐車場)              
		case (@マップ_学習棟Ｂ棟_廊下)     
		case (@マップ_体育館裏)            
		case (@マップ_野球場)              
		case (@マップ_第二連絡橋下_河原)   
		case (@マップ_大食堂)              @大食堂マップＸ = 860   @大食堂マップＹ = 210
		case (@マップ_図書館)              
		case (@マップ_保健室)              
		case (@マップ_出現しない)          @大食堂マップＸ = $no_x @大食堂マップＹ = $no_x
	}

	// ----------------------------------------------------------------------------------------
	// 保健室 ※イベント
	// ----------------------------------------------------------------------------------------
	switch (@保健室マップ居場所)	{
		case (@マップ_戦線本部)            
		case (@マップ_学習棟Ｂ棟_教室)     
		case (@マップ_学習棟Ａ棟_廊下)     
		case (@マップ_学習棟Ａ棟_空き教室) 
		case (@マップ_駐車場)              
		case (@マップ_学習棟Ｂ棟_廊下)     
		case (@マップ_体育館裏)            
		case (@マップ_野球場)              
		case (@マップ_第二連絡橋下_河原)   
		case (@マップ_大食堂)              
		case (@マップ_図書館)              
		case (@マップ_保健室)              @保健室マップＸ = 550   @保健室マップＹ = 210
		case (@マップ_出現しない)          @保健室マップＸ = $no_x @保健室マップＹ = $no_x
	}

	// ----------------------------------------------------------------------------------------
	// ＴＫ ※イベント
	// ----------------------------------------------------------------------------------------
	switch (@ＴＫマップ居場所)	{
		case (@マップ_戦線本部)            
		case (@マップ_学習棟Ｂ棟_教室)     
		case (@マップ_学習棟Ａ棟_廊下)     @ＴＫマップＸ = 550  @ＴＫマップＹ = 210
		case (@マップ_学習棟Ａ棟_空き教室) 
		case (@マップ_駐車場)              
		case (@マップ_学習棟Ｂ棟_廊下)     @ＴＫマップＸ = 470  @ＴＫマップＹ = 220
		case (@マップ_体育館裏)            
		case (@マップ_野球場)              
		case (@マップ_第二連絡橋下_河原)   
		case (@マップ_大食堂)              
		case (@マップ_図書館)              
		case (@マップ_保健室)              
		case (@マップ_出現しない)          @ＴＫマップＸ = $no_x @ＴＫマップＹ = $no_x
	}

	// ----------------------------------------------------------------------------------------
	// ガルデモ（軽音楽部） ※イベント
	// ----------------------------------------------------------------------------------------
	switch (@ガルデモマップ居場所)	{
		case (@マップ_戦線本部)            
		case (@マップ_学習棟Ｂ棟_教室)     
		case (@マップ_学習棟Ａ棟_廊下)     
		case (@マップ_学習棟Ａ棟_空き教室) @ガルデモマップＸ = 380   @ガルデモマップＹ = 110
		case (@マップ_駐車場)              
		case (@マップ_学習棟Ｂ棟_廊下)     
		case (@マップ_体育館裏)            
		case (@マップ_野球場)              
		case (@マップ_第二連絡橋下_河原)   
		case (@マップ_大食堂)              
		case (@マップ_図書館)              
		case (@マップ_保健室)              
		case (@マップ_出現しない)          @ガルデモマップＸ = $no_x @ガルデモマップＹ = $no_x
	}

	// ----------------------------------------------------------------------------------------
	// 大山
	// ----------------------------------------------------------------------------------------
	switch (@大山マップ居場所)	{
		case (@マップ_戦線本部)            
		case (@マップ_学習棟Ｂ棟_教室)     
		case (@マップ_学習棟Ａ棟_廊下)     
		case (@マップ_学習棟Ａ棟_空き教室) 
		case (@マップ_駐車場)              
		case (@マップ_学習棟Ｂ棟_廊下)     
		case (@マップ_体育館裏)            
		case (@マップ_野球場)              
		case (@マップ_第二連絡橋下_河原)   
		case (@マップ_大食堂)              
		case (@マップ_図書館)              
		case (@マップ_保健室)              
		case (@マップ_男子寮)              @大山マップＸ = 830   @大山マップＹ = 60
		case (@マップ_出現しない)          @大山マップＸ = $no_x @大山マップＹ = $no_x
	}
}


