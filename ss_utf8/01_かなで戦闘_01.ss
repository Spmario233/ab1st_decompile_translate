;;@最初の授業受けた=1

@bgm_stop(2000)

逃げ切れないだろうし、一度授業を受けてみるか…。R

farcall(＿かなで+"_00")		;;授業を受ける用の管理ＳＳへ。

RETURN
 

@fade(bg_kuro, 25)

