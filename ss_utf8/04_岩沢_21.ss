	KOE(040004937,004)【岩沢】「ほぅ、だとしたらすごいな。理由は？」R

	@@選択=SELBTN(@selbtn_m_3,
		作詞が苦手だから,
		アレンジ次第だから,
		本当はインストバンドが好きだから
	)@selbtn_log
	IF(@選択==0){		// (作詞が苦手だから/アレンジ次第だから/本当はインストバンドが好きだから) 

		【@音無】「作詞が苦手だから、とか？」R
		;－－－★★★★修正
		//	▼▼ボイスに合わせてこちらをコメントアウトしておきました▼▼		西村
		;KOE(040004946,004)【岩沢】「それはないな。やっぱり伝えたいメッセージがあるからな」R
		
		@bf(iw0109_01)
		KOE(040004946,004)【岩沢】「いいとこつくな。確かに、作曲よりは苦手だ。でも別に理由がある」R

	}ELSEIF(@選択==1){		// (作詞が苦手だから/アレンジ次第だから/本当はインストバンドが好きだから) 

		【@音無】「アレンジ次第だからか？」R
		
		@bf(iw0102)
		KOE(040004951,004)【岩沢】@bc「いいとこつくな。確かに、アレンジに引っ張られて、書くこともある。でも別に理由があるんだ」@bf_c(6500, iw0109_01)R

	}ELSE{	// IF(@選択==2){		// (作詞が苦手だから/アレンジ次第だから/本当はインストバンドが好きだから) 

		【@音無】「本当はインストバンドが好きだからか？」R
