		IF(@ギルドに居続けた==0){

			【@音無】（なんていうか…アメリカのように銃社会でもない日本で、こんなにも簡単に銃を撃ちまくってもいいものなのかと…）R

		}

//		IF(@夜に入隊決めた==0){

