		;;【@音無】「そっか…」R
		;;@bs(hn0101_09)
		;;KOE(000400044,010)【@日向】「それと、鼻からも相当な出血が見られたそうだ。背中から落ちたのに不思議な話だな」R
		if( @ゆりをオカズにした１ == 1 )		// k-takahashi ぶら下がりで落ちた場合のみ回想ＣＧはさみます
		{
