			@fade(bg_siro, 2)
			@回想終了スタック
		}
		
		@縦揺れ_弱
		
		【@音無】「うわあああぁぁぁぁーーー！！」R

		IF(@ゆりをオカズにした１==1){

			@bs(hn0403)
			KOE(000400050,010)【@日向】「お前が鼻血をまき散らしながら落ちていく姿も俺は確認した」R

		}

		@bs(hn0408)
