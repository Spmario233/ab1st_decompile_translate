		@野田との訓練全身刻まれた=0
		//@松下関係で怪我=0

	}

	【@音無】「それで結局、オペレーションは成功したのか…？」R

	GOTO #AAYURIPPE

}elseif(@ギルド降下作戦の途中で死んだ==1){		// 最初の分岐２

	@bg_pan_zd(ep99_bg001, 0, 300, 2)
	@timewaitkey(300)
	@pcmch_play(0, @起きるベッド)
	@縦揺れ_弱
	
	【@音無】「はっ！！」R
	飛び起きた。R

	@bgm_play(m301)		;;♪日常曲（朝の寮の部屋など）
	;;@bgm_play(m106)		;;■体験版用日常曲（朝の行動時）
	
	@pcmch_stop(1, 1000)

	@bs(hn0104)
	KOE(000400036,010)【@日向】「ようっ、起きたか」R
	【@音無】「俺はどうなっていたんだ…？」R
	張り付くような恐怖感は残っているが、どうなったか全く覚えていない。R

