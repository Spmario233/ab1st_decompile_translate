//立っているビットの個数でselbtnの種類を返す
command $get_selbtn_type( property $src ) : int
{
	L[9]=0

	for(L[0]=0,L[0]<=@岩沢＿話題の最大値,L[0]+=1){		//最下位ビットより順番にカウント
		if( ($src & 1) == 0 ){
			L[9]+=1
		}
		$src = $src >>> 1
	}

	//ビット個数によりselbtnの登録番号を返す
	switch(L[9]){
		case(1)  return(@selbtn_s_1)
		case(2)  return(@selbtn_s_2)
		case(3)  return(@selbtn_s_3)
		case(4)  return(@selbtn_s_4)
		case(5)  return(@selbtn_s_5)
		case(6)  return(@selbtn_s_6)
		case(7)  return(@selbtn_s_7)
		case(8)  return(@selbtn_s_8)
		case(9)  return(@selbtn_s_9)
		case(10) return(@selbtn_s_10)
	}
}


command $check_iwasawa_sel_onoff( property $src ) : int
{
	if( $src < 0 || $src>@岩沢＿話題の最大値 ){
		return(0)	//範囲外
	}
	if( (@岩沢話題 & (1 << $src)) != 0 ){	//該当のＢＩＴが１
		return(0)
	}
	return(1)		//選択肢、表示
}

command $iwasawa_sel_off( property $src )
{
	if( $src < 0 || $src>@岩沢＿話題の最大値 ){
		return		//範囲外
	}
	@岩沢話題 |= (1 << $src)
}


