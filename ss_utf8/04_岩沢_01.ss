	//	関根の自己紹介抜けのため、シーン作成		西村
	【@音無】"「お前らと同じ人間であることに変わりはない。死んでるけど」"R //「お前らと同じ人間であることに変わりはない。死んでるけど」R
	@bf(sk0514)
	KOE(031000038,006)【関根＿？？】"「んなこたーわかっとるわあぁぁぁーー！！」"R //「んなこたーわかっとるわあぁぁぁーー！！」R
	【@音無】"「…頼む、落ち着いてくれ」"R //「…頼む、落ち着いてくれ」R
	
	IF(@野田で怪我してる){
	
		"傷だらけの体にこいつのリアクションが響く…。"R //傷だらけの体にこいつのリアクションが響く…。R
	
	}else{
	
		"テンションが高すぎてついていくのに疲れる…。"R //テンションが高すぎてついていくのに疲れる…。R
	
	}
	
	【@音無】"「で、あんたの名前は？」"R //「で、あんたの名前は？」R
	
	@bf(sk0313)
	KOE(040000452,006)【関根】"「あたしは関根しおりです」"R //「あたしは関根しおりです」R
	"テンションの落ち着いた自己紹介をしてくれる。"R //テンションの落ち着いた自己紹介をしてくれる。R
	"騒がしいが、人の話を聞いてくれるキャラではあるようだ。"R //騒がしいが、人の話を聞いてくれるキャラではあるようだ。R
	【@音無】"「来たばっかだが、よろしく頼む」"R //「来たばっかだが、よろしく頼む」R

	@bf(iw0101_02)
	KOE(040000454,004)【岩沢＿重複】"「おい、ひさ子、入江、いきなり幹部に入った奴だから、お前らも挨拶しておけよ」"R //「おい、ひさ子、入江、いきなり幹部に入った奴だから、お前らも挨拶しておけよ」R
	//関根はまだどん引きしたままだが、岩沢がそう部室に向けて手招きした。R
	"岩沢がそう部室に向けて手招きした。"R //岩沢がそう部室に向けて手招きした。R
	#LABEL_NASIO
	
	@bs

}

//	まだ自己紹介を受けておらず名前と顔が一致しないはずなので、テキスト修正		西村
//まず、入江が現れる。R
"まず、髪の長い小柄な女生徒が現れる。"R //まず、髪の長い小柄な女生徒が現れる。R

