;;↑自己紹介２重になるときがあるから、if文に入れます

IF(@野田で怪我してる){

	@bs(ir0101)
	KOE(040000459,007)【入江】"「入江です」"R //「入江です」R

	@bf(ir0104_05@00d)
	@横揺れ_弱
	KOE(040000462,007)【入江】"「って、えぇぇぇぇぇえーーーー！！」"R //「って、えぇぇぇぇぇえーーーー！！」R

	@bf(ir0106_04)
	
	"俺のぼろぼろな姿を見て、また引かれる。"R //俺のぼろぼろな姿を見て、また引かれる。R
	
	@face(iw0109_08)
	KOE(040000464,004)【岩沢】"「怪我は耐えられる痛みらしい」"R //「怪我は耐えられる痛みらしい」R

}

