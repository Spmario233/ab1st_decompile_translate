@@選択=SELBTN(@selbtn_s_2,
	"喉が渇くまで持ち歩く", //喉が渇くまで持ち歩く,
	"すぐさま間接キスに挑む" //すぐさま間接キスに挑む
)@selbtn_log
IF(@選択==1){		// (喉が渇くまで持ち歩く/すぐさま間接キスに挑む) すぐさま間接キスに挑む

	@bgm_pause
	@pcmch_play_loop(1, @心音)
	【@音無】"（よし、いくぞ！）"R //（よし、いくぞ！）R

	@pcmch_stop(1, 600)
	@bgm_resume(3000)
	"…って、ただの変態じゃないか！"R //…って、ただの変態じゃないか！R
	"そもそも間接キスにどんな意味があるんだ？"R //そもそも間接キスにどんな意味があるんだ？R
	"そりゃ、少量の唾液は飲み口や、中身にも混じったりするが、そんなのは微々たるもので、実際残るのは、岩沢と間接キスをした、という自己満足だけだ。"R //そりゃ、少量の唾液は飲み口や、中身にも混じったりするが、そんなのは微々たるもので、実際残るのは、岩沢と間接キスをした、という自己満足だけだ。R
	"それでもやるのか？"R //それでもやるのか？R

	@@選択=SELBTN(@selbtn_s_2,
		"やる", //やる,
		"やめておく" //やめておく
	)@selbtn_log
	IF(@選択==0){		// (やる/やめておく) やる

		【@音無】"（やろう…鮮度が大事だ！）"R //（やろう…鮮度が大事だ！）R
		"キャップを慎重に外し、岩沢の口をつけた位置を入念に探る。"R //キャップを慎重に外し、岩沢の口をつけた位置を入念に探る。R
		"唇の跡を発見する。"R //唇の跡を発見する。R
		【@音無】"（いくぞ…）"R //（いくぞ…）R
		"俺はそこに唇を当てながら、中身をゆっくり味わいつつ飲み干した。"R //俺はそこに唇を当てながら、中身をゆっくり味わいつつ飲み干した。R
		"つまりは、間接キスと、岩沢の唾液を少量と言えど、飲み込んだ、そのふたつの行為を達成したことになる。"R //つまりは、間接キスと、岩沢の唾液を少量と言えど、飲み込んだ、そのふたつの行為を達成したことになる。R
		【@音無】"（自分で引くぜ…）"R //（自分で引くぜ…）R
		
		@おかしい音無２=1
		@岩沢と話して間接キスした=1
		@実績チェック

	}ELSE{	// IF(@選択==1){		// (やる/やめておく) やめておく

		"やめておこう。喉が渇いた時、気軽に飲めばいい。"R //やめておこう。喉が渇いた時、気軽に飲めばいい。R

		GOTO #TORIAEZU

	}

}ELSE{	// IF(@選択==0){		// (喉が渇くまで持ち歩く/すぐさま間接キスに挑む) 喉が渇くまで持ち歩く

	"俺は所持金０なので、助かる。"R //俺は所持金０なので、助かる。R

	#TORIAEZU
	"とりあえず上着のポケットに仕舞っておいた。"R //とりあえず上着のポケットに仕舞っておいた。R

	@岩沢と話しだけ=1

}		// (喉が渇くまで持ち歩く/すぐさま間接キスに挑む) 

