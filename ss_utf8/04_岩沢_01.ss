;－－－□部室棟の廊下
//－－－□学習棟Ａ棟の空き教室		// こちらジャマイカ（西
//@bg(ep88_bg016)

IF(@０１日ひとりで行動==0 && @DAYS==1){		;;一日目、ひなたと一緒に行動してる場合
	
	@移動(ep99_bg001)
	
	@bs(hn0403)
	KOE(990300067,010)【@日向】"「你想去见岩泽吗？」"R //「岩沢に会いたいのか？」R
	【@音無】"「嗯」"R //「ああ」R
	
	@bf(hn0407_03)
	KOE(990300069,010)【@日向】"「她们下午一般都在社团活动室里练习，还是不要去打扰她们比较好哦？」"R //「午後は部室で練習してるから、邪魔しないほうがいいぜ？」R
	【@音無】"「那上午呢？」"R //「午前は？」R
	
	@bf(hn0401)
	KOE(990300071,010)【@日向】"「岩泽会一个人作曲或者作词。最好也不要打扰她」"R //「岩沢ひとりで作曲や作詞をしてるよ。それもあまり邪魔するな」R

	IF(@０１日気がある||@その気さらにあり){

		【@音無】"「好，了解！」"R //「ああ、了解！」R
		
		@bs(hn0108)
		KOE(990300076,010)【@日向】"「你这也太通情达理了…」"R //「ものすごいものわかりのよさだな…」R

	}ELSEIF(@０１日ホモ疑惑||@さらにホモ疑惑){
		
		【@音無】"「是吗…」"R //「そうか…」R
		【@音無】"「你是为了不让我去见岩泽，才这么说的吧…」"R //「俺と岩沢を会わせないために言ってるのか…」R
		
		@bs(hn0104)
		KOE(990300082,010)【@日向】"「你在说什么啊。这样做对谁有什么好处吗？」"R //「何言ってんだよ。そんな誰も得しないことなんか言わねーぜ？」R
		【@音無】"（不就是对你自己有好处吗——！！）"R //（お前が得するだろぉーー！！）R
		"我把这些想法咽到了嘴里，继续保持着沉默。"R //その思いは口にせず、黙ったままでおく。R

	}ELSE{

		【@音無】"「这样啊…」"R //「そうか…」R

	}

	@０１日日向から岩沢の行動パターン聞いた=1

	return(-1)		//遭遇フラグ立てない

}


;－－－●↓2で合ってるよね？R	合ってないかな。１日目で、１人で来た場合、という条件　それ以外はオペレーションで聞いた体（魁
IF(@DAYS==1){

	;;@bg(ep03_bg017, 25)
	@bg(EP88_BG007, 25)
	
	//	シーンの繋ぎを滑らかにするために一文追記		西村
	"对校内的构造不甚了解的我，正漫无目的地走着，来到了一间略有嘈杂的教室前。"R //学校内の構造もよくわからないままフラフラ歩いていると、微かに騒がしい教室に辿り着いた。R
	"在这种地方闹腾，是要干什么呢。"R //こんな場所で何をしてるんだろう。R

	@bgm_play(Alchemy2, 5000,3000)

	"首先能听到的是声音。"R //まず音が聞こえてきた。R
	"走近之后，发现是音乐，并且还是摇滚乐。"R //近づくにつれ、それが音楽であり、ロックバンドの曲であることがわかってきた。R
	【@音無】"（难道是在放CD之类的东西吗…？）"R //（ＣＤでもかけてるのか…？）R

	close
	@回想開始スタック
	@bgs(ep01_bg053, yr0101)
	KOE(040000013,002)【@ゆり】"「你很快就能亲耳见证到她的活跃了」"R //「彼女の活躍はすぐ耳にすることになると思うわ」R
	@回想終了スタック

	【@音無】"（该不会，现在正在演奏音乐吧…）"R //（まさか、この曲を今演奏し、歌っているというのか…）R

}else{

	;;@bg(ep03_bg017, 25)
	@bg(EP88_BG007, 25)

	@bgm_play(Alchemy2, 3000)

	;;廊下にまで反響するこの音は…。R
	;;確か、オペレーション中に聴いた曲だ。R
	;;トルネードの時はCrowSongなので、曲でなく歌声に変更（魁0418
	"走廊里回响着的这首歌…。"R //廊下にまで反響するこの歌声は…。R
	"应该就是作战时听到的声音。"R //確か、オペレーション中に聴いた声だ。R

}

