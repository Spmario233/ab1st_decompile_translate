		ＴＫ, @制御２,
		野田, @制御３,
		藤巻, @制御４,
		日向, @制御５
	)@selbtn_log
	if(@選択==0){	// ＴＫ
		
		ＴＫ。あいつは基本、日本語を喋らないので、今回の作戦には最適だ。R
		
		;－－－移動　廊下
		@移動(ep03_bg010)		/// 廊下
		
		if(@制御５==0){			;－－－★★★★すでに日向が居る場合
			@face(hn0403)
			KOE(005000676,010)【@日向】「お、ＴＫじゃん」R
			
		}elseif(@制御４==0){	;－－－★★★★日向が居なくてすでに藤巻が居る場合
			;;@bs(fj0101)
			;;KOE(005000678,013)【藤巻】「お、ＴＫじゃねぇか」R
			
		}elseif(@制御３==0){	;－－－★★★★日向と野田(←藤巻だよね？/西)が居なくてすでに野田が居る場合
			@face(nd0301)
			KOE(005000680,011)【@野田】「ＴＫじゃないか」R
		}
		
		頭を地面につけてくるくる回っているＴＫを見つけた。R
		
		@制御２ = @制御３+@制御４+@制御５

		@bs
		
		if(@制御２ < 3){
			
			;－－－★★★★すでに複数の場合
			【@音無】「なあ、ＴＫ。ちょっと穏やかじゃない事態が起きているんだ。俺たちに付き合ってくれないか」R
			
		}else{
			
			【@音無】「なあ、ＴＫ。ちょっと穏やかじゃない事態が起きているんだ。俺に付き合ってくれないか」R
			
		}
		
		@bs(tk0308@r3)
		KOE(030000730,016)【ＴＫ】「ｈｏ！」R
		フー！と言われても、ＯＫなのかＮＯなのかわからない…。R
