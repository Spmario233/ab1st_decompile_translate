			【@音無】「それにはわけがあるんだ。この後、それは教える。とにかく手助けしてくれないか」R
			
		}else{		// else がないので勝手に作る（西
			@bs(fj0107)
			;;KOE(005000734,013)【藤巻】「あん？　どーしたってんだ」R		//音声ない
			//KOE(001011600,013)【藤巻】「…ん？　なんだ、てめーか」R		// 風呂加工されてるっつの
			KOE(005000729,013)【藤巻】「…ん？　なんだ、てめーか」R
			//	謎の ＿重複 表記を削ります		西村
			//【@音無＿重複】「手助ってほしいことがあるんだ」R
			【@音無】「手助ってほしいことがあるんだ」R
			
		}
		
		@bs(fj0102)
		KOE(030000750,013)【藤巻】「よくわかんねーが、わかったぜ」R
		
		@bs
		
		単純で助かる。R
		
		
		@制御４ = 0

	}else{				// 日向
		
		@移動(ep88_bg027)		/// エントランス
		
		@制御５ = @制御２+@制御３+@制御４
		
		if(@制御５==1){			;－－－★★★★すでにふたり居る場合
			@bs(hn0403)
			KOE(005000743,010)【@日向】「ん？　どうした、お前ら」R
			
		}elseif(@制御５==0){	;－－－★★★★すでに三人以上居る場合
			@bs(hn0403)
			KOE(005000746,010)【@日向】「ん？　どうした、揃いも揃って」R
		}
		

		IF(@その気さらにあり==1){
		
			//	チェックシート修正。「俺」が抜けてると思うので、挿入		西村
			//【@音無】「日向…にはおまえが必要だ」R
			【@音無】「日向…俺にはおまえが必要だ」R
			
			@bs(hn0104)
			KOE(030000755,010)【@日向】「なに水くさいこと言ってんだよ。お前の頼みとあらばなんでもやってやんよ」R
			【@音無】「ありがとう、本当にありがとう」R
			
			@bgs_nf(hn0114_13, 2)
			
			どさくさに紛れて、抱き締めてみる。R
			とても温かかった。R
			
			@bgs_fe("none", 2, 1, 2)
			
		}ELSE{
			【@音無】「日向…男の頼みを聞いてくれるか…」R
			@bs(hn0104)
			KOE(030000755,010)【@日向】「なに水くさいこと言ってんだよ。お前の頼みとあらばなんでもやってやんよ」R
			【@音無】「恩に着る」R
			単純で助かる。R
			@bs
		}
		@制御５ = 0

	}		// 四択

}		// while

