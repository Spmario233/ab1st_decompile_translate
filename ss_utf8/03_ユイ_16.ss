		}else{
			
			ユイはなんで筋トレをしているんだろう。R
			IF(@岩沢消えた==1){		;;ガルでデモ、岩沢がヴォーカル
				ガルデモのボーカルとして、発声をよくするために腹筋をするならわかるが。R
			}ELSE{
				発声をよくするために腹筋をするならわかるが。R
			}
			やはり全身バランスよく筋肉をつけなきゃいけない物なんだろうか。R
			
		}
		
		@bs(bs1_yi0109@u1)
		
		ユイはもそもそと起き上がり、また腕立て伏せを始めた。R
		
		@fade(bg_kuro, 25)
		
		俺はしばらくその様子を眺めてから、駐車場を後にした。R
		
		goto #OWARI
		
	}						// (声をかける/そっとしておく) 選択肢処理のケツ
	
}		// IF(@岩沢消えた==0) else					// 追記。ちゃんとインデントしてたら避けられるミス。（西


#OWARI

@bgm_stop(2000)
@fade(bg_kuro, 25)

return
