				【@音無】（えぇ！？　それじゃ、俺が上に行くだけじゃないか！！）R

			}else{

				【@音無】（それはなんとなく嫌だな…）R

			}

			【@音無】「いや、やっぱこのままでいい」R
			
			@face(hn0108)
			KOE(001401896,010)【@日向】「えーーー、なんだよ、たたみかけてたのに…」R
			【@音無】「すまん…」R
			
			@face(hn0109)
			KOE(001401898,010)【@日向】「じゃ、改めておやすみ」R
			【@音無】「おやすみ」R
				
			GOTO #NEMURU

		}		// IF(@AB04いやらしい漫画読み始めた==1) else

	}ELSE{	// IF(@選択==2){		// (素直に話す/はぐらかす/糞した) 

		@bgm_stop(200)
		【@音無】「糞した」R
		
		@face(hn0106)
