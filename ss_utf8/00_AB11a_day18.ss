			KOE(001401654,010)【@日向】「ま、いいけどさ…すげー理不尽を感じるぜ…」R
		}else{
			【@音無】「もちろん！！」R
			@face(hn0108)
			KOE(001401659,010)【@日向】「すげーいい返事だな…」R
		}
		俺は勉強を始めた。R
		//GOTO #BENNKYOUO
	;;■■コメントアウト待避296■■
	}else{
		【@音無】「ああ」R
		一言だけ答えて、勉強を始めた。R
	}
	//#BENNKYOUO
	@AB11勉強を始めた=1
	GOTO #SYUUSHIN
}
*/


IF(@AB11日向目が見えない){

	@bs(hn0109_07)
