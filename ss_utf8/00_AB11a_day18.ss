		@bg(ep99_bg004, 2)		;－－－消灯
		
		@face(hn0105)
		KOE(001401604,010)【@日向】「おいおいおい、マジかよっ！？　点けるぞ！？」R

		@bs(hn0105)
		【@音無】「今日だけは許してくれ、すまん」R
		
		@bs(hn0208)
		KOE(001401606,010)【@日向】「…ちっ！」R
		
		@bs(hn0209)
		KOE(001401607,010)【@日向】「そこまで言うんなら、わかったよっ。今日だけだからな」R
		【@音無】「ああ。ありがとう！」R
		
		@bs
