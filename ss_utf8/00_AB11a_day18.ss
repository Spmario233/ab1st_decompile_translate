			それだけは俺にもどうすることもできない。R

//		}IF(@選択==1){		// (放っておく/一喝する/煙を手刀で斬り続ける) 一喝する
//		k-takahashi ↓elseifに修正します
		}elseif(@選択==1){		// (放っておく/一喝する/煙を手刀で斬り続ける) 一喝する

			IF(@おかしい音無１==1||@おかしい音無２==1||@おかしい音無３==1){
				
