// #SCENE_SCRIPT_ID = 0014 （スクリプトＩＤ：この行は削除したり、変更したりしないで下さい）R
#Z00
;－－－水曜日
//@DAYS=18	***********旧設定***********
@DAYS += 1	@day_change	// 18日目
$bs_dress_init

;－－－●↓このファイルからホモ太関係のフラグ参照していない…汗
/*
;－－－朝
IF(@AB10壁に銃を撃って跳弾し死ぬ){

	陽が目に染みて、自然と目覚める。R
	【@音無】（朝か…）R
	辺りを見渡すと、地面に倒れていた。R
	足場から落ちたようだ。R
	最後に銃で見えない壁を撃ったはず。R
	再び、俺は足場を登る。R
	明るければ、壁の向こうが見えるはず。R
	そう期待したが、そこに待っていたのは、一面雲に覆われた世界。R
	【@音無】（まさか…浮いているのか…！？）R
	雲は動いてはいるが、あまりにぶ厚く、どれだけ待っても地面も空も見えなかった。R
	そうだ、と思い出し、銃でもう一度撃ってみる。R
	スカンと変な音がして、何かがぽろりと落ちる。R
	それを摘まみ上げて確認してみると、平べったくなった今撃った銃弾だった。R
	【@音無】（なんてこった…）R
	再び、絶望する…。R
	重い足取りで、部屋に帰る。R

}
*/

@bgm_play(m301)
;－－－
;;IF(@AB10壁に銃を撃って跳弾し死ぬ){		//■■■■削除予定なので放置。でも一部は残したいなぁ（あまの
//IF(@その気さらにあり){		//▼▼▼参照フラグを変更して、下記のシナリオを活用します。（魁0327
IF(@その気さらにあり||(@おかしい音無１==1||@おかしい音無２==1||@おかしい音無３==1||@おかしい音無４==1)){		//■■■■どれかのフラグが立ってたときのみ入るようにした（あまの 0401
	
	@日向服装=@ジャージ
	
	@bg(ep99_bg005, 143)

	カーテンの隙間から差し込む光で目が醒める。R
	日向はすーぴーと鼻を鳴らしながら眠っていた。R
	起こすにはまだ早い時間だ。R

	@@選択=SELBTN(@selbtn_s_3,
		もう少し眠る,
		日向の隣で寝る,@その気さらにあり,
		起こす,(@おかしい音無１==1||@おかしい音無２==1||@おかしい音無３==1||@おかしい音無４==1)		//■■■■こうしないとシナリオ抜けが発生します（あまの）
	)@selbtn_log
	IF(@選択==0){		// (もう少し眠る/日向の隣で寝る/起こす) もう少し眠る
		
		@fade(bg_kuro, 145)
		
		俺は布団に潜り、目を閉じた。R
		
		close
		@timewaitkey(3000)

	}ELSEIF(@選択==1){		// (もう少し眠る/日向の隣で寝る/起こす) 日向の隣で寝る
		
		@bgm_stop(2000)
		
		俺は二段目に登り、日向の布団に潜り込んだ。R
		
		@bgs_nf(hn0113, 3)
		@bgm_play(m120, 1000)
		
		【@音無】（なんて温かいんだ…）R
		すーぴーすーぴー。R
		【@音無】（そして、なんて可愛らしい寝息なんだ…）R
		
		@bgm_stop(3000)
		@ピンクフィルター消去
		@fade(bg_kuro, 146)
		
		しばらくその顔を見つめていたが、さすがに睡眠不足だったのか、俺も寝入ってしまった。R
		
		close
		@timewaitkey(3000)
		
		@pcmch_play_loop(1, @目覚まし時計, 800)
		ぴっぴっぴ…と目覚まし時計の音。R
		
		@pcmch_stop_all
		@bg(ep99_bg001, 143)
		
		@bs(bs3_hn0101)
		KOE(001400054,010)【@日向】@bc「ふわぁ…って、なんでお前が居るんだぁーー！！」@bs_c(1200, hn0106)@横揺れ_弱 R

		@bgm_play(m118)
		
		【@音無】「むにゃむにゃ…おはよう」R

		@bs(bs2_hn0209_07@00a)
		KOE(001400056,010)【@日向】「いやいや、いつの間に添い寝状態に！？」R

		@@選択=SELBTN(@selbtn_s_3,
			底が抜けてお前が落ちてきた,
			すごい寝返りをした,
			夢遊病
		)@selbtn_log
		IF(@選択==0){		// (底が抜けてお前が落ちてきた/すごい寝返りをした/夢遊病) 底が抜けてお前が落ちてきた

			【@音無】「底が抜けてお前が落ちてきた」R
			
			@bs(hn0206)
			KOE(001400066,010)【@日向】「えっ！？」R
			
			@bs(hn0108)
			KOE(001400067,010)【@日向】「って、上段じゃねーか！　落ちようがねーだろっ！！」R
			【@音無】「間違えた、俺が浮き上がってきたんだ」R
			
			@bs(hn0306)
			@縦揺れ_弱
			KOE(001400069,010)【@日向】「言い訳が雑ぅーーーー！！」R
			
			@bs(hn0305)
			KOE(001400070,010)【@日向】「人が浮き上がって、上段の板も通り抜けて上がってくるはずねぇだろぉーー！！」R

			GOTO #MATTAKUKONO

		}ELSEIF(@選択==1){		// (底が抜けてお前が落ちてきた/すごい寝返りをした/夢遊病) すごい寝返りをした

			【@音無】「すごい寝返りをしたようだ…」R
			
			@bs(hn0105)
			KOE(001400083,010)【@日向】「なら床に落ちるだろっ！　上段にあがっては来ねーだろっ！！」R

			GOTO #MATTAKUKONO

		}ELSE{	// IF(@選択==2){		// (底が抜けてお前が落ちてきた/すごい寝返りをした/夢遊病) 夢遊病

			【@音無】「夢遊病だ」R
			
			@bs(hn0105)
			KOE(001400090,010)【@日向】「そんな病気はこの世界じゃ治ってるはずだぁーー！！」R

			IF(@ゆりただのエロ少年にイラっとする==1||@ゆりただのエロ少年にイラっとする２==1||@ゆりただのエロ少年にイラっとする３==1||@ゆりただのエロ少年にイラっとする４==1){	// ||@ゆりただのエロ少年にイラっとする５==1){

				【@音無】「なら俺の記憶は戻ってるはずですが、何か？」R
				
				@bs(hn0306)
				@横揺れ_弱
				KOE(001400095,010)【@日向】「それ、俺もイラっと来るぅーー！！」R

			}else{

				【@音無】「でも、記憶喪失も治ってねーし」R

			}

			#MATTAKUKONO
			
			【@音無】「まったくこの世界は謎だらけだな…こういうこともある。いい経験になったろ…？」R
			
			@bs(hn0112)
			KOE(001400074,010)【@日向】「ええぇぇぇーーー！！」R
			【@音無】「無限に続く世界だから、まあ、こんなこともあるさ…」R
			
			@bs(hn0108)
			KOE(001400076,010)【@日向】「ええぇぇぇーーー！！」R
			【@音無】「さ、顔洗って着替えて、飯行こうぜ？」R
			
			@bs(hn0606)
			@横揺れ_弱
			KOE(001400078,010)【@日向】「ええぇぇぇーーー！！」R

		}		// (底が抜けてお前が落ちてきた/すごい寝返りをした/夢遊病) 
		
		@bgm_stop(2000)
		
		GOTO #SYOKUDOU

	}ELSE{	// IF(@選択==2){		// (もう少し眠る/日向の隣で寝る/起こす) 起こす
		
		@縦揺れ_弱
		
		【@音無】「起きろ、朝だぞぉー！！」R
		はしごを登り、大声で日向にそう告げる。R
		
		@face(hn0113)
		KOE(001400111,010)【@日向】「んんー…」R
		唸るだけで、起きない。R

		//IF(@おかしい音無１==1||@おかしい音無２==1||@おかしい音無３==1||@おかしい音無４==1){		//■■■■この条件でしか入れないように変更したのでコメントアウト（あまの）

		@@選択=SELBTN(@selbtn_s_2,
			鼻をつまむ,
			目つぶしする
		)@selbtn_log
		IF(@選択==0){		// (鼻をつまむ/目つぶしする) 鼻をつまむ

			日向の鼻を息ができないようにつまむ。R
			
			@face(hn0113_14)
			KOE(001400123,010)【@日向】「んっ…」R
			
			@face(hn0110_09)
			KOE(001400124,010)【@日向】「んんんっ…」R
			
			@bs(bs3_hn0106@u3)
			@縦揺れ_弱
			KOE(001400125,010)【@日向】「ぷはあぁぁーーー！！　ああぁぁーー！？」R

			@bs(hn0105)
			起きた途端、俺の顔を見る。R
			
			@bs(hn0208)
			KOE(001400127,010)【@日向】「お前かよっ…なにしてくれてんだよ…」R

			@bs(bs2_hn0209@00a)
			
			日向は目覚まし時計を確認する。R
			
			@bs(hn0209_07)
			KOE(001400129,010)【@日向】「１時間も早いじゃねーか…」R
			【@音無】「早起きは三文の徳だぜ？」R
			
			@bs(hn0209)
			KOE(001400131,010)【@日向】「なんの得になるんだよ…」R
			【@音無】「うーん…健康的に」R
			
			@bs(hn0108)
			KOE(001400133,010)【@日向】「だから、病まない世界だから、んなもん関係ねーんだよ…」R
			【@音無】「だったな、わりぃ…」R

			IF(@日向とキャッキャウフフした>=1){

				@bgm_stack
				@bgm_stop(2000)
				
				@bs(hn0102)
				KOE(001400138,010)【@日向】「反省の色が見られない。なので、こうしてやるーー！！」R

				@bgm_play(m090)		;;キャッキャウフフスタート！
				@timewaitkey(1000)
				@キャッキャウフフ開始(hn0102, 3)

				日向が起き上がり、俺の鼻と口を両手で塞いでくる。R
				よけようとすると、はしごから落ちてしまう。激痛が走り、動けなくなる。R
				
				@bs_w(2, hn0103)
				KOE(001400141,010)【@日向】「勝機！」R
				その床に倒れた俺に日向が襲いかかってくる。R
				
				@bs_w(2, hn0102)
				KOE(001400143,010)【@日向】「このやろぉーー！！」R
				【@音無】「打撲、打撲ーー！！」R
				
				@bs_w(2, hn0104)
				KOE(001400145,010)【@日向】「そんなこと知るかぁーー！！」R
				
				マウントポジションを取られ、口と鼻を押さえられる。R
				;;KOE(001400147,010)【@日向】「だもむ…ももふ…！！」R
				【@音無】「だもむ…ももふ…！！」R
				
				手で床を叩く。R
				
				@bs_w(2, hn0102)
				
				KOE(001400149,010)【@日向】「タップしても許さねーぜ！？」R
				その手を噛んでやる。R
				
				@bs_w(2, hn0104)
				//@横揺れ_弱
				KOE(001400151,010)【@日向】「いてぇーー！！　噛むのは反則だろぉーー！！」R
				;;KOE(001400152,010)【@日向】「ここから反撃だぁーー！！」R
				【@音無】「ここから反撃だぁーー！！」R

				ひるんだ日向を押し倒し、逆にマウントポジションを取り、その鼻と口を押さえてやる。R

				@bs_w(2, hn0102)
				
				がぶっ。R

				//@縦揺れ_弱
				
				【@音無】「いてぇーー！！　噛むのは反則だろぉーー！！」R
				
				@bs_w(2, hn0104)
				KOE(001400156,010)【@日向】「先にお前が噛んだんじゃねーかよぉーー！！」R
				
				@bgm_stop(3000)
				@キャッキャウフフ終了フェード
				
				また、ふたりでキャッキャウフフした。R

				@噛みつきながらキャッキャウフフした=1
				@実績チェック
				
				@キャッキャウフフ終了(ep99_bg005)
				
				@bgm_pop_play
				【@音無】「ふぅ…はぁ…はぁ…」R
				
				@bs(hn0109)
				KOE(001400159,010)【@日向】「はぁ…はぁ…なぜこんな時間から、ハッスルしなくちゃならないんだ…」R
				【@音無】「だな…」R

			}

			
			@bs(hn0109_07)
			KOE(001400164,010)【@日向】「あーあ、完全に起きちまったし…早いが、顔洗って着替えて、朝食に行くか」R
			【@音無】「こんな時間でも、やってるのか？」R
			
			@bs(hn0101)
			KOE(001400166,010)【@日向】「ああ。部活で朝練してるＮＰＣも居るからなぁ」R
			【@音無】「なるほど…」R

			GOTO #SYOKUDOU

		}
		// IF(@選択==1){		// (鼻をつまむ/目つぶしする) 目つぶしする

		人差し指と中指をＶ字に立て、日向の瞼に思い切り突き刺す。R
		
		close
		@sc_flash_w
		@横揺れ_弱
		
		@bs(bs3_hn0610@u3)
		@縦揺れ_弱
		KOE(001400172,010)【@日向】「ぎゃあああぁぁぁああぁぁあああーーーーー！！」R

		@AB11日向目が見えない=1
		@実績チェック

		【@音無】「起きたか、おはよう」R
		
		@bs(bs2_hn0606)
		@横揺れ_弱
		KOE(001400174,010)【@日向】「どんな起こし方だぁぁぁぁーーー！！　痛えぇぇぇーー！！　視力がまだ戻らないぃぃーー！！」R
		【@音無】「まあ、死後の世界だから、すぐ治るさ」R
		
		@bs(hn0605)
		KOE(001400176,010)【@日向】「まだ見えないぃぃーーー！！」R
		【@音無】「だから、すぐ治るって」R

		IF(@日向とキャッキャウフフした>=1){

			@bs(hn0102)
			KOE(001400181,010)【@日向】「てめーにも仕返ししてやるぅー！！」R
			
			@bgm_stack
			@bgm_play(m090)		;;キャッキャウフフスタート！
			@timewaitkey(1000)
			@キャッキャウフフ開始(hn0102, 3)
			
			@bgm_stop(3000)
			
			@キャッキャウフフ終了フェード準備
			
			@bs(hn0108)
			KOE(001400182,010)【@日向】「ってこれまではじゃれ合ってきたが、今回はあまりに悪質だ…」R
			
			@bgs(ep99_bg005, bs2_hn0108, 2)
			
			【@音無】「えぇっ！？」R
			
			@bs(hn0105)
			KOE(001400184,010)【@日向】「もう二度とこんなことすんじゃねーぞ」R
			
			@bgm_play(m090)		;;キャッキャウフフスタート！
			@キャッキャウフフ開始(hn0105, 3)
			
			【@音無】「と、言いながらぁー！？」R
			
			@キャッキャウフフ終了フェード準備
			@bgm_stop
			@bgm_pop_play
			@bs(hn0108)
			
			KOE(001400186,010)【@日向】「はぁ？　なんもないぜ？　二度とすんなよ」R

			@bgs(ep99_bg005, bs2_hn0108, 2)

			【@音無】「あれ？　ガチで叱られてる？」R
			
			@bs(hn0105_09)
			KOE(001400188,010)【@日向】「ああ、ガチで叱ってる。まだぼやけて見えねーし」R
			
			@bs(hn0108)
			KOE(001400189,010)【@日向】「だから、こんなこと二度とすんなよ。いいな？」R
			【@音無】「ああ…」R
			
			@bs(hn0109_07)
			KOE(001400191,010)【@日向】「くっそ、すぐには治らねぇ…面倒な一日になりそうだぜ…」R

			@AB11日向にガチで叱られた=1

		}else{

			
			@bs(hn0105)
			KOE(001400198,010)【@日向】「そんなすぐ治るかよっ！」R
			
			@bs(hn0208)
			KOE(001400199,010)【@日向】「くっそ、面倒な一日になりそうだぜ…」R
			【@音無】「ええと…それは…すまん」R
			
			@bs(hn0105)
			KOE(001400201,010)【@日向】「ほんとだよっ！　ったく…」R

		}		// IF(@日向とキャッキャウフフした>=1)

		@bs(hn0116@06)
		KOE(001400209,010)【@日向】「俺はしばらく休んでおく。てめーはほら、これで朝飯食ってこい」R
		
		@bs
		
		無造作に食券がばらまけられる。R
		
		IF(@朝食のチケットは平等){

			その中から、朝定食Ａを取り上げる。R

			@AB11朝定食Ａ=1

		}else{

			その中から、比較的胃に軽そうな秋刀魚塩焼き定食の食券を取り上げる。R

			@AB11秋刀魚塩焼き定食=1

		}

		;－－－食堂
		@移動(ep05_bg047)
		
		@pcmch_play_loop(1, @ガヤ,1300)

		受け取り口でお盆を受け取ると、実に朝ご飯らしいものが並んでいた。R
		//IF(@その気さらにあり){		//シナリオ抜けが発生してるので条件式を削除（あまの）

		でも、さすがに俺のせいで、朝食を食べられなくなった日向のことを考えると胸が痛い…。R

		@pcmch_stop(1, 5000)

		@@選択=SELBTN(@selbtn_l_3,
			せめてご飯を握って日向にあげる,
			せめて秋刀魚にかけるカボスを日向にあげる,@AB11秋刀魚塩焼き定食,
			せめて納豆を日向にあげる,@AB11朝定食Ａ
		)@selbtn_log
		IF(@選択==0){
			
			@bg(ep06_bg015, 25)
			
			俺はおかずを食べ終えた後、ご飯茶碗をひっくり返し、手に載せると塩をふりかけつつ、おにぎりにした。R
			@AB11日向におにぎり作った=1

		}ELSEIF(@選択==1){

			@bg(ep06_bg015, 25)
			
			カボスを秋刀魚にかけることなく、食べ終えた。R
			@AB11日向にカボスを残した=1

		}ELSE{	// IF(@選択==2){

			@bg(ep06_bg015, 25)
			
			納豆はパックだったので、持ち運びやすい。それを残し、食べ終えた。R
			@AB11日向に納豆を残した=1

		}

		IF(@AB11朝定食Ａ==1) {
			@食券朝定食Ａ=1
		}
		ELSEIF(@AB11秋刀魚塩焼き定食==1) {
			@食券秋刀魚塩焼き定食=1
		}
		@実績チェック
		
			
		;－－－自室
		@fade(bg_kuro, 25)
		//	ここで服装戻しておくべき？
		//	まだ安静にしている状態なので、シーン末尾までジャージにしておきます		西村
		//@日向服装 = @戦線制服
		
		トレーを返し、部屋に戻る。R

		@移動(ep99_bg001)

		【@音無】「戻った」R
		
		@face(hn0113_09)
		KOE(001400258,010)【@日向】「ああ、おかえり」R
		日向はベッドで寝たままでいた。R
