		GOTO #HINATANIMORATTA

	}else{

		呆然と立ち尽くす。R

	}

}
// k-takahashi ↓くくらないとおかしくなるのでelseでくくります
else
{
	腹が減ったな…。R

	IF(@二日目で食券もらった){

