// ====================================================================
// 演出用マクロ（鈴木）
// ====================================================================





// =================================================
// 背景スタック
// =================================================
#macro	@bg_stack_push
			$$bg_stack(1)
#macro	@bg_stack_pop
			$$bg_stack(0)
#macro	@bg_stack_pop_name
			$$bg_stack_pop_name

// =================================================
// CG表示_背景スタックつき
// =================================================
#macro	@cg1_bg_stack_push(@CG_NAME, @WIPE_NO(3), @WAIT(1))
			@bg_stack_push
			@CG1(@CG_NAME, @WIPE_NO, @WAIT)


// =================================================
// 松下用バストショットコマンド
//「@松下がスリムになった」を参照して自動でmtとmsを切り替える
// 引数がmtでもフラグオンならmsに変わります
// ※bs1からbs3にも対応
// 入力例）@bsmt(mt01),@bsmt(mt0102),@bsmt(bs2_mt0102_06)
// =================================================
#macro	@bsmt(@bs_name)
			$$stg_macro_bsmt(@bs_name)

// =================================================
// 松下用フェイスコマンド
//「@松下がスリムになった」を参照して自動でmtとmsを切り替える
// 引数がmtでもフラグオンならmsに変わります
// =================================================
#macro	@facemt(@bs_name)
			$$stg_macro_facemt(@bs_name)

// =================================================
// 松下のバストショット表示用の名前取得
//「@松下がスリムになった」を参照して自動でmtとmsを切り替える
// 引数がmtでもフラグオンならmsに変わります
// ※名前だけを取得するので他のマクロを噛ませたい時に使います
// 例）@bs_set(0, @bsmtn(mt0102_03), @pos_c)
// =================================================
#macro	@bsmtn(@bs_name)
			$$stg_macro_bsmtn(@bs_name)


// 犬視点バストショット系は現状ゆりのbs2のみ対応
// 他のキャラで使う場合は、@pyに適切なY座標を設定して下さい
// 複数キャラを立たせたい場合は、@pxに適切なX座標を設定して下さい

// =================================================
// 犬視点バストショット表示待ち
// =================================================
#macro	@bs_set_dog(@bs_name, @py(@pos_ft2), @px(@pos_c))
	@bs_set(0, @bs_name, @px, @pos_z, @py)

// =================================================
// 犬視点バストショット表示
// =================================================
#macro	@bs_dog(@bs_name, @wipe_no(3), @py(@pos_ft2), @px(@pos_c))
	@bs_set_dog(@bs_name, @py, @px)
	@wipe(@wipe_no)

// =================================================
// 犬視点バストショット表示＋顔(with face)
// =================================================
#macro	@bs_dog_wf(@bs_name, @wipe_no(3), @py(@pos_ft2), @px(@pos_c))
	@bs_set_dog(@bs_name, @py, @px)
	@wipe(@wipe_no)
	@face(@bs_name)

// =================================================
// 犬視点背景表示
// デフォルト Y座標0 1.5倍拡大表示
// =================================================
#macro	@bg_dog(@bg_name, @py(0), @scl(150))
	//@bg_n(@bg_name)
	@bg_set(@bg_name, 0, 0, @py, 255, 0, @scl, @scl)



// =================================================
// 松下ルートの似顔絵依頼回数のカウンタ
// ユイと岩沢を分ける必要がない使い方をするので排他にしてない
// =================================================
#macro	@松下ルート似顔絵打診カウント
	@松下ルートユイに似顔絵 + @松下ルート岩沢に似顔絵 + @松下ルートひさ子に似顔絵 + @松下ルート入江に似顔絵 + @松下ルート関根に似顔絵





// =================================================
// 関数定義
// =================================================
#command $$bg_stack(int)
#command $$bg_stack_pop_name : str

#command $$stg_macro_bsmt(str)
#command $$stg_macro_facemt(str)
#command $$stg_macro_bsmtn(str) : str

