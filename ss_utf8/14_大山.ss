}elseif(@メガネ仲間){
	KOE(000202970,014)【大山】「じゃ、僕は行くね！　色々あるだろうけど、頑張ってね、メガネ仲間くん！」R
}elseif(@暗算日本記録保持者){
	KOE(000202972,014)【大山】「じゃ、僕は行くね！　色々あるだろうけど、頑張ってね、暗算日本記録保持者くん！」R
}elseif(@通り魔){
	KOE(000202974,014)【大山】「じゃ、僕は行くね！　色々あるだろうけど、頑張ってね、通り魔くん！」R
}elseif(@記憶ナシ男){
	KOE(000202976,014)【大山】「じゃ、僕は行くね！　色々あるだろうけど、頑張ってね、記憶ナシ男くん！」R
}elseif(@音速){
	KOE(000202978,014)【大山】「じゃ、僕は行くね！　色々あるだろうけど、頑張ってね、音速くん！」R
}elseif(@音無){
	KOE(000202980,014)【大山】「じゃ、僕は行くね！　色々あるだろうけど、頑張ってね、音無くん！」R
}else{		//(@無限)
	KOE(000202982,014)【大山】「じゃ、僕は行くね！　色々あるだろうけど、頑張ってね、無限くん！」R
