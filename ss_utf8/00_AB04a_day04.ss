		IF(@その気さらにあり){
			【@音無】「いや、ひとっ風呂浴びれば元気になれる、そんな気がする…」R
			
			@bs(hn0104)
			KOE(000502117,010)【@日向】「そっか。じゃまだ早い時間だけど早速風呂行くか」R
			【@音無】「ああ」R

			GOTO #HINATAOSHIRI

		}

		@fade(bg_kuro, 25)
		
	}elseif(@裸の日向を見つめた==1){

		【@音無】「ああっ！」R
		
