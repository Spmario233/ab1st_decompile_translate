}ELSE{		// IF(@ゆりへの思い日向がなんとかしてくれる==0)

	#JAAHURO
	
	//この時点で寮の背景が表示されているはず（あまの
	@bs(hn0101)
	KOE(000502108,010)【@日向】「じゃ、風呂行くか」R

	IF(@岩沢に振られた==1||@岩沢と個人的に会えなくなる==1){

		【@音無】「ああ…」R
		
		@bs(hn0109)
