		KOE(000502127,010)【@日向】「相変わらずすげー嬉しそうだな…」R

		#HINATAOSHIRI
		
		@fade(bg_kuro, 25)
		
		;－－－□脱衣所
		@湯気
		@bg(ep88_bg025, 25)
		@日向服装=@上半身裸
			
		@bs(hn0101)
		
		日向のお尻は相変わらずのイケヒップだ…。R
		タオルで隠されているが、もしかして…あそこもイケてるのでは…？R

		@@選択=SELBTN(@selbtn_s_2,
			あそこも確認する,
			そこまではやめておく
		)@selbtn_log
		IF(@選択==0){

			;－－－□大浴場
			@bgs_nf(hn0101)
			
			目を瞑り、頭を洗っている日向のあそこを覗き見た。R
			
			@sc_flash_w
			@pcmch_play(1, @大砲爆発)
			@縦揺れ_弱
			
			【@音無】（なんて、イケチンなんだ！！）R
			理想的。それを美しいとさえ俺は思った。R
			
			//	AB06bの会話整合性をとるためフラグ追加		西村
			@AB04aでイケチン見た=1
			
			@日向のイケチン見た=1
			@実績チェック
			
			@湯気消去
			@fade(bg_kuro, 25)

		}ELSE{	//IF(@選択==1){
			
			@bs
			
			偶然見れるのならまだしも、そこまでの行動は避けておこう…。R
			
			@湯気消去
			@fade(bg_kuro, 25)
		}
		
	}ELSE{

		IF(@０１日ホモ疑惑||@さらにホモ疑惑){

			【@音無】「いや、お前の後に入る…」R
			
			@bs(hn0208)
			KOE(000502157,010)【@日向】「はぁ？　なぜそこまで避けるんだ？」R
			【@音無】「ええと…俺の裸を見せたくないから…」R
			
			@bs(hn0207)
			KOE(000502159,010)【@日向】「ん？　恥ずかしいのか？」R
			【@音無】「ああ…」R
			
			@bs(hn0408)
			KOE(000502161,010)【@日向】「うーん…」R
			
			@bs(hn0404)
			KOE(000502162,010)【@日向】「まあ、いいや。これからは誘うのはやめるよ」R
			【@音無】「それは助かる…」R
			
			@bs(hn0102)
			KOE(000502164,010)【@日向】「なんかあるんだろーな。いいぜ、気にすんな」R
			助かった！R
			
			@fade(bg_kuro, 25)

			日向がジャージ姿で戻ってきたところで、入れ替わり俺は風呂に入った。R

			@日向と風呂入るのが今後ない=1

		}
		else{		//←追加（あまの）
		
			@fade(bg_kuro, 25)
			
			いつものように、ふたり並んでひとっ風呂浴びた。R
		}
		
	}
	
	@日向服装 = @ジャージ
	@bg(ep99_bg003, 25)

}		// IF(@ゆりへの思い日向がなんとかしてくれる==1) & else の処理おわり（なげー）



