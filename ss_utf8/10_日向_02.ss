	@bg(ep05_bg052, 25)		/// テーブル
	
	そう告げて、空いていた椅子につく。R

	@face(hn0107)
	IF(@音無をただのエロ少年と呼ぶ==1){

		KOE(100000864,010)【@日向】「おいおい、どーしたんだよ、ただのエロ少年っ！」R

	}else{

		KOE(100000868,010)【@日向】「おいおい、どーしたんだよ、音無っ！」R

	}
	
	@bs(hn0109)

	【@音無】「一緒に食べると、お前を襲いかねない！！」R
	
	@bs(hn0209_07)
	KOE(100000873,010)【@日向】@bc「えぇ？　俺との身体能力の差、わかってるだろ？　まだまだ新米には負けねーぜ？」@bs_c(4000, hn0204)R
	【@音無】「そうかもしれないけどさ…」R
	
	@bs(hn0102)
	KOE(100000875,010)【@日向】「じゃ、いっただきまーす！」R
	そう言って、俺の前に盆を置き、豚角煮定食を食べ始める。R
	
	@bgm_stack
	@bgm_stop(2000)
	
	歯で切れずとも、とろりと割ける豚角煮を見て、俺はキレた。R

	;－－－●↓バトル
	;－－－●ここからどうする？R
	//	▼▼シーンちょっとだけ新規追加しました▼▼		西村
	@bgm_play(m114)
	@集中線開始
	@bgs_nf(hn0102, 0)
	@縦揺れ_弱
	
	【@音無】「くそおおおーっっ！　そいつをよこせぇぇーーっ！！」R
	
	@bf(hn0107)
	
	日向に飛びかかる。R
	正面からまともに向かっても敵わないとわかっていながら、自分を抑えることができなかった。R
	
	@bf(hn0106)
	@横揺れ_弱
	
	KOE(000901811,010)【@日向】「はああぁぁぁあーー！？」R
	
	@縦揺れ_弱
	
	【@音無】「俺の目の前で食うなって言っただろぉぉっ！！」R
	
	@bf(hn0606)
	@横揺れ_弱
	
	KOE(100001348,010)【@日向】「イッテェェーー！！」R
	
	@集中線終了
	@縦揺れ_弱
	@bgm_stop(2000)
	@fade(bg_kuro, 0)
	
	必死に食らいつくも、あっさり日向に引き剥がされる。R
	
	@bg(ep05_bg052, 25)
	@bgm_pop_play
	
	@bf(bs2_hn0101)
	KOE(000602581,010)【@日向】「ごちそうさまでした」R
	【@音無】「…ごちそうさまでした」R
	結局、日向に勝てるわけもなく。R
	豚角煮定食の匂いすらかき消すパクチー臭満点のトムヤムカレーで胃を満たした。R

													// ■■■■ シナリオ抜け（西	← ▲▲追記しました▲▲		西村

}else{

	@bs(hn0404)
	KOE(100000886,010)【@日向】「じゃ、まずお前の夕飯は、えぇーーと…」R

	@bs(hn0408)
	
	日向がポケットを探る。R
	
	@bs(hn0405)
	KOE(100000888,010)【@日向】「これだ！」R
	
	@bs(hn0106)
	KOE(000600240,010)【@日向＿重複】@bc「えぇ！？　しくった…」@bs_c(800,hn0108)R
	【@音無】「え？　しくる？　ランダムだろ？」R
	
	@bs(hn0408)
	KOE(000600242,010)【@日向＿重複】「あー…その通り。問題ない。そういうことももちろんあるさ」R
	【@音無】「で、なに」R
	
	@bs(hn0402)
	KOE(100000893,010)【@日向】「ほらよ」R
	
	@bs
	
	食券を渡される。R
	そこには『豚角煮定食』の文字。R
	【@音無】「よし、これは期待できる！！」R
	
	@bs(hn0101)
	KOE(100000897,010)【@日向】「俺はっと…クリームコロッケ定食。ふつーだな…」R

	@bs
	
	受け取り口で待つ。R
	KOE(100000900,051)【食堂のおばさん】「ほい、豚角煮定食ー」R
	きったーーーー！！と心の中で叫んでしまう。R
	いかにもとろっとろの豚の角煮がでかでかと皿に載せられている。からしもついている。否応なく食欲が湧く！R

	@bg(ep05_bg052, 25)		/// テーブル
	日向と向かい合い食べ始める。R
	//	テキスト微調整		西村
	//歯なんて要らない…唇だけで割けるような柔らかい角煮だった。味もよく汁を吸い込んでいて、絶品だ。R
	歯なんて要らない…唇だけで割けるような柔らかい角煮だった。よく汁を吸い込んでいて、味も絶品だ。R
	
	@縦揺れ_弱
	
	【@音無】「きったーーー！！　なんて美味しさだ！」R
	今度は衝動を抑えきれず口に出してしまう。R
	
	@bs(hn0108)
	KOE(100000908,010)【@日向】「そいつはよかったな」R
	その冷めた一言に違和感を覚える。R

	それは…。R

	@@選択=SELBTN(@selbtn_l_3,
		お前はクリームコロッケが苦手なはずだ,
		俺はクリームコロッケが苦手だ,
		本当にランダムなのか
	)@selbtn_log
	IF(@選択==0){		// (お前はクリームコロッケが苦手なはずだ/俺はクリームコロッケが苦手だ/本当にランダムなのか)

		【@音無】「お前はクリームコロッケが苦手なはずだ」R
		
		@bs(hn0107)
		KOE(100000921,010)【@日向】「え？　大好きだが？」R
		【@音無】「そうか…」R
		
		@bs(hn0101)
		KOE(000600271,010)【@日向＿重複】「まだ、一緒にご飯を食うのも数日だし、俺の苦手なメニューなんてわからなくて当然だ」R
		言う通りだ…。R
		【@音無】「だよな…」R

	}ELSEIF(@選択==1){		// (お前はクリームコロッケが苦手なはずだ/俺はクリームコロッケが苦手だ/本当にランダムなのか)

		【@音無】「俺はクリームコロッケが苦手だ」R
		
		@bs(hn0107)
		KOE(100000930,010)【@日向】「え？　そうなのか。俺は大好きだから、それは回さないでおくな」R

		IF(@０１日気がある||@その気さらにあり){

			【@音無】「いつも悪いな…」R
			
			@bs(hn0102)
			KOE(100000935,010)【@日向】「そんなの気にすんなって」R
			美味しそうにクリームコロッケにぱくつく日向はなんとも愛らしく思った。R

		}else{

			【@音無】「ああ…」R

		}

	}ELSE{	// IF(@選択==2){		// (お前はクリームコロッケが苦手なはずだ/俺はクリームコロッケが苦手だ/本当にランダムなのか)

		【@音無】「本当にランダムなのか？」R
		
		@bs(hn0109_07)
		KOE(100000947,010)【@日向】「え？　何が？」R
		【@音無】「食券選びだよ」R
		【@音無】「まだ数日だけど、なぜか、お前はハズレのない食券を選んでいる気がする…」R
		
		@bs(hn0208)
		KOE(100000950,010)【@日向】「新米相手にそんな器がちっせーことしねぇーよ」R
		【@音無】「偶然か…」R
		
		@bs(hn0102)
		KOE(100000952,010)【@日向】「ああ」R

		@日向からの食券に少し疑問を持つ=1

		IF(@０１日気がある||@その気さらにあり){

			【@音無】「疑ってすまん…」R
			
			@bs(hn0404)
			KOE(100000959,010)【@日向】「いやいや、ぜんぜん気にしてねーぜ？」R
			【@音無】「マジかよ！」R
			
			@bs(hn0402)
			KOE(100000961,010)【@日向】「ああ、それだけ俺はお前を信じてる」R
			【@音無】「くっそー、その俺がお前を疑ってしまうなんて！」R
			
			@bs(hn0202)
			KOE(100000963,010)【@日向】「だから、気にすんなって！　平気、平気ー！」R
			【@音無】「日向、お前はほんと懐が深いぜ！」R
			
			@bs(hn0104)
			KOE(100000965,010)【@日向】「意味はよくわからないが褒め言葉として受け取っておくぜ！」R
			【@音無】「ああ！」R

		}

	}
	
	@食券豚角煮定食=1
	@実績チェック

}

