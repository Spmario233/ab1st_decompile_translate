#IINOKATOKIKU

@@選択=SELBTN(@selbtn_s_2,
	"いいのか？と訊く",
	"このまま流されておく"
	)@selbtn_log

IF(@選択==1){		// "このまま流されておく"

	GOTO #WARUINA

}else{		// "いいのか？と訊く"

	@bs(hn0114_13)
	
	【@音無】"「いいのか？」"R //「いいのか？」R
	
	@bs(hn0103)
	KOE(000202143,010)【@日向】"「あいつとはもう数十年過ごしてきてるからな。しばらくなら、全然平気さ」"R //「あいつとはもう数十年過ごしてきてるからな。しばらくなら、全然平気さ」R
	【@音無】"「そういう意味じゃなく、俺はＮＰＣと過ごす気まんまんだから、今度はお前がひとりになるぞ？」"R //「そういう意味じゃなく、俺はＮＰＣと過ごす気まんまんだから、今度はお前がひとりになるぞ？」R
	
	@bs(hn0106@10)
	KOE(000202145,010)【@日向】"「ええぇぇぇーー！？　この話の流れでも、その気持ちは少しも揺らがねーの！？」"R //「ええぇぇぇーー！？　この話の流れでも、その気持ちは少しも揺らがねーの！？」R
	【@音無】"「ああ」"R //「ああ」R
	
	@bs(hn0306)
	KOE(000202147,010)【@日向】"「どーして！？　ワッツ！？　ホワーイ！？」"R //「どーして！？　ワッツ！？　ホワーイ！？」R
	【@音無】"「特にルームメイトにこだわりを感じないから」"R //「特にルームメイトにこだわりを感じないから」R
	
	@bs(hn0105)
	KOE(000202149,010)【@日向】"「相手は人間じゃないんだぞ！？」"R //「相手は人間じゃないんだぞ！？」R

	IF(@通り魔){
		【@音無】"「こっちは通り魔ですが、何か？」"R //「こっちは通り魔ですが、何か？」R
		
		@bs(hn0109)
		KOE(000202153,010)【@日向】"「いや、それは名前を思い出すまでのあだ名で、実際には通り魔じゃないだろ…」"R //「いや、それは名前を思い出すまでのあだ名で、実際には通り魔じゃないだろ…」R
		【@音無】"「まあ、そうだろうけど、別に獲って食われたりはしないだろ。むしろ、銃なんて持ってるお前らのほうが怖いじゃないか」"R //「まあ、そうだろうけど、別に獲って食われたりはしないだろ。むしろ、銃なんて持ってるお前らのほうが怖いじゃないか」R
	}else{
		【@音無】"「別に、獲って食われたりはしないだろ。むしろ、銃なんて持ってるお前らのほうが怖いじゃないか」"R //「別に、獲って食われたりはしないだろ。むしろ、銃なんて持ってるお前らのほうが怖いじゃないか」R
	}

	@bs(hn0208)
	KOE(000202159,010)【@日向】"「なんだ…この温度差は…」"R //「なんだ…この温度差は…」R
	
	@face(yr0109)
	KOE(000202160,002)【@ゆり】"「この世界に来たばかりで、まだパニック状態なんじゃない？」"R //「この世界に来たばかりで、まだパニック状態なんじゃない？」R

//	【@日向】「そうだよっ、冷静に考え直せよ、音無＠、悪いようにはしないからさっ！」R

	@bs(hn0104)
	IF(@クソ坊主){
		KOE(000202165,010)【@日向】"「そうだよっ、冷静に考え直せよ、クソ坊主っ、悪いようにはしないからさっ！」"R //「そうだよっ、冷静に考え直せよ、クソ坊主っ、悪いようにはしないからさっ！」R
	}elseif(@代理人){
		KOE(000202167,010)【@日向】"「そうだよっ、冷静に考え直せよ、代理人っ、悪いようにはしないからさっ」"R //「そうだよっ、冷静に考え直せよ、代理人っ、悪いようにはしないからさっ」R
	}elseif(@微妙すぎるイケメン){
		KOE(000202169,010)【@日向】"「そうだよっ、冷静に考え直せよ、微妙すぎるイケメンっ、悪いようにはしないからさっ」"R //「そうだよっ、冷静に考え直せよ、微妙すぎるイケメンっ、悪いようにはしないからさっ」R
	}elseif(@ロリコン){
		KOE(000202171,010)【@日向】"「そうだよっ、冷静に考え直せよ、ロリコンっ、悪いようにはしないからさっ」"R //「そうだよっ、冷静に考え直せよ、ロリコンっ、悪いようにはしないからさっ」R
	}elseif(@メガネ仲間){
		KOE(000202173,010)【@日向】"「そうだよっ、冷静に考え直せよ、メガネ仲間っ、悪いようにはしないからさっ」"R //「そうだよっ、冷静に考え直せよ、メガネ仲間っ、悪いようにはしないからさっ」R
	}elseif(@暗算日本記録保持者){
		KOE(000202175,010)【@日向】"「そうだよっ、冷静に考え直せよ、暗算日本記録保持者っ、悪いようにはしないからさっ」"R //「そうだよっ、冷静に考え直せよ、暗算日本記録保持者っ、悪いようにはしないからさっ」R
	}elseif(@通り魔){
		KOE(000202177,010)【@日向】"「そうだよっ、冷静に考え直せよ、通り魔っ、悪いようにはしないからさっ」"R //「そうだよっ、冷静に考え直せよ、通り魔っ、悪いようにはしないからさっ」R
	}elseif(@記憶ナシ男){
		KOE(000202179,010)【@日向】"「そうだよっ、冷静に考え直せよ、記憶ナシ男っ、悪いようにはしないからさっ」"R //「そうだよっ、冷静に考え直せよ、記憶ナシ男っ、悪いようにはしないからさっ」R
	}elseif(@音速){
		KOE(000202181,010)【@日向】"「そうだよっ、冷静に考え直せよ、音速っ、悪いようにはしないからさっ」"R //「そうだよっ、冷静に考え直せよ、音速っ、悪いようにはしないからさっ」R
	}elseif(@音無){
		KOE(000202183,010)【@日向】"「そうだよっ、冷静に考え直せよ、音無っ、悪いようにはしないからさっ！」"R //「そうだよっ、冷静に考え直せよ、音無っ、悪いようにはしないからさっ！」R
	}else{		//(@無限)
		KOE(000202185,010)【@日向】"「そうだよっ、冷静に考え直せよ、無限っ、悪いようにはしないからさっ」"R //「そうだよっ、冷静に考え直せよ、無限っ、悪いようにはしないからさっ」R
	}

	"なぜ、そこまでルームメイトになることにこだわるのか…。"R //なぜ、そこまでルームメイトになることにこだわるのか…。R

	;－－－☆☆☆☆　@０１日ＮＰＣと同じ部屋にしたが日向の部屋に==1　がシナリオ内に存在しません
	;－－－☆☆☆☆　セットするならホワーイが拾えるのはここだけです。R
	;－－－☆☆☆☆　ただ、午後に大山を追い出す流れでも参照しているのですが、流れがおかしい（そもそも日向と同部屋ルートは仲間にならないルートのみ排他）ので
	;－－－☆☆☆☆　もう解決方法を一度考えてみます。たぶんフラグがもうひとつ必要っぽいです。R
	;－－－☆☆☆☆↑は修正済み（角）

	;;@おかしい音無１=1		;;もっとおかしいところに移植

	@@選択=SELBTN(@selbtn_s_2,
		"考え直す",
		"お前ホモなのか？"
	)@selbtn_log
	IF(@選択==1){				// "お前ホモなのか？"

		【@音無】"「お前ホモなのか？」"R //「お前ホモなのか？」R
		
		@bs(hn0110_06)
		KOE(000202205,010)【@日向】"「ちっがーーーーーうっ！！」"R //「ちっがーーーーーうっ！！」R

		@bs(hn,bs1_yr0502)
		KOE(000202209,002)【@ゆり】"「あるかもよぉーー？」"R //「あるかもよぉーー？」R
		
		@bf(hn0306)
		KOE(000202210,010)【@日向】"「ありませんからーー！！」"R //「ありませんからーー！！」R
		
		@bf(yr0307_01)
		KOE(000202211,002)【@ゆり】"「ふふ…先が楽しみだわ…」"R //「ふふ…先が楽しみだわ…」R

		@お前ホモなのか聞いた=1

		if(@０１日気がある){

			@bf(hn0316)
			"なんでだろう、俺も楽しみだ。"R //なんでだろう、俺も楽しみだ。R
			"…とりあえず、悪いようにはしないとまで言ってくれている。"R //…とりあえず、悪いようにはしないとまで言ってくれている。R
			"なら信じてみよう。"R //なら信じてみよう。R

			@bf(hn0302_13)
			GOTO #WAKKATAYO

		}else{
			"なんだか恐い…。"R //なんだか恐い…。R

			@０１日ホモ疑惑=1

		}

		
		;;@face(fj0101)	//ここの藤巻、流れによってはいてはおかしい
		;;KOE(000202213,013)【藤巻】「で、結局どーなるんだよ」R

		//IF(@加入前に阿部に会った){		//立たないフラグ（あまの）
		//	でも、それ以上にＮＰＣの不気味さを思い出すと、同じ部屋で過ごす気にはなれない。ここは折れておくとしよう。R
		//	@bf(hn0302_13)
		//	GOTO #WAKKATAYO
		//}

		;;■■コメントアウト待避507■■

		@bf(hn0316)
		"どうしたものだろう。"R //どうしたものだろう。R
		"…とりあえず、悪いようにはしないとまで言ってくれている。"R //…とりあえず、悪いようにはしないとまで言ってくれている。R
		"なら信じてみよう。"R //なら信じてみよう。R

		@bf(hn0302_13)

	}

	#WAKKATAYO

	【@音無】"「わかったよ」"R //「わかったよ」R
		
	@bs(hn0402)
	KOE(000202239,010)【@日向】"「オーケー。その判断は間違ってなかったと思わせるぜ？」"R //「オーケー。その判断は間違ってなかったと思わせるぜ？」R
	【@音無】"「だといいけどな」"R //「だといいけどな」R

}


