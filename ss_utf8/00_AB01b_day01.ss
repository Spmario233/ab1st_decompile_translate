;－－－●選んだ選択肢は消えていき、最後まで繰り返す
// 以下オレのやり方（西村）

@選択肢チェック=0b111111  //フラグを6本立てる

command $get_selbtn_type( property $src ) : int
{
	if( ($src & 0b100000) != 0 ){
		return(4)
	}
	return(0)
}


while(@選択肢チェック!=0){		// 全てのフラグを倒すまでループ

	if(@選択肢チェック!=0b111111){	// 2回目以降
		@bs(yr0101)		//２回目以降はここで固定しておく
		KOE(000201359,002)【@ゆり】"「…他には？」"R //「…他には？」R
	}

	close


	@@選択=SELBTN($get_selbtn_type(@選択肢チェック),		//						0(フラグが倒れた)なら選択肢から外す
		"校長室に居た連中以外の生徒について",	@選択肢チェック>>>5,
		"天使の凶暴性について",					(@選択肢チェック&0b011111)>>>4,
		"神について",							(@選択肢チェック&0b001111)>>>3,
		"この学校の外について",					(@選択肢チェック&0b000111)>>>2,
		"天使の持つ力について",					(@選択肢チェック&0b000011)>>>1,
		"人間について",							(@選択肢チェック&0b000001)&&(@ＮＰＣの説明聞いた==1)		//■■■■シナリオ抜けに対処（あまの）
		)@selbtn_log
	switch(@選択){

		case(0)

			【@音無】"「校長室に居た連中以外に生徒は？」"R //「校長室に居た連中以外に生徒は？」R

