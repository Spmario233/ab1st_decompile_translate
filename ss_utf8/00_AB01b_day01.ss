		"藤巻が去っていく。"R //藤巻が去っていく。R
		
		@bs(hn0107)
		KOE(000204178,010)【@日向】"「すごい理由で断るんだな…」"R //「すごい理由で断るんだな…」R
		【@音無】"「そうか？　初日から麻雀だなんて、もっと大切なものがある気がするんだ」"R //「そうか？　初日から麻雀だなんて、もっと大切なものがある気がするんだ」R
		
		@bs(hn0101_09)
		KOE(000204180,010)【@日向】"「それが俺と居たいってことか」"R //「それが俺と居たいってことか」R
		【@音無】"「ああ」"R //「ああ」R
		
		@bs(hn0202)
		KOE(000204182,010)【@日向】"「ま、好きにすればいいけどさ」"R //「ま、好きにすればいいけどさ」R

		@麻雀断った=1

	 }ELSE{

		【@音無】"「記憶も戻っていないのに打てるはずないだろ」"R //「記憶も戻っていないのに打てるはずないだろ」R
		
		@bs(fj0110)
		KOE(000204130,013)【藤巻】"「んだよ、ノリがわりーな…」"R //「んだよ、ノリがわりーな…」R
		【@音無】"「親交を深めるためにも乗りたいところだが、俺は打てない」"R //「親交を深めるためにも乗りたいところだが、俺は打てない」R
		
		@bs(fj0303)
		KOE(000204132,013)【藤巻】"「くっそ、邪魔したな」"R //「くっそ、邪魔したな」R

		@bs
		
		"藤巻が去っていく。"R //藤巻が去っていく。R

		【@音無】"「ああ」"R //「ああ」R
		
		@bs(hn0102)
		KOE(000204155,010)【@日向】"「打てないなら仕方ねーけど、仲良くしておいたほうがいいぜ？　ルールも教えてもらえるしな」"R //「打てないなら仕方ねーけど、仲良くしておいたほうがいいぜ？　ルールも教えてもらえるしな」R
		【@音無】"「そっか、次からは考えるよ」"R //「そっか、次からは考えるよ」R
		
		@０１日麻雀の誘いが来て打てない=1

	 }

}else{

	//@０１日ホモ疑惑==1 しか来ない

	@pcmch_play(0, @鉄製ノック)
	"そこへ、ノックの音が。"R //そこへ、ノックの音が。R
	
	@pcmch_play(0, @寮扉開ける)
	@bs(fj0101)
	
	"ドアを開くと藤巻が立っていた。"R //ドアを開くと藤巻が立っていた。R
	【@音無】"「どうした？」"R //「どうした？」R
	
	@bs(fj0102)
	KOE(000204128,013)【藤巻】"「お前さ、麻雀打てねーか？」"R //「お前さ、麻雀打てねーか？」R
	【@音無】"「記憶も戻っていないのに打てるはずないだろ」"R //「記憶も戻っていないのに打てるはずないだろ」R
	
	@bs(fj0110)
	KOE(000204130,013)【藤巻】"「んだよ、ノリがわりーな…」"R //「んだよ、ノリがわりーな…」R
	【@音無】"「親交を深めるためにも乗りたいところだが、俺は打てない」"R //「親交を深めるためにも乗りたいところだが、俺は打てない」R
	
	@bs(fj0303)
	KOE(000204132,013)【藤巻】"「くっそ、邪魔したな」"R //「くっそ、邪魔したな」R
	
	@bs
	
	"藤巻が去っていく。"R //藤巻が去っていく。R
	"入れ替わりに、日向が戻ってくる。"R //入れ替わりに、日向が戻ってくる。R
	
	@bs(hn0102)
	KOE(000204135,010)【@日向】"「ふぅ…いい湯だったぜ」"R //「ふぅ…いい湯だったぜ」R
	"ジャージ姿で、髪にバスタオルを載せて、戻ってくる。"R //ジャージ姿で、髪にバスタオルを載せて、戻ってくる。R
	
	@bs(hn0101_07)
	KOE(000204137,010)【@日向】"「ん？　俺が風呂に入ってる間に何かあったのか？」"R //「ん？　俺が風呂に入ってる間に何かあったのか？」R
	"俺がドアの前で立ちつくしているのに疑問を覚えたのだろう。"R //俺がドアの前で立ちつくしているのに疑問を覚えたのだろう。R
	【@音無】"「なんでもない。藤巻が、麻雀に誘いに来ただけだ」"R //「なんでもない。藤巻が、麻雀に誘いに来ただけだ」R

	@bs(hn0101_09)
	KOE(000204140,010)【@日向】"「お前、打てねーの？」"R //「お前、打てねーの？」R

	【@音無】"「打てる」"R //「打てる」R
	
	@bs(hn0103)
	KOE(000204145,010)【@日向】"「なら、行けばいいじゃん」"R //「なら、行けばいいじゃん」R
	【@音無】"「そうだな…そうすべきだったな…」"R //「そうだな…そうすべきだったな…」R
	
	@bs(hn0107)
	KOE(000204147,010)【@日向】"「なんだよ、その遠い目…」"R //「なんだよ、その遠い目…」R
	【@音無】"「いや、忘れてくれ。とっとと寝よう」"R //「いや、忘れてくれ。とっとと寝よう」R
	
	@０１日麻雀の誘いが来て打てる=1

}


