	"日向と同じ部屋の方が安心"				;;元"日向の好意を受け取る"
	)@selbtn_log
IF(@選択==0){		// 遠慮しておく

	【@音無】"「いいよ、俺は。相手がみんなの言うＮＰＣでも。そいつと上手くやっていくよ」"R //「いいよ、俺は。相手がみんなの言うＮＰＣでも。そいつと上手くやっていくよ」R
	
	@bs(hn0102)
	KOE(000202080,010)【@日向】"「そんな、遠慮すんなって！」"R //「そんな、遠慮すんなって！」R

	@bs(oy0107,hn0102)
	【@音無】"「だって、大山がすでにこれだけ困っている」"R //「だって、大山がすでにこれだけ困っている」R
	
	@bf(oy0308)
	KOE(000202082,014)【大山】"「いやぁっ、僕のことなんてそんな気にしなくても…」"R //「いやぁっ、僕のことなんてそんな気にしなくても…」R

	#AACHITOIIKA

	@bs(fj0501)
	KOE(000202086,013)【藤巻】"「あー…、ちといいか」"R //「あー…、ちといいか」R
	"去ったはずの藤巻がドアにもたれかかっていた。"R //去ったはずの藤巻がドアにもたれかかっていた。R
	
	@bs(fj0101)
	KOE(000202088,013)【藤巻】"「俺もルームメイトを追い出しちまってるから、ひとりぶん、空いてるぜ」"R //「俺もルームメイトを追い出しちまってるから、ひとりぶん、空いてるぜ」R
	
	@bs(oy0105,fj)
	KOE(000202089,014)【大山】"「えっ、そうだったの！？」"R //「えっ、そうだったの！？」R
	
	@bf(fj0111)
	//	脱字修正		西村
	//KOE(000202090,013)【藤巻】「これで大山が俺の部屋に引っ越せば、丸く収まるんじゃーの。まー、好きにするがいいさ…」R
	KOE(000202090,013)【藤巻】"「これで大山が俺の部屋に引っ越せば、丸く収まるんじゃねーの。まー、好きにするがいいさ…」"R //「これで大山が俺の部屋に引っ越せば、丸く収まるんじゃねーの。まー、好きにするがいいさ…」R
	
	@bf(oy0303)
	KOE(000202091,014)【大山】"「じゃあ、僕、藤巻くんの部屋に引っ越しするね！」"R //「じゃあ、僕、藤巻くんの部屋に引っ越しするね！」R
	
	@bf(oy9999@l2)
	
	"大山が本部から飛び出していく。"R //大山が本部から飛び出していく。R
	
	@bs(fj0501)
	KOE(000202093,013)【藤巻】"「ちっ、子供みてーな奴だぜ…だりぃ…」"R //「ちっ、子供みてーな奴だぜ…だりぃ…」R
	
	@bs(fj9999@l2)
	
	"その後に、やれやれといった具合で藤巻が続いた。"R //その後に、やれやれといった具合で藤巻が続いた。R

	@藤巻と大山ルームメイトになった=1

	//IF(@０１日気がある==0){ goto #IINOKATOKIKU }
	
}else{				// 日向の好意を受け取る

	//@０１日気がある=1			//■■■■こっちに移動させた（あまの）ここに入れても、プレイヤが意識しないところで立ってしまうので、とりあえずコメントアウト（あまの）

	"この世界のことがまだよくわかっていない状態なので、色々と教えてくれるという日向と同じ部屋の方が心強い。"R //この世界のことがまだよくわかっていない状態なので、色々と教えてくれるという日向と同じ部屋の方が心強い。R
	"ただ、俺の都合で大山に迷惑をかけていいものか…。"R //ただ、俺の都合で大山に迷惑をかけていいものか…。R

	@bs(fj0501)
	KOE(000202086,013)【藤巻】"「あー…、ちといいか」"R //「あー…、ちといいか」R
	"去ったはずの藤巻がドアにもたれかかっていた。"R //去ったはずの藤巻がドアにもたれかかっていた。R
	
	@bs(fj0101)
	KOE(000202088,013)【藤巻】"「俺もルームメイトを追い出しちまってるから、ひとりぶん、空いてるぜ」"R //「俺もルームメイトを追い出しちまってるから、ひとりぶん、空いてるぜ」R
	
	@bs(oy0105,fj)
	KOE(000202089,014)【大山】"「えっ、そうだったの！？」"R //「えっ、そうだったの！？」R

	@bf(fj0111)
	//	脱字修正		西村
	//KOE(000202090,013)【藤巻】「これで大山が俺の部屋に引っ越せば、丸く収まるんじゃーの。まー、好きにするがいいさ…」R
	KOE(000202090,013)【藤巻】"「これで大山が俺の部屋に引っ越せば、丸く収まるんじゃねーの。まー、好きにするがいいさ…」"R //「これで大山が俺の部屋に引っ越せば、丸く収まるんじゃねーの。まー、好きにするがいいさ…」R
	
	@bf(oy0303)
	KOE(000202091,014)【大山】"「じゃあ、僕、藤巻くんの部屋に引っ越しするね！」"R //「じゃあ、僕、藤巻くんの部屋に引っ越しするね！」R
	
	@bf(oy9999@l2)
	
	"大山が本部から飛び出していく。"R //大山が本部から飛び出していく。R
	
	@bs(fj0501)
	KOE(000202093,013)【藤巻】"「ちっ、子供みてーな奴だぜ…だりぃ…」"R //「ちっ、子供みてーな奴だぜ…だりぃ…」R
	
	@bs(fj9999@l2)
	
	"その後に、やれやれといった具合で藤巻が続いた。"R //その後に、やれやれといった具合で藤巻が続いた。R

	#WARUINA

	@bs(hn0101)
	【@音無】"「なんだか悪いな」"R //「なんだか悪いな」R
	
	@bs(hn0103)
	KOE(000202113,010)【@日向】"「あいつとはもう数十年と過ごしてきてるからな。しばらくなら、全然平気さ」"R //「あいつとはもう数十年と過ごしてきてるからな。しばらくなら、全然平気さ」R
	【@音無】"「そんなにこの世界に居続けているのか…」"R //「そんなにこの世界に居続けているのか…」R
	
	@bs(hn0101)
	KOE(000202115,010)【@日向】"「ゆりっぺはさらに昔からだし、椎名っちや大山はそれ以上」"R //「ゆりっぺはさらに昔からだし、椎名っちや大山はそれ以上」R
	【@音無】"「学校なのに、進学したり、卒業したりしないのか？」"R //「学校なのに、進学したり、卒業したりしないのか？」R
	
	@bs(hn0403)
	KOE(000202117,010)【@日向】"「この世界から消えなかった人間は、始業式で、同じ学年のクラスにまた配属される」"R //「この世界から消えなかった人間は、始業式で、同じ学年のクラスにまた配属される」R
	
	@bs(hn0402)
	KOE(000202118,010)【@日向】"「ＮＰＣのクラスメイトは卒業していくけどな」"R //「ＮＰＣのクラスメイトは卒業していくけどな」R
	"ほんと、上手く出来てる世界だな…。"R //ほんと、上手く出来てる世界だな…。R

	@藤巻と大山ルームメイトになった=1

	goto #ARATAMETE

}

