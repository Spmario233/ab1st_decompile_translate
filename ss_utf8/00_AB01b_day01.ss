		"その時、ようやくがちゃりと解錠がされ、ドアが開く。"R //その時、ようやくがちゃりと解錠がされ、ドアが開く。R
		@pcmch_play(0, @木製扉開ける中)//効果音(日向が本部のドアを開け放つ音)
		@timewaitkey(500)
		
		@face(hn0301)
		KOE(000200746,010)【@日向】"「入れよ」"R //「入れよ」R
		"すまない、と告げて、中に入る。"R //すまない、と告げて、中に入る。R

		@０１日開けゴマした=1
		@０１日一度去ってから仲間に=1

	case(2)

		@ハンマートラップセット
		@ハンマートラップ発動拡大
		@pcmch_play(0, @トラップ炸裂)//効果音(トラップ発動)
		@横揺れ_強(0, 0)
		@bg(bg_kuro, 1)
		
		"ぶぅんと風を切る音と共に意識が飛ぶ。"R //ぶぅんと風を切る音と共に意識が飛ぶ。R

		close
		@pcmch_stop_all
		@bg_pan_lr(ep01_bg045, 0, 1500, 2)
		@pcmch_play(0, @窓割れる)
		@縦揺れ_強
		@timewaitkey(1000)
		@fade(bg_kuro, 3)
		@timewaitkey(2000)

		@またハンマー=1
		@０１日一度去ってから仲間に=1

}



