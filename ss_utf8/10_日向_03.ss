@@選択=SELBTN(@selbtn_s_2,
	撃つ,
	待つ
)@selbtn_log
IF(@選択==0){		// (撃つ/待つ) 

	close
	@pcmch_play(0, @ハンドガン２)
	@sc_flash_w
	
	ぱぁん！R
	
	@face(hn0106)
	@横揺れ_弱
	KOE(100001346,010)【@日向】「ぐっ…！！」R
	日向の肩を銃弾がえぐってしまった…！R
	
	@face(hn0110)
	@縦揺れ_弱
	KOE(100001348,010)【@日向】「イッテェェーー！！」R
	日向がもんどりうつ。R

	;－－－●この時点でエロエロ団ナンバー１のフラグが立つことある？R

	IF(@音無をただのエロ少年と呼ぶ==1){

		@bs(bs3_hn0105@r3)
		@横揺れ_弱
		KOE(100001355,010)【@日向】「だから、どーして缶を立てていないのに撃つんだよっ！？」R
		【@音無】「ただのエロ少年だけに、早漏なんだ…」R
		
		@bs(hn0606)
		@縦揺れ_弱
		
		KOE(100001357,010)【@日向】「その上手い言い訳二度と言うなぁぁーー！！」R

	}else{

		@bs(bs3_hn0106@r3)
		@横揺れ_弱
		//KOE(100001361,010)【@日向】「なんでまだセット前に撃つんだよぉーー！！」R	//ボイス合わせ（白）
		KOE(100001361,010)【@日向】「なんでセット前に撃つんだよぉーー！！」R
		
		//	▼▼整合性とるために分岐追加▼▼		西村
		IF(@日向を撃ちかけた){

			【@音無】「すまない…結果をそろそろ出さないと思って…また焦れてしまった…」R

		}else{

			【@音無】「すまない…結果を出さないと思って…焦れてしまった…」R

		}
		//	▲▲追加ここまで▲▲

		@bf(hn0610)
		@縦揺れ_弱
		KOE(100001363,010)【@日向】「だから、無限に続く世界だから、たった数日で焦ったりすんなよぉー！！」R

	}
	
	// k-takahashi ↓演出のため少しテキストを変更しました
	@bs
	不満を言いつつも日向が缶を立て直して、戻ってくる。R
	// k-takahashi ↑
	
	@日向の肩をえぐった=1

	GOTO #MODOTTEKURU

}ELSE{	// IF(@選択==1){		// (撃つ/待つ) 
	
	@bs
	
