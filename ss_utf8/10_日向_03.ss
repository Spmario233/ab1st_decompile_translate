/// ■■■■着替えるタイミングの指定がないので、ここでジャージから制服に戻します。地の文が欲しいかもです（鈴木）
@日向服装 = @戦線制服

@bgm_stop(2000)

;－－－昼飯
@移動(ep05_bg047)

@bgm_play(M119)

IF(@次からもトムヤムカレーを回される==1){
	
	@bs(hn0102)
	KOE(100001217,010)【@日向】「ほら、お前の好きなトムヤムカレー」R

	IF(@ゲロ吐いても筋トレしたい==1){
		
		@bs
		@横揺れ_弱
		
		;－－－●↓用法合ってる？R
		【@音無】（泣きっ面に蜂ぃーー！！）R

	}else{

		【@音無】「ああ…」R
	}

	@bs(hn0403)
	KOE(100001229,010)【@日向】「さって、俺は何かなー！？」R

	@bs(hn0408)
	
	日向がポケットから拾い上げた食券、それは…。R
	
	@bs(hn0302)
	KOE(100001231,010)【@日向】「明太子スパ！」R
	
	【@音無】（記憶にはないが、大好きだった気がする！）R

	IF(@０１日気がある||@その気さらにあり){
		
		@bs
		
		【@音無】（でも、トムヤムカレーの食券だって、いつか潰えるはず…。その時には、本当の笑顔で食べたいものだ…）R

	}else{

		日向の喜びように殺意すら覚える…。R
		
	}

	#SYOKKENNO
	
	@bs
	
	食券を受け取り、カウンターでおばさんに渡す。R
	//	ここまで来るのにトムヤムカレーの頻度はバラける可能性があるので、どう来ても対応できるよう修正		西村
	//受け取り口には、いつものパクチー臭いトムヤムカレー。R
	受け取り口には、例のパクチー臭いトムヤムカレー。R
	その後の日向は、明太子とバター、刻み海苔と青じその香る、絶品の明太子スパを受け取っていた。R
	
	@bg(ep06_bg015, 25)		/// テーブル
	
	向かい合って食べるが、パクチーの匂いが邪魔して、日向の明太子スパの芳醇な香りが届いてこない…。R
	【@音無】（なんでこんな本格的なんだよっ！　タイ人も来るのか、この世界！）R
	それでも我慢して、食べきる。R
	【@音無】「ごちそうさま…」R
	
	@bs(hn0102)
	KOE(100001253,010)【@日向】「ごちそうさま」R

	GOTO #GOGO

}else{
;－－－	●@トムヤムカレー完食した==1は必ず立ってよるよね？R

	@bs(hn0401)
	KOE(100001260,010)【@日向】「ええと、まずはお前のメニューな」R
	
	@bs(hn0402)
	KOE(100001261,010)【@日向】「ほいっと」R
	
	@bs(hn0102)
	KOE(100001262,010)【@日向】「はい、トムヤムカレー」R
	
	@縦揺れ_弱
	
	【@音無】「また来たぁぁーーーーー！！」R
	
	@bs(hn0109)
	KOE(100001265,010)【@日向】「それは喜んでいるのか、悲しんでいるのか、よくわかんねーぜ」R

	@@選択=SELBTN(@selbtn_s_3,
		喜んでいる,
		悲しんでいる,
		ニュートラル
	)@selbtn_log
	IF(@選択==0){		// (喜んでいる/悲しんでいる/ニュートラル) 
		【@音無】「喜んでいるさ…」R
		
		@bs(hn0102)
		KOE(100001274,010)【@日向】「だよな。ここのトムヤムカレーは超本格的な味だからな」R

	}ELSEIF(@選択==1){		// (喜んでいる/悲しんでいる/ニュートラル) 

		【@音無】「悲しい…」R
		
		@bs(hn0107)
		KOE(100001279,010)【@日向】「え？　どーしてさ」R
		【@音無】「本格的過ぎるから…」R
		
		@bs(hn0104)
		KOE(100001281,010)【@日向】「本格的で癖はあるけど、食べ続けていれば、ハマッちまうのが、トムヤムカレーさ」R
		
		@bs(hn0102)
		KOE(100001282,010)【@日向】「でなけりゃ、ＮＰＣがこんな食券買うはずないだろ？」R
		【@音無】（確かに、筋は通っている…）R
		【@音無】「わかったよ…食うよ…」R
		
		@bs(hn0404)
		KOE(100001285,010)【@日向】「ああ、一度ハマッたら、毎日でも食べ続けられる魔性のメニューだぜ？」R

	}ELSE{	// IF(@選択==2){		// (喜んでいる/悲しんでいる/ニュートラル) 

		【@音無】「ニュートラルな感じだ…」R
		
		@bs(hn0102)
		KOE(100001290,010)【@日向】「ニュートラル？　よくわかんねーけど、一回食べただけじゃわからない、奥深いメニューで信者も多い一品なんだぜ？」R
		【@音無】「わかった…食うよ…」R
	}

	GOTO #SYOKKENNO

}

