@@選択=SELBTN(@selbtn_s_3,
	目を閉じる,
	耳をふさぐ,
	口を閉ざす
)@selbtn_log
IF(@選択==0){		// (目を閉じる/耳をふさぐ/口を閉ざす) 目を閉じる
	
	@bg(bg_kuro, 144)
	
	目を閉じた。R
	
	close
	@pcmch_play_loop(2, @ハウリング発動,3000)		// 効果音（ガードスキル・ハウリング/きーーーん）
	@timewaitkey(1000)
	
	GOTO #SONOTYOKUGO

}ELSEIF(@選択==2){		// (目を閉じる/耳をふさぐ/口を閉ざす) 口を閉ざす

	毒ガス的なものが発生しているのか。俺は口を閉ざし、しばらく呼吸を止めた。R

	@pcmch_play_loop(2, @ハウリング発動,3000)		// 効果音（ガードスキル・ハウリング/きーーーん）
	@bg(ep08_bg038,253)
	
	#SONOTYOKUGO

	その直後、耳がきーーーんと痛くなる。その後、吹き飛ばされそうなものすごい風圧を感じる。R
	なんだ、これ…。R
	痛みが増していく…。R
	【@音無】「うあぁぁぁーーーー…！！」R
	
	@bgm_stop(3000)
	@fade(bg_kuro)
	
	目の前が闇に閉ざされた。R
	気を失ったのだ。R

	@第八話で気を失った=1

	close
	@pcmch_stop(2, 3500)// ハウリングFO
	@timewaitkey(3500)
	@pcmch_stop(2, 100)// ハウリングFO

	RETURN

}

