@@選択=SELBTN(@selbtn_s_2,
	聞きたいことがある,
	お前に会いに来ただけ
)@selbtn_log

IF(@選択==1){		// (ああ/お前に会いに来ただけ) お前に会いに来ただけ

	IF(@ゆりからこの件では来ないでと釘を刺された==1){
		
		【@音無】「お前に会いに来ただけ」R
		
		@bs(yr0205)
		@横揺れ_弱
		
		KOE(020000420,002)【@ゆり】「だから、そんな理由でやって来るなぁーーー！！」R
		いきなり怒声を浴びせられる。R
		【@音無】「えぇ！？」R
		
		@集中線開始
		@bs(bs3_yr0205@00a)
		@縦揺れ_弱
		KOE(020000423,002)【@ゆり】「新米らしく、訓練に勤しめぇーーー！！」R

		@集中線終了
		;@bs(yr0207)
		@bs(yr0205_09)
		
		【@音無】「あ、ああ…」R
		
		@fade(bg_kuro, 25)
		
		追い出される。R
		
		@ゆりから釘を刺された上追い出される=1
		
	}else{
		
		【@音無】「お前に会いたかっただけだけど、問題あるか？」R
		@bs(yr0107)
		KOE(020000277,002)【@ゆり】「理由は？」R
		【@音無】「えーっと…」R
		【@音無】「だから、会いたかっただけだけど？」R
		@bs(yr0110_06)
		KOE(001205770,002)【@ゆり】「ふぅ…」R
		@bs(yr0109)
		KOE(020000358,002)【@ゆり】「用はそれだけ？」R
		【@音無】「え？　あ、ああ」R
		@bs(yr0210_06)
		KOE(020000360,002)【@ゆり】「じゃあ、あなたはまだまだ新米なんだから、幹部のみんなに追いつくぐらい、体力作りと銃の練習に努めなさい」R
		@bs(yr0209)
		【@音無】「わかった…」R
		
		@fade(bg_kuro, 25)
		
		たしなめられ、俺は本部を後にした。R
		
	}
	
	GOTO #OWARI
} else {	// (ああ/お前に会いに来ただけ) 聞きたいことがある
	/// そのまま下へ流す
}

【@音無】「ちょっと聞きたいことがある」R

