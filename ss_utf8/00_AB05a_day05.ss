#Z00
;－－－□寮　木曜日
//@DAYS=05	***********旧設定***********
@DAYS += 1	@day_change	// 05日目
$bs_dress_init

@bg(ep99_bg001, 143)

@pcmch_play(0, @着替え)
@timewaitkey(1500)

物音で目が覚めた。R
日向が、制服に着替えている最中だった。R

@bgm_play(m301)		;;♪日常曲（朝の寮の部屋など）

;－－－■■＠■■毎朝治ります（角）　ＯＫ（前田）R
@野田との訓練全身刻まれた=0
//@松下関係で怪我=0


IF(@０１日気がある||@その気さらにあり){
	
	@日向服装 = @上半身裸
	@bs(hn0101)
	
	上は今素っ裸で、これからジャージの下を脱ごうとしている。R

	@@選択=SELBTN(@selbtn_s_2,
		ガン見する,
		そんな趣味はない
	)@selbtn_log
	IF(@選択==0){		// (ガン見する/そんな趣味はない) ガン見する

		日向は俺が起きていることに気づいていない…。R
		このままじっと、目を見開いていよう…。R
		
		@pcmch_play(0, @着替え)
		@bs(hn0103)
		
		日向がジャージを下ろし、トランクス一枚になった…。R

		IF(@裸の日向を見つめた){

			それも脱げ！　素っ裸になれ！R

			IF(@日向のイケチン見た){

				【@音無】（あの、感動のイケチンをもう一度見せてくれ！）R

			}else{

				そしてあそこを露わにしろ！R

			}

			俺はそう祈った。R
			
			@pcmch_play(0, @着替え)
			@bs(hn0102)
			
			が、もちろん、制服のズボンを履く。R
			
			@bs
			
			あーあ…と思ったところで、身を起こし、日向におはようと告げた。R

		}ELSE{	// IF(@裸の日向を見つめた==0){

			………。R
			
			@bs(hn0102)
			
			そこからするすると制服のズボンを履く。R
			………。R
			
			@bs
			
			着替え終わるまでをガン見し続けた。R
			それから俺は身を起こし、日向におはようと告げた。R

		}

		@その気さらにあり=1		//メモ：その気さらにありが立つ最後のチャンス

	}else{	// ELSEIF(@選択==1){		// (ガン見する/そんな趣味はない) そんな趣味はない
		
		@bs
		
		何考えてんだ、俺…。R
		そりゃ、日向のことは好きだが、あくまでも友達としてだ。R

		俺は身を起こし、日向におはようと告げた。R
		@その気さらにあり=0
		@０１日気がある=0		//消しておかないとおかしなことに（あまの）

	}

	@日向服装 = @戦線制服
	//GOTO #OH

	//}		// (ガン見する/そんな趣味はない) 選択肢処理のケツ
//;－－－■■■■「戦線服ではない」フラグが立たない流れになったので、復活させる際このあたりのホモ疑惑系は#KAOARATTE以降にも処理が必要です（角）
//}ELSEIF(@０１日気がある==0&&@もう戦線服ではない==0){		// ■■■■つのっちの言う通りに訂正
}else{		// ■■■■こっちに修正（あまの）
	//現状、コメントアウトされていて @もう戦線服ではない==0 しかありえない
	俺は身を起こす。R
	【@音無】「おはよう」R
}

//	#OH

@bs(hn0402)
IF(@音無をエロ侍と呼ぶ){
	KOE(000600080,010)【@日向】「おう、起きたか、エロ侍。おはよーさん」R
}elseif(@音無をエロエロ団ナンバー１と呼ぶ){
	KOE(000600082,010)【@日向】「おう、起きたか、エロエロ団ナンバー１。おはよーさん」R
}elseif(@音無をただのエロ少年と呼ぶ){

	KOE(000600084,010)【@日向】「おう、起きたか、ただのエロ少年。おはよーさん」R

	@bs(hn0109)
	
	日向は朝の挨拶を告げた後、こちらを伺うように見てくる。R

	【@音無】「どうしたんだ？」R

	@bs(hn0109_07)
	KOE(001401113,010)【@日向】「なあ、ただのエロ少年。そろそろ音無と呼ばせてくれねーか？」R

	【@音無】「俺は十分、罪滅ぼしが出来たのかな…」R
	
	@bs(hn0202)
	KOE(000600354,010)【@日向】「ああ。俺が相当言い続けたからな。十分だと思うぜ？」R
	【@音無】「よかった…」R
	【@音無】「だったら、もういいよ…ありがとう、日向」R
	
	@bs(hn0104)
	KOE(000600357,010)【@日向】「いんや。こっちはお前の反省の仕方に拍手だ」R

	@bs(hn0103)
	
	ぱちぱちと手を叩かれる。R
	【@音無】「そう言ってもらえるとありがたい…」R

	@今あだ名である=0
	@音無をただのエロ少年と呼ぶ=0
	@音無_呼び方 = @音無と呼ぶ

}else{

	KOE(000600086,010)【@日向】「おう、起きたか。おはよーさん」R

}


@bs(hn0104)
KOE(000600089,010)【@日向】「顔洗ってこいよ」R
【@音無】「ああ」R

@fade(bg_kuro, 25)

//───────────────────────────────────────
//ここは必ず通る
//───────────────────────────────────────

IF(@０１日ホモ疑惑==1||@さらにホモ疑惑==1){
	ふと、それが自然な光景になり始めていることに気付く。R
	【@音無】（あいつはホモなのに…）R
	いや、思い返してみれば、あいつがホモならいくらでも俺を襲うチャンスはあったはずだ。R

	;－－－■■■■ホモ太を二巻以降で復活させるなら、ここに選択肢で「信じ続ける」「思い込み」とかで分けましょう（角）

	思い込みだったのかもしれない。R
	【@音無】（だとしたら、いつまでも頑なな態度をとるのは止めて、ルームメイトとして接していくべきかもしれないな…）R
	これからは改めよう。R
	
	@０１日ホモ疑惑=0
	@さらにホモ疑惑=0

}
