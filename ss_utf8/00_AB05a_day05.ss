@bs(hn0101)
KOE(000600245,010)【@日向】「いただきまーす」R
【@音無】「頂きます」R

@bs

俺は『"This is "日本』的な朝食を美味しく頂く。R
【@音無】「やっぱ、朝食はこういうのがいいな」R

@bs(hn0104)
KOE(000600249,010)【@日向】「ああ、だよな…」R
日向は、とん汁納豆定食。それも美味しそうだ。R

@@選択=SELBTN(@selbtn_s_2,
	違和感を覚える,
	羨ましく思う
)@selbtn_log
IF(@選択==0){		// (違和感を覚える/羨ましく思う) 違和感を覚える

	そこで俺は、違和感を覚える。R
	それは…。R

	@@選択=SELBTN(@selbtn_s_3,
		お前は納豆が苦手なはずだ,
		俺は納豆が苦手だ,
		本当にランダムなのか
	)@selbtn_log
	IF(@選択==0){		// (お前は納豆が苦手なはずだ/俺は納豆が苦手だ/本当にランダムなのか) お前は納豆が苦手なはずだ

		【@音無】「お前は納豆が苦手なはずだ」R
		
		@bs(hn0107)
		KOE(000600269,010)【@日向】「え？　大好きだが？」R
		【@音無】「そうか…」R
		
		@bs(hn0101)
		KOE(000600271,010)【@日向】「まだ、一緒にご飯を食うのも数日だし、俺の苦手なメニューなんてわからなくて当然だ」R
		言う通りだ…。R
		【@音無】「だよな…」R

	}ELSEIF(@選択==1){		// (お前は納豆が苦手なはずだ/俺は納豆が苦手だ/本当にランダムなのか) 俺は納豆が苦手だ

		【@音無】「俺は納豆が苦手だ」R
		
		@bs(hn0109_07)
		KOE(000600278,010)【@日向】「え？　マジかよ…匂いが気になるなら、離れて食おうか？」R
		【@音無】「いや、そこまでじゃないし、そもそも記憶も思い出していないし…」R
		
		@bs(hn0102)
		KOE(000600280,010)【@日向】「じゃ、納豆はとっとと食いきっちまうぜ」R

		@bs(hn0104)
		KOE(000600281,010)【@日向】「その後、歯磨きもする。それで完璧だろ？」R
		【@音無】「ああ、完璧だ…」R

		IF(@その気さらにあり){

			【@音無】「いつも悪いな…」R
			
			@bs(hn0402)
			KOE(000600287,010)【@日向】「そんなの気にすんなって」R
			言って、ろくにかき混ぜずに、納豆を一口で食べきってくれる。R

		}

	}ELSE{	// IF(@選択==2){		// (お前は納豆が苦手なはずだ/俺は納豆が苦手だ/本当にランダムなのか) 本当にランダムなのか

		【@音無】「本当にランダムなのか？」R
		
		@bs(hn0114)
		KOE(000600295,010)【@日向】「え？　何が？」R
		【@音無】「食券選びだよ」R
		【@音無】「まだ数日だけど、朝食に関してはなぜか、お前は常にハズレのない食券を選んでいる気がする…」R
		
		@bs(hn0106@00d)
		KOE(000600298,010)【@日向】「…っ！」R
		
		@bs(hn0407_03)
		KOE(000600299,010)【@日向】「い、いやーそりゃ偶然でしょ。ぴゅーぴゅぴゅー」R
		口笛を吹かれる。R

		IF(@その気さらにあり==0){

			完全にぎくっとしてたし、ごまかし方も下手くそすぎる。R
			//	フォローのため一文追記		西村
			とりあえず食事を続けながらも、俺の疑惑はさらに深いものになった…。R

			@日向からの食券に少し疑問を持つ=1

		}else{

			【@音無】「疑ってすまん…」R
			
			@bs(hn0408_03)
			KOE(000600312,010)【@日向】「あ、いや…いやいや、ぜんぜん気にしてねーぜ？」R;>>焦りつつ
			【@音無】「マジかよ！」R
			
			@bs(hn0402)
			KOE(000600314,010)【@日向】「ああー…大丈夫だ…安心しろ…ははっ」R;>>焦りつつ
			//	誤字修正。「その俺」→「この俺」		西村
			//【@音無】「くっそー、その俺がお前を疑ってしまうなんて！」R
			【@音無】「くっそー、この俺がお前を疑ってしまうなんて！」R
			【@音無】「日向、お前はほんと懐が深いぜ！」R
			
			@bs(hn0209_01)
			KOE(000600317,010)【@日向】「意味はわからないが、いい意味なんだろうな…」R;>>焦りつつ
			【@音無】「もちろん！」R
			
			//	チェックシート修正。朝食シーンの〆を追記		西村
			せっかくの朝食向きメニューだ。日向と一緒に気分良く食べたい。R
			【@音無】「じゃあ、頂きます！　ほら、日向も食おうぜ！」R
			
			@bf(hn0209)
			KOE(001000087,010)【@日向】「あ、ああ…」R
			
			@bs
			
			ふたりで美味しく朝食を頂いた。R
			
			@AB05日向後ろめたく思った=1

		}

	}		// (お前は納豆が苦手なはずだ/俺は納豆が苦手だ/本当にランダムなのか) 選択肢処理のケツ

}ELSE{	//IF(@選択==1){		// (違和感を覚える/羨ましく思う) 羨ましく思う
	
	【@音無】（豚汁と納豆とご飯なんて、朝食として最高な組み合わせじゃないか！）R
	
	羨ましく思うが、口には出さない。R
	
	@bs
	
	サバの塩焼きに箸を入れて、食べる。R
	【@音無】（…！！）R

	;－－－■■＠■■４までありましたが、前回同様カットしておきました（角）　ＯＫ（前田）R
	IF(@おかしい音無１==1||@おかしい音無２==1||@おかしい音無３==1){

		【@音無】（まるで、スキャットマン・ジョンのスキャットを初めて聴いた時のような衝撃だ！）R

	}else{

		その味に衝撃を覚える。R

	}
	;－－－●サバの旬ってほんとに春以降？　■■＠■■さばは秋です。（角）　ＯＫ（前田）R
	【@音無】「ほどよく脂が乗って、完璧すぎる！　旬はこれからだと言うのに！」R
	
	@bs(hn0101)
	KOE(000600345,010)【@日向】「まあ、ここのメニューは旬なんて関係なく、いつでも美味いぜ？」R
	
	@bs
	
	【@音無】（死後の世界なのに、素晴らしい食堂だ。いや、死後の世界だからこそ、か…）R

}		// (違和感を覚える/羨ましく思う) 選択肢処理のケツ

;;■■コメントアウト待避426■■

IF(@岩沢に振られた==1||@岩沢と個人的に会えなくなる==1){
	
	@bs
	
	日向のおかげか、岩沢ともう個人的に会えなくなることも、そこまで深く考えられずにいれた。R

	IF(@その気さらにあり){

		【@音無】「助かるぜ、日向、お前という存在が」R
		
		@bs(hn0207)
		KOE(000600450,010)【@日向】「ん？　俺がなんかしたか？」R
		【@音無】「ああ。ありがとう」R
		
		@bs(hn0104)
		KOE(000600452,010)【@日向】「よくわかんねーけど、どーいたしまして」R

		;@AB05でありがとう言った=1
		@bgm_stack
		@bgm_stop(3000)
		@bgs_nf(hn0101, 3)
		
		【@音無】「………」R
		無言のまま見つめ合う…。R
		
		@bgm_play(m090)		// キャッキャウフフテーゼ(ループ)
		@キャッキャウフフ開始(hn0202, 3)
		KOE(000600367,010)【@日向】「んだよっ、なんとか言えよっ」R

		【@音無】「ありがとうじゃ物足りないぐらい感謝してる」R

		@bs_w(2, hn0103)
		KOE(000600378,010)【@日向】「はっ、そいつは過言だぜ」R
		【@音無】「んなことねーよっ、お前にはほんと感謝してるんだっ」R
		
		@bs_w(2, hn0102)
		KOE(000600380,010)【@日向】「だから、言い過ぎだってよっ」R
		【@音無】「いやいや、感謝感激雨あられさっ」R
		
		@bs_w(2, hn0404)
		KOE(000600382,010)【@日向】「いやいやいやっ！　お前は凄い！　認めろよぉ！？」R
		【@音無】「マジやめてくれよっ、照れるからさぁ！」R
		
		@bs_w(2, hn0402)
		KOE(000600384,010)【@日向】「凄いんだから、照れる必要なんてねぇぜ！！」R
		//	誤字修正。「お前の背中に」→「お前の背中を」		西村
		//【@音無】「いやいや、俺なんてまだまだだっ！　ひたすらお前の背中に追うのに必死だっ！」R
		【@音無】「いやいや、俺なんてまだまだだっ！　ひたすらお前の背中を追うのに必死だっ！」R
		
		@bs_w(2, hn0202)
		KOE(000600386,010)【@日向】「お前のポテンシャルなら、俺の背中なんて、すぐだって話だぜ！」R
		【@音無】「いやいや、お前の背中は途方もなく遠いぜ！？」R
		
		@キャッキャウフフ終了フェード

		IF(@日向とキャッキャウフフした!=0){

			またしばらく、ふたりでキャッキャウフフした。R

		}ELSE{	// IF(@日向とキャッキャウフフした==1){

			しばらく、ふたりでキャッキャウフフした。R
		}
		
		@日向とキャッキャウフフした+=1	;;MAX4

		@キャッキャウフフ終了
		@bgm_pop_play
		
		//#OTONASHIHAAHAA
		【@音無】「はぁ…ごちそうさま…」R
		
		@bs(hn0108)
		KOE(000600414,010)【@日向】「俺もだ…はぁ…はぁ…ごちそうさま…うおぇっ…」R;>>息切れしながら

		IF(@日向とキャッキャウフフした>=1){

			@bs(hn0202)
			KOE(000600418,010)【@日向】「はしゃぎすぎちまったな…」R;>>息切れしながら
			【@音無】「だな…」R
		}

		@感謝しつつキャッキャウフフした=1
		@実績チェック

	}else{		;;その気さらにあり=0

	【@音無】「いろいろと助かったぜ」R

	@bs(hn0207)
	KOE(000600450,010)【@日向】「ん？　俺がなんかしたか？」R
	【@音無】「ああ。ありがとう」R

	@bs(hn0104)
	KOE(000600452,010)【@日向】「よくわかんねーけど、どーいたしまして」R

