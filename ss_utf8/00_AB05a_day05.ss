		@@選択=SELBTN(@selbtn_l_2,
			陽動部隊に合流する,
			カップラーメンに湯を注いだっきり忘れてた
		)@selbtn_log
		IF(@選択==0){		// (陽動部隊に合流する/カップラーメンに湯を注いだっきり忘れてた) 陽動部隊に合流する

			【@音無】「俺は陽動部隊に合流する！」R
			
			@bs(yr0405)
			KOE(000601448,002)【@ゆり】「え！？　そんな勝手許さないわよ！？」R
			
			@fade(bg_kuro, 24)
			
			ゆりの声も無視して、俺は身を翻し、来た道を引き返した。R
			
			close
			
		}ELSE{	//IF(@選択==1){		// (陽動部隊に合流する/カップラーメンに湯を注いだっきり忘れてた) カップラーメンに～

			【@音無】「すまん、カップラーメンに湯を注いだっきり忘れてたから戻る！」R
			俺は身を翻し、来た道を引き返した。R
			
			@bs(yr0205)
			KOE(000601455,002)【@ゆり】「はぁ！？　その言い訳は無理がありすぎるんじゃない！？　しかも本当だとしても今からじゃ麺はのびのびの、ぶよぶよラーメン状態じゃない！？」R
			
			@bs(yr,hn0212)
			KOE(000601456,010)【@日向】「あいつは、きっと、その麺が汁を吸いきったぶよぶよ状態のラーメンが好きなんだろ。すまんって謝ってるんだし、行かせてやれよ」R
			
			@bf(yr0405)
			KOE(000601457,002)【@ゆり】「えーーーっ！　そんなんでいいのかぁーっ！？」R
			
			@bf(hn0104)
			KOE(000601458,010)【@日向】「その分俺が働くからさ」R
			
			@bs(yr0506)
			KOE(000601459,002)【@ゆり】「はー…なんのためのリーダーなんだか」R

			@理由をぶよぶよラーメンにした=1
			
			@fade(bg_kuro, 25)
			@timewaitkey(1000)
		}


		;－－－□外
		@bg_set(ep11_bg015, 0, 0, 0)
		@wipe(3)
		@bg_pos_event(0, 30000, -650, 0, 0, 0)
		@timewaitkey(1000)
		
		//	チェックシート修正。告知ライブが体育館であると明言されていない場合の処理		西村
