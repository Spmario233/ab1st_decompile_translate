IF(@その気さらにあり){		//これ以降で「@その気さらにあり=1」になることはありえないので、「@０１日気がある=0」にします。
	@０１日気がある=0		//消しておかないとおかしなことに（あまの）
}

@bg(ep99_bg001, 25)

