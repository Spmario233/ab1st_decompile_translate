	//	▲▲追記ここまで▲▲
	
	@@選択=SELBTN(@selbtn_s_2,
		岩沢が心配,
		責務を全うする
	)@selbtn_log
	IF(@選択==0){		// (岩沢が心配/責務を全うする) 岩沢が心配

