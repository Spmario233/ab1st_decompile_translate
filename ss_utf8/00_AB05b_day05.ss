				)@selbtn_log
				IF(@選択==0){		// (俺は本気だ/そうかもしれない) 俺は本気だ

					【@音無】「どんな生前でも、俺の思いは本気だ！！」R
					軽々しく扱われ思わず、かっとなってしまう。R
					
					//	整合性のためラベル設置		西村
					#SOUIWARETEMO
					
					@bs(hn0407)
					KOE(000700306,010)【@日向】「いやー、そう言われてもなー。ゆりっぺの生前の話を聞いたか？」R

					IF(@ギルド降下作戦でゆりの生前聞いた==0){

						【@音無】「それは…聞いていない…」R
						
						@bs(hn0408)
						KOE(000700311,010)【@日向】「じゃあまずそれを聞いてみろよ。そしたら、そんな浮ついた考えはゆりっぺに対して消えるから」R
						
						@bs(hn0407)
