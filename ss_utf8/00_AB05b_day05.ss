					}

				}ELSEIF(@選択==1){		// (俺は本気だ/そうかもしれない) そうかもしれない

					【@音無】「そうかもしれない…」R

					GOTO #JYAATONIKAKU

				}		// (俺は本気だ/そうかもしれない) 選択肢処理のケツ

			}ELSE{	// IF(@選択==1){		// (アドバイスをもらう/仲を取り持ってもらう) 仲を取り持ってもらう

				【@音無】「仲を取り持ってくれよ！」R
				;－－－●ここもフラグ必用な気がする…

				@bs(hn0407)
				IF(@音無をただのエロ少年と呼ぶ==1){
					KOE(000700342,010)【@日向】「ただのエロ少年くんは、呑気な奴だなぁ…」R
				}elseif(@音無をエロエロ団ナンバー１と呼ぶ==1){
					KOE(000700344,010)【@日向】「エロエロ団ナンバー１くんは、呑気な奴だなぁ…」R
				}elseif(@音無をエロ侍と呼ぶ==1){
					KOE(000700346,010)【@日向】「エロ侍くんは、呑気な奴だなぁ…」R
				}else{
					KOE(000700348,010)【@日向】「音無くんは、呑気な奴だなぁ…」R
				}

				#OTONASHIE

				【@音無】「え？」R
				
				@bs(hn0109_07)
				KOE(000700354,010)【@日向】「お前、まだ生前の記憶を思い出してないんだろ？」R
				【@音無】「ああ…」R

				#JYAATONIKAKU

				@bs(hn0101)
				KOE(000700359,010)【@日向】「じゃあとにかく、生前を思い出すことを頑張れ。そんな浮ついたゆりっぺへの恋心なんて失せちまうぜ」R
				【@音無】「そうかよ…」R
				【@音無】「でも、頑張れっつっても、何を頑張ればいいんだ…」R
				
				@bs(hn0104)
				KOE(000700362,010)【@日向】「それは時間が解決してくれる。それまでは大人しくしてろよ。な？」R
				【@音無】「ああ…」R
				
				@bs
				
				そう答えるしかなかった。R

				@AB05生前を思い出したい=1

			}		// (アドバイスをもらう/仲を取り持ってもらう) 選択肢のケツ

			//}		// IF(@AB03音無ゆりが好きと日向に伝えた==0) のケツ		// ■■■■ここ else なくていいの？（西）上階層と結合して対処（西

//	@ゆりに気がある 系が立ってると矛盾するので、コメントアウト		西村
/*
		}ELSE{		//		;－－－■■＠■■条件を満たしていない場合が必要ですので追加しました。（角）　ＯＫ（前田）R

			【@音無】「ゆり…かなぁ？」R
			
			@bs(hn0109_07)
			KOE(000700375,010)【@日向】「なんだよ、そのふわふわした回答は…」R
			言ってはみたものの、そんな気はまるでしない…。R
	
			GOTO #SUMANUSO
*/

		//}		// IF((@ゆりから釘を刺された上追い出される==1||@ゆり浮ついたら死よりも恐い罰==1)&&なんちゃら) の else ケツ

	}		// IF(@ゆりの下着でどぴゅりまくった==1||@音無をエロ侍と呼ぶ==1||@ゆりのパンツを大事に仕舞った==1)の else ケツ

}

//#MODORUYO


return

