// #SCENE_SCRIPT_ID = 0007 （スクリプトＩＤ：この行は削除したり、変更したりしないで下さい）
#Z00


@@選択=SELBTN(@selbtn_s_5,
	岩沢に気がある,
	ひさ子に気がある,
	関根に気がある,
	入江に気がある,
	//	整合性とるために条件付き選択肢にしました		西村
	ゆりに気がある,@ゆりに気がある==1||@ゆりに気があると答えた==1
)@selbtn_log
IF(@選択==0){		// (５人から選択)===========================================岩沢に気がある

	GOTO #AAIWASAWADA

}ELSEIF(@選択==1){		// (５人から選択)===========================================ひさ子に気がある

	@AB05ひさ子に気がある=1

	【@音無】「ひさ子」R

	GOTO #HEEE

}ELSEIF(@選択==2){		// (５人から選択)===========================================関根に気がある

	【@音無】「いや、関根に気がある」R
	
	@bs(hn0106)
	KOE(000700027,010)【@日向】「えぇぇぇー！！　あいつにどんな魅力があるってんだよ！？」R
	【@音無】「やっぱ引くよな…」R
	
	@bs(hn0105)
	KOE(000700029,010)【@日向】「そもそも接点ないだろ！」R

	@@選択=SELBTN(@selbtn_s_2,
		嘘だと白状する,
		本気だと伝える
	)@selbtn_log
	IF(@選択==0){		// (嘘だと白状する/本気だと伝える) 嘘だと白状する

		#SUMANUSO

		【@音無】「すまん、嘘だ…」R
		
		@bs(hn0108)
		KOE(000700040,010)【@日向】「だろーな。岩沢か、ひさ子、どっちだ？」R

		@@選択=SELBTN(@selbtn_s_2,
			岩沢,
			ひさ子
		)@selbtn_log
		IF(@選択==0){		// (岩沢/ひさ子) 岩沢

			#AAIWASAWADA

			IF(@ゆりとの舌戦に勝った==1){

				【@音無】「ああ、岩沢だ」R

			}else{

				【@音無】「ああ…岩沢だ…」R
				苦しげに告げた。R

			}

			@bs(hn0104)
			KOE(000700061,010)【@日向】「だろーな。今のガルデモの人気は岩沢がフロントマンに立つ、そのカリスマ性によるものだ」R
			【@音無】「まるで、俺がただの１ファンみたいじゃないか」R
			
			@bs(hn0103)
			KOE(000700063,010)【@日向】「ああ、その通りだ」R

			IF(@ゆりとの舌戦に勝った==0){

				俺は言葉を失う。R

			}

			@bs(hn0401)
			KOE(000700071,010)【@日向】「でも時間をかければ、岩沢が心を許す唯一の存在が、お前になる日も来るかもな」R
			【@音無】「マジかよ…」R
			
			@bs(hn0402)
			KOE(000700073,010)【@日向】「時間はいくらでもあるからな」R

			@bs
			
			IF(@ゆりとの舌戦に勝った==1){
				
				本当にそんな日が来るといいな…。R

			}else{

				そんな日が果たしてくるのだろうか…。R

			}

			@AB05岩沢に気がある=1

//			GOTO #MODORUYO

		}ELSEIF(@選択==1){		// (岩沢/ひさ子) ひさ子

			【@音無】「…ひさ子だ」R

			#HEEE

			@bs(hn0107)
			KOE(000700095,010)【@日向】「へー、ひさ子の生前を聞いたのか？」R

			IF(@ひさ子の生前を聞いた==0){

				【@音無】「いや…聞いていない」R
				
				@bs(hn0103)
				KOE(000700100,010)【@日向】「それでどうしてひさ子なんだよ。ルックスか？」R

				@@選択=SELBTN(@selbtn_s_2,
					ああ,
					わからない
				)@selbtn_log
				IF(@選択==0){

					【@音無】「ああ」R
					
					@bs(hn0402)
					KOE(000700109,010)【@日向】「おっと、そいつは通だな」R
					【@音無】「え？　どうして？」R
					
					@bs(hn0408)
					KOE(000700111,010)【@日向】「ガルデモってのは、素人から見れば、岩沢のワンマンバンドに見える」R
					
					@bs(hn0404)
					KOE(000700112,010)【@日向】「でも、それを支えてるのはこの世界で古くから親友関係にあった、ひさ子だ」R
					
					@bs(hn0401)
					KOE(000700113,010)【@日向】「ガルデモの作曲は岩沢だが、アレンジはほぼひさ子が考えている」R
					
					@bs(hn0403)
					KOE(000700114,010)【@日向】「岩沢も任せっきりにできるぐらい、あのふたりの絆は深い」R
					【@音無】「だったら、俺の行動は正しかったのか…？」R

				}ELSE{	//IF(@選択==1){

					【@音無】「わからない…」R
					
					@bs(hn0202)
					KOE(000700120,010)【@日向】「まあ、あいつはあいつで、カリスマ性があるからなー。わからなくもない」R

//					GOTO #OTONASHIKOREWA

				}

			}else{		// not (@ひさ子の生前を聞いた==0)

				【@音無】「ああ」R
				
				@bs(hn0109_07)
				KOE(000700129,010)【@日向】「あいつはあいつでヘヴィーな生前だったからな…その気持ちはわかるよ」R

//				GOTO #OTONASHIKOREWA

			}		// if(@ひさ子の生前を聞いた==0) ケツ

//			#OTONASHIKOREWA
			
			@bs(hn0105_09)
			KOE(000700137,010)【@日向】「音無、これはあくまでも俺の意見だ…」R
			日向の目つきが鋭く変わる。R
			何を言う気だ…。身構えてしまう…。R
			
			@bs(hn0105_07)
			KOE(000700140,010)【@日向】「きっと、お前が行動を起こしていなければ、岩沢はこの世界から消えていたかもしれない」R
			
			IF(@ひさ子の生前を聞いた==0){

				@bs(hn0105_09)
				KOE(000700144,010)【@日向】「岩沢がこの世界から消えていれば、ひさ子は精神的に壊れてるはずだった」R

			}else{

				@bs(hn0105_09)
				KOE(000700148,010)【@日向】「過去を知っている俺からすれば、岩沢がこの世界から消えていれば、ひさ子は精神的に壊れてるはずだった」R

			}

			【@音無】「でもそんなの一晩で癒える世界だろ？」R
			
			@bs(hn0202)
			KOE(000700153,010)【@日向】「まあ、怪我とかはな」R
			つんつんと日向は自分の頭を人差し指で小突く。R
			
			@bs(hn0109)
			KOE(000700155,010)【@日向】「でも頭のほうは違う。絆を深めた相手が消えれば、すぐには受け入れられない」R
			
			@bs(hn0104)
			KOE(000700156,010)【@日向】「だから、俺は正しかったと思うよ」R
			【@音無】（俺と同じ思いだ…）R
			
			@bs(hn0102)
			KOE(000700158,010)【@日向】「今話したこと、ゆりっぺには言うなよ？」R
			【@音無】「ああ…」R

//			GOTO #MODORUYO

		}		// (岩沢/ひさ子) ケツ

	}ELSE{ //IF(@選択==1){		// (嘘だと白状する/本気だと伝える) 本気だと伝える

		【@音無】「本気だ…」R
		
		@bs(hn0209)
		KOE(000700168,010)【@日向】「じゃあ、あいつのどこに惹かれたってんだよ」R
		【@音無】「それは…」R

		@関根に嘘で気がある=1

		@@選択=SELBTN(@selbtn_s_2,
			ルックス,
			ベースのプレイ姿
		)@selbtn_log
		IF(@選択==0){

			【@音無】「単純にルックス」R
			
			@bs(hn0209_07)
			KOE(000700180,010)【@日向】「それ、本気で言ってるのか？」R
			【@音無】「ああ」R
			
			@bs(hn0208)
			KOE(000700182,010)【@日向】「そこまで言い切るのか…」R
			
			@bs(hn0102)
			KOE(000700183,010)【@日向】「わかったよ。とりあえず信じてやるよ」R

		}ELSE{	// IF(@選択==1){

			【@音無】「ベースのプレイ姿」R
			
			@bs(hn0207)
			KOE(000700188,010)【@日向】「へー」R
			【@音無】「おかしいか？」R
			
			@bs(hn0101)
			KOE(000700190,010)【@日向】「いや、特には。あーそうなんだー、という感想」R
			【@音無】「そう言われると、俺、軽いな…」R
			
			@bs(hn0102)
			KOE(000700192,010)【@日向】「いやいや、趣味は人それぞれだから、いいと思うぜ？」R
			【@音無】「なら、いいんだが…」R

		}

	}		// (嘘だと白状する/本気だと伝える) ケツ

}ELSEIF(@選択==3){		// (５人から選択)===========================================入江に気がある

	【@音無】「いや、入江に気がある」R
	
	@bs(hn0106)
	KOE(000700202,010)【@日向】「マジかよっ！？」R
	【@音無】「おかしいか？」R
	
	@bs(hn0408)
	KOE(000700204,010)【@日向】「いや、校内でも、あいつは小動物的に人気が高い。お目が高いときたもんだ…」R
	【@音無】「マジで！？」R
	
	@bs(hn0407_06)
	KOE(000700206,010)【@日向】「なんだよ、自分から言っておいて」R
	@@選択=SELBTN(@selbtn_s_2,
		嘘だと白状する,
		本気だと伝える
	)@selbtn_log
	IF(@選択==0){

		GOTO #SUMANUSO

	}ELSEIF(@選択==1){

		【@音無】「本気だ…」R
		
		@bs(hn0209)
		KOE(000700168,010)【@日向】「じゃあ、あいつのどこに惹かれたってんだよ」R
		【@音無】「それは…」R

		@入江に嘘で気がある=1

		@@選択=SELBTN(@selbtn_s_2,
			ルックス,
			ドラムを叩く姿
		)@selbtn_log
		IF(@選択==0){

			【@音無】「単純にルックス」R
			
			@bs(hn0102)
			KOE(000700229,010)【@日向】「確かに入江は小動物系で可愛い。俺は年上のスレンダーなクールビューティーが好きだから、興味ねーけどな」R
			【@音無】「へー」R

		}ELSEIF(@選択==1){

			【@音無】「ドラムを叩く姿」R
			
			@bs(hn0102)
			KOE(000700234,010)【@日向】「まあ、あいつはドラムを叩く時と普段でギャップがありすぎるから、そういうところに惚れるＮＰＣもよく居るからなぁ」R

		}

	}

}ELSEIF(@選択==4){		// (５人から選択)===========================================ゆりに気がある
	;;■■コメントアウト待避545■■


	//	分岐条件修正しました		西村
	//IF(@ゆりの下着でどぴゅりまくった==1||@音無をエロ侍と呼ぶ==1||@ゆりのパンツを大事に仕舞った==1){
	IF(@ゆりの下着でどぴゅりまくった==1&&@今あだ名である==1){
	
		【@音無】「いや、ゆり一筋だ…」R
		
		// k-takahashi ↓名前ミスと声命令直しました。一つ声が見つかりませんでした
		@bs(hn0209_07)
