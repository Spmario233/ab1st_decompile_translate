		}else{
		
			【@音無】「え、どうして！？」R
		
		}
		
		@bs(hn0103)
		KOE(000700279,010)【@日向】「お前、用もなしにゆりっぺに会いに行ってたろ」R
		【@音無】「なぜ、それを？」R
		
		@bs(hn0404)
		KOE(000700281,010)【@日向】「そういう情報はこの世界ではすぐ回ってくるんだよ…」R
		【@音無】「そっか…」R
		
		//	嫌われていない場合の条件分岐		西村
		IF(@ゆりから釘を刺された上追い出される==0&&@ゆり浮ついたら死よりも恐い罰==0){
		
