//■■■■ユリブサイク抜け（あまの

IF(@野田とのフラグがすごく立つ){
	
	@bf(nd0301)
	KOE(001008035,011)【@野田】「そうか…」R

	@bs(nd0102)
	KOE(001008036,011)【@野田】「頼んだぞ、音無」R

	IF(@歯が飛んでまともに話せない){
	
		@bs(nd0101_02)

		今度は、真剣な目で見られる。R
		前歯がないので、無言のまま頷く。R

		GOTO #HINATASHIKASHI

	}

	IF(@今あだ名である){
		
		// k-takahashi ここは通りません
		
		IF(@音無を日向markⅡと呼ぶ){
			【@音無】「今の俺は日向"mar"…」R
		}elseif(@音無をアメリカンエロドッグと呼ぶ){
			【@音無】「今の俺はアメリカン…」R
		}elseif(@音無をエロ侍と呼ぶ){
			【@音無】「今の俺はえろ…」R
		}elseif(@音無をエロエロ団ナンバー１と呼ぶ){
			【@音無】「今の俺はえろえろ…」R
		}elseif(@音無をただのエロ少年と呼ぶ){
			【@音無】「今の俺はただのえろ…」R
		}
		//■■■■ユリブサイク抜け（あまの

		KOE(001008061,011)【@野田】「お前は音無だっ！　俺はそう呼ぶ！！」R
		いきなりのことで、俺は反応出来ずにいる…。R

		KOE(001008063,011)【@野田】「ええと…」R

		KOE(001008064,011)【@野田】「駄目か…？」R

		@@選択=SELBTN(@selbtn_s_2,
			いい,
			駄目
		)@selbtn_log
		IF(@選択==0){

			【@音無】「いいよ。呼んでくれ、音無ってさ」R
			
			KOE(001008073,011)【@野田】「ふぅ…断られるかと思ったぜ…」R
			
			KOE(001008074,010)【@日向】「え？　俺は？」R

			IF(@音無をエロ侍と呼ぶ){
				IF(@歯が飛んでまともに話せない){
					【@音無】「お前はほのままで頼む」R
				}else{
					【@音無】「お前はエロ侍と呼んでくれ」R
				}
			}elseif(@音無をエロエロ団ナンバー１と呼ぶ){
				IF(@歯が飛んでまともに話せない){
					【@音無】「お前はほのままで頼む」R
				}else{
					【@音無】「お前はエロエロ団ナンバー１と呼んでくれ」R
				}
			}elseif(@音無をアメリカンエロドッグと呼ぶ){
				IF(@歯が飛んでまともに話せない){
					【@音無】「お前はほのままで頼む」R
				}else{
					【@音無】「お前はアメリカンエロドッグと呼んでくれ」R
				}
			}elseif(@音無をただのエロ少年と呼ぶ){
				IF(@歯が飛んでまともに話せない){
					【@音無】「お前はほのままで頼む」R
				}else{
					【@音無】「お前はただのエロ少年と呼んでくれ」R
				}
			}

			KOE(001008102,010)【@日向】「俺ひとりが、いじめてるようじゃねぇーかよぉーー！！」R

			IF(@歯が飛んでまともに話せない){

				【@音無】「ほれは俺にはひたいまひめだ。頼む」R

			}else{

				【@音無】「それは俺に課した戒めだ。頼む」R

			}

			KOE(001008114,010)【@日向】「理不尽だぁぁーーー！！」R

			@AB07野田は音無と呼ぶ=1

		}ELSE{	// EIF(@選択==1){

			IF(@歯が飛んでまともに話せない){

				【@音無】「駄目だ…ほれは俺にはしたいまひめだ。頼む」R

			}else{

				【@音無】「駄目だ…それは俺に課した戒めだ。頼む」R

			}

			KOE(001008130,011)【@野田】「はっ、自分に厳しい奴だな」R
			【@音無】「悪い…」R

			KOE(001008132,011)【@野田】「いや、そういうところは嫌いじゃない」R

			KOE(001008133,010)【@日向】「へーーー」R
			今度は日向が不思議そうな目で俺たちを見てくる。R

			KOE(001008135,011)【@野田】「どうした」R

			KOE(001008136,010)【@日向】「いや、何も…」R

		}

	}else{		// not(@今あだ名である==1)
		
		@bs(nd0101_02)
		
		今度は、真剣な目で見られる。R

		IF(@歯が飛んでまともに話せない==1){

			無言のまま頷く。R

		}else{

			【@音無】「ああ」R
			頷く。R

		}

	}		// IF(@今あだ名である==1) 処理のケツ

}else{		// not (@野田とのフラグがすごく立つ==1)

	@bf(bs3_nd0103@00a)
	@横揺れ_弱
	KOE(001008159,011)【@野田】「音無っ、俺と代われ！！」R

	@bf(hn0305)
	KOE(001008160,010)【@日向】「いやいやっ、代えられないから！」R

}		// IF(@野田とのフラグがすごく立つ==1) else処理のケツ

