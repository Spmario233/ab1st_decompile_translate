					}else{
					
						【@音無】「いやいや、それは褒めすぎだろぉー！！　こいつぅーー！！」R
					
					}
					
					// k-takahashi ↓かぶってたのでswitch内に含みます
					// 抱き合いながら、くるくる回り、しばらくふたりでキャッキャウフフした。R

					@キャッキャウフフ終了フェード

					switch(@日向とキャッキャウフフした){	;;この時点でMAX5
						case(0)	
							抱き合いながら、くるくる回り、しばらくふたりでキャッキャウフフした。R
						case(1)	
							抱き合いながら、くるくる回り、またふたりでキャッキャウフフした。R
						case(2)	
							抱き合いながら、くるくる回り、またふたりでキャッキャウフフした。R
						case(3)	
							抱き合いながら、くるくる回り、いつものようにふたりでキャッキャウフフした。R
						case(4)	
							抱き合いながら、くるくる回り、いつものようにふたりでキャッキャウフフした。R
						case(5)	
							抱き合いながら、くるくる回り、いつものようにふたりでキャッキャウフフした。R
					}

					@キャッキャウフフ終了
					@bgm_pop_play

					@くるくる回りながらキャッキャウフフした=1
					@実績チェック
					
					//#NODASHITTO

					IF(@野田に嫉妬されるまでになる==1||@野田とのフラグがすごく立つ==1){
						
