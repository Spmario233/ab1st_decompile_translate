						@bgm_play(m118)
						@pcmch_play(0, @ヘルメット)
						@縦揺れ_弱(0, 0)
						@bgs(ep04_bg043, nd0307, 0)
						
						そこへ憤慨の声。野田がマスクを剥いで、地面に叩きつけていた。R
						
						@face(hn0107)
						KOE(001009787,010)【@日向】「えっ！？」R

						@bs(nd0606)
						KOE(001009788,011)【@野田】「野球未経験だった俺が、お前のボールをキャッチし続け、ホームランを打ち続けていたこと、そんなことはお前にとってはどーでもいいことなのかよっ！！」R
						
						IF(@歯が飛んでまともに話せない){
						
							【@音無】「それは、もひほん助はっはよ」R
						
						}else{
						
							【@音無】「それは、もちろん助かったよ」R
						
						}
						
						@bs(nd0307)
						KOE(001009790,011)【@野田】「だったら、俺も混ぜろぉーー！！」R
						
						@bs_add(bs3_hn0112, 4)
						KOE(001009791,010)【@日向】「えぇ！？　野田、マジで言ってんの！？」R

						@bf(nd0205)
						KOE(001009792,011)【@野田】「ああ…マジだ」R

						@bf(hn0105)
						KOE(001009793,010)【@日向】「ゆりっぺの言うことしか聞かない、ずっと一匹狼だった野田、お前に何があった！？」R

						@bf(nd0301_02)
						KOE(001009794,011)【@野田】「こいつは何かを持っているっ！　俺のポテンシャルを引き出し、ネクストステージへ運んでくれる…そんな存在だからだ！！」R

						@bf(hn0109_07)
