	@bs(hn0102)
	KOE(000502463,010)【@日向】「電気消すなー」R

	【@音無】「ああ」R
	
	@bs
	@timewaitkey(300)
	@pcmch_play(0, @照明スイッチ)
	@bg(ep99_bg004, 2)


	@face(hn0104)
	KOE(000502473,010)【@日向】「おやすみ」R
	【@音無】「ああ、おやすみ」R
}

