		@bs(bs2_hn0104)
		KOE(001500939,010)【@日向】「ただの味噌ラーメンが、味噌コーンバターラーメンへと生まれ変わった瞬間さっ」R;>>青春的な爽やかさで


		IF(@日向とキャッキャウフフした>=1){
			【@音無】「はっ…お前って奴は…」R
			【@音無】「粋な真似しやがってぇーー！！」R
			
			@bgm_play(m090)		;;キャッキャウフフスタート！
			@timewaitkey(1000)
			@キャッキャウフフ開始(hn0104, 3)
			
			俺は日向に襲いかかる。R
			
			@bs_w(2, hn0102)
			KOE(001500943,010)【@日向】「うおっと、やめろよぉーー！！」R;>>嬉しそうに
			
			日向を押し倒し、床を転がる。まるで草原の上のように。R
			
			@bs_w(2, hn0104)
			KOE(001500945,010)【@日向】「こら、皆さんの邪魔になってるだろぉーー！！」R
			【@音無】「自業自得さぁーー！！　このやろぉーー！！」R
			
			@bs_w(2, hn0202)
			KOE(001500947,010)【@日向】「机にぶつかって、ＮＰＣさんの食器割っちゃってるぜぇーー！？」R
			【@音無】「それも自業自得さぁーー！！　このやろぉーー！！」R
			
			@bs_w(2, hn0104)
			KOE(001500949,010)【@日向】「やめろやめろやめろぉーー！！　今度はカレールーみたいのが降ってきたぜぇーー！？」R
			【@音無】「それも自業自得さぁーー！！　このやろぉーー！！」R
			
			@bs_w(2, hn0202)
			KOE(001500951,010)【@日向】「アチーーー！！　アッチーー！！　今度はホットのお茶が降ってきたぁーー！！」R
			【@音無】「それも自業自得さぁーー！！　このやろぉーー！！」R

			@キャッキャウフフ終了フェード
			
			いつものようにふたりでキャッキャウフフした。R

			@カレーとお茶を浴びながらキャッキャウフフした=1
			@実績チェック

			@AB12日向カレールーとお茶浴びた=1
			
			@bgm_stop(2000)
			@fade_all(bg_siro, 5, 1)
			@timewaitkey(2000)
		}

		@bg(ep01_bg100, 25)	;－－－テーブル
		
		それぞれお盆を持ち、横並びにテーブルにつく。R
		【@音無】「やべー、すげーいい匂いなんだが…」R
		
		@bs(hn0102)
		KOE(001500969,010)【@日向】「お気に召しますかね」R
		【@音無】「すぐ食べたい！」R
		
		@bs(hn0101)
		KOE(001500971,010)【@日向】「では、頂きます」R
		【@音無】「頂きます！」R
		
		@bs
		
		手を合わした後、互いに麺をすすり始める。R
		【@音無】「美味い！」R
		
		@bs(hn0104)
		KOE(001500975,010)【@日向】「そりゃよかった」R

		IF(@AB12日向カレールーとお茶浴びた){
		
			@bs(hn0208)
			KOE(001500976,010)【@日向】「しかし、制服がベタベタして気持ち悪いぜ…」R
			【@音無】「明日には綺麗になってるよ」R
			
			@bs(hn0209_07)
			KOE(001500978,010)【@日向】「いや、制服は勝手に回復しない世界なんだが…」R
    	}
		
		@食券味噌コーンバターラーメン=1
		@実績チェック


	}ELSE{	// IF(@選択==1){		// (いい/駄目) 駄目

		【@音無】「駄目」R
		
		@bs(hn0407_06)
		KOE(001500983,010)【@日向】「えーー…」R
		
		@bs(hn0407)
		KOE(001500984,010)【@日向】「ま、しゃーない。にゅうめんだけを食うぜ」R

		@bg(ep01_bg100, 25)	;－－－テーブル
		
		それぞれお盆を持ち、横並びにテーブルにつく。R
		
		@bs(hn0101)
		KOE(001500988,010)【@日向】「では、頂きます」R
		【@音無】「頂きます」R
		
		@bs
		
		手を合わした後、お互い、黙々と食べ続けた。R
		
		@食券味噌ラーメン=1
		@実績チェック

	}		// (いい/駄目) 

}else{		// not (@朝食のチケットは平等==1)

	@bs(hn0104)
	KOE(001500919,010)【@日向＿重複】「じゃ、まずお前の夕飯いっくぜっ？」R

	@bs(hn0401)
	
	ポケットからランダムに取り出された食券は…。R
	
	@bs(hn0302)
	KOE(001500998,010)【@日向】「にゅうめんーーー！！」R
	【@音無】「え？　にゅうめんって、あの、そーめんを煮た？」R
	
	@bs(hn0101)
	KOE(001501000,010)【@日向】「ああ」R
	【@音無】「軽っ！」R
	
	@bs(hn0102)
	KOE(001501002,010)【@日向】「おっと、またトッピングを希望かい？　何がでるかわからないぜ？」R
	
	ポケットの中をかき混ぜながら訊いてくる。R

	@@選択=SELBTN(@selbtn_s_2,
		トッピング行く,
		やめておく
	)@selbtn_log
	IF(@選択==0){		// (トッピング行く/やめておく) トッピング行く

		【@音無】「トッピング行く」R
		
		@bs(hn0104)
		KOE(001501012,010)【@日向】「よし、わかった、いくぜー」R
		
		@bs(hn0105)
		KOE(001501013,010)【@日向】「トッピングはこれだぁーー！！」R
		【@音無】（…なんだ！？）R
		
		@bs(hn0302)
		KOE(001501015,010)【@日向】「トムヤムカレー！！」R

		IF(@トムヤムカレーにハマる==1){
			
			@bs
			@縦揺れ_弱
			
			【@音無】「いよっしゃぁーーー！！」R
			
			@bs(hn0109_07)
			KOE(001501020,010)【@日向】「え？　なぜ喜ぶ…？」R
			不思議そうな目で見られる。R
			【@音無】「いや、そいつの味にハマッてさ。久々に食べられるぜ」R
			
			@bs(hn0109)
			KOE(001501023,010)【@日向】「そうか…なら、いいんだが…」R

		}else{
			
			@bs
			@縦揺れ_弱
			
			【@音無】「うわああぁぁぁぁーー…！！」R
			ショックの余り、頭を抱えてしまう。R

			IF(@AB03夕飯塩ラーメンと醤油ラーメンに==1){

				【@音無】「しかも前回と同じトッピングではなくメインーー！！」R

			}else{

				【@音無】「しかもトッピングではなくメインーー！！」R

			}

			@bs(hn0408)
			KOE(001501040,010)【@日向】「俺のポケットにはあらゆる食券が入ってる。丼物だったら良かっただろうけど、こんなこともあるさ」R

		}

		@bs(hn0402)
		KOE(001501044,010)【@日向】「じゃ、俺はと、ほいっ！」R
		
		@bs(hn0302)
		KOE(001501045,010)【@日向】「味噌ラーメンゲットォーー！！」R

		IF(@トムヤムカレーにハマる==0){

			【@音無】（くっそ、羨ましすぎる…！）R

		}

		@bs(hn0104)
		KOE(001501053,010)【@日向】「さらにトッピング行くぜぇ…」R

		IF(@トムヤムカレーにハマる==0){

			【@音無】（トムヤムカレー引けぇーー！！）R

		}

		@bs(hn0105)
		KOE(001501061,010)【@日向】@bc「とうっ！　コーーーン！」@bs_c(800,hn0102) R

		IF(@トムヤムカレーにハマる==0){

			【@音無】「なな、なんだ、そのしっくりくるトッピングは！！」R

		}

		@bs(hn0408)
		KOE(001501069,010)【@日向】「そして、俺はさらに攻める！！」R

		IF(@トムヤムカレーにハマる==0){

			【@音無】「まま、まさか…！！」R

		}

		@bs(hn0402)
		KOE(001501077,010)【@日向】「もう一枚、引くぜ、引くぜ、引くぜぇーーー！！」R
		
		@bs(hn0302)
		KOE(001501078,010)【@日向】「ほいっ！　バターー！！」R

		IF(@トムヤムカレーにハマる==0){

			【@音無】「なな、なんだ、そのもうそれ以外はありえないぐらいしっくりくるトッピングは！！」R

		}else{

			日向がひとりで盛り上がっていた。R

		}

		@bs(hn0104)
		KOE(001501090,010)【@日向】「よし、ただの味噌ラーメンが、味噌コーンバターラーメンへと生まれ変わったぜ」R
		
		@移動(ep01_bg100)		;－－－テーブル
		
		それぞれお盆を持ち、横並びにテーブルにつく。R

		@bs(hn0102)
		KOE(001501095,010)【@日向】「では、頂きます」R
		【@音無】「頂きます」R

		IF(@トムヤムカレーにハマる==1){

			@bs
			
			まずトムヤムカレーをスプーンで一口。R
			
			@縦揺れ_弱
			
			【@音無】「これこれこれー！　うめぇーー！！」R
			
			@bs(hn0107)
			KOE(001501102,010)【@日向】「すげーな、お前…」R

		}else{
			
			@bs
			
			【@音無】（くっ、またこの臭いとの戦いかよっ…）R
			
			@bs(hn0105)
			KOE(001501107,010)【@日向】「めげるな、頑張れー」R
			【@音無】「そりゃ頑張るけどさ…」R

		}

		@bs
		
		それからはお互い、黙々と食べ続けた。R
		
	
	}else{		// (トッピング行く/やめておく) やめておく

		【@音無】「やめとく」R
		
		@bs(hn0107)
		KOE(001501117,010)【@日向】「え？　にゅうめんだけでいいのか？　そんなんじゃ腹膨れねーぜ？」R
		【@音無】（…ん？）R

		@@選択=SELBTN(@selbtn_s_2,
			疑問に思う,
			気のせいだ
		)@selbtn_log
		IF(@選択==0){		// (疑問に思う/気のせいだ) 疑問に思う

			【@音無】「なんだか、もう一枚引かないと都合が悪いようだな」R
			
			@bs(hn0209_07)
			KOE(001501127,010)【@日向】「え？　いや、純粋にそれだけでいいのかなって思っただけだぜ？」R;>>ちょい焦りつつ
			【@音無】「いいよ。これだけで」R
			
			@bs(hn0402)
			KOE(001501129,010)【@日向】「ああ、よし。じゃ、行こう」R

		}ELSE{	// IF(@選択==1){		// (疑問に思う/気のせいだ) 気のせいだ
			
			@bs
			
			【@音無】（気のせいだ…日向に限って…）R

		}		// (疑問に思う/気のせいだ) 

		//───────────────────────────────────
		//上からコピーしてきた
		@bs(hn0402)
		KOE(001501044,010)【@日向】「じゃ、俺はと、ほいっ！」R
		
		@bs(hn0302)
		KOE(001501045,010)【@日向】「味噌ラーメンゲットォーー！！」R

		@bs(hn0104)
		KOE(001501053,010)【@日向】「さらにトッピング行くぜぇ…」R

		@bs(hn0105)
		KOE(001501061,010)【@日向】@bc「とうっ！　コーーーン！」@bs_c(800,hn0102) R

		@bs(hn0408)
		KOE(001501069,010)【@日向】「そして、俺はさらに攻める！！」R

		@bs(hn0402)
		KOE(001501077,010)【@日向】「もう一枚、引くぜ、引くぜ、引くぜぇーーー！！」R
		
		@bs(hn0302)
		KOE(001501078,010)【@日向】「ほいっ！　バターー！！」R

		IF(@その気さらにあり){

			【@音無】「なな、なんだ、そのもうそれ以外はありえないぐらいしっくりくるトッピングは！！」R

		}else{

			日向がひとりで盛り上がっていた。R

		}

		@bs(hn0104)
		KOE(001501090,010)【@日向】「よし、ただの味噌ラーメンが、味噌コーンバターラーメンへと生まれ変わったぜ」R
		//ここまで
		//───────────────────────────────────

		@移動(ep01_bg100)	;－－－テーブル

		それぞれお盆を持ち、横並びにテーブルにつく。R
		
		@bs(hn0101)
		KOE(001501139,010)【@日向】「では、頂きます」R
		【@音無】「頂きます」R
		
		@bs
		
		お互い、黙々と食べ続けた。R
	
	}		// (トッピング行く/やめておく) 
	
	// トムヤムカレーはすでに立っている
	@食券にゅうめん=1
	@実績チェック

}		// IF(@日向態度で示していくことに==1)

//	▼▼AB13で雨が降る流れはカットになってるので、雨の会話はカット▼▼		西村
/*
@移動(ep01_bg100)	;－－－テーブル

@bs(hn0401)
KOE(001501147,010)【@日向】「明日はたぶん雨だなー…」R
食事を終えたところで、窓の外を見ながら日向が呟いた。R
【@音無】「え？　この世界でも降るのか？」R

@bs(hn0101)
KOE(001501150,010)【@日向】「そりゃ、降るさ。生前の世界を再現してるんだからな。初日にゆりっぺから聞かされてなかったのか？」R

@ゆり服装=@戦線制服

@回想開始スタック
@fade(bg_kuro, 2)
@bgs(ep88_bg002, bs2_yr0101)
KOE(000201457,002)【@ゆり＿重複】「正解。ちゃんと移ろうわよ。今は春。夏には雨が、冬には雪が降るわ」R
【@音無】「雪まで降るのか…」R

@bs(yr0101_02)
KOE(000201459,002)【@ゆり＿重複】「生きていた時そのままを再現した世界でないと意味がないんでしょ」R

@fade(bg_kuro, 2)
@回想終了スタック

【@音無】「思い出した…確かに言われたよ」R
【@音無】「でもどうして雨だとわかる？」R

@bs(hn0104)
KOE(001501160,010)【@日向】「慣れだよ。空気の感じとか、空の色とか」R
【@音無】「ふーーーん…」R
*/
//	▲▲雨の会話カットここまで▲▲

@bgm_stop(2000)
@fade(bg_kuro, 25)
@bgm_play(m303)

IF(@もうイケチン見られない==1||@日向と風呂入るのが今後ない==1){

	部屋に戻り、その後、日向と入れ替わりに風呂に入る。R

	@湯気
	@bg(ep88_bg025, 25);－－－浴場

	浴場に入ると、すぐＮＰＣに混じっている幹部メンバーを見つける。R
	【@音無】（あの筋肉は、高松…）R
	たまたま隣のカランが空いていたので、高松の隣に座ることに。R
	高松は筋肉をまとった背中をタオルで乾布摩擦のように洗っていた。R
	【@音無】「よう」R
	一応声をかけてみる。R
	
	@高松服装=@上半身裸
	
	@bs(bs2_tm0409)		//■■■■眼鏡いるんかね？（あまの
	KOE(001501176,012)【高松】「ん？　これは音無さん」R
	俺に気づいても、背中を洗う手は止めないでいた。R
	【@音無】「こんなところで会うなんて珍しいな」R
	
	@bs(tm0409_10)
	KOE(001501179,012)【高松】「これまでは、この鍛え抜かれた肉体を仲間にさえ晒すことはありませんでした」R
	【@音無】「じゃあ、なぜ？」R
	
	@bs(tm0111)
	KOE(001501181,012)【高松】「もう、バレてしまったので」R
	
	@bs(tm0111_10)
	KOE(001501182,012)【高松】「いつかそんな日が来ることはわかっていました」R
	
	@bs(tm0111_06)
	KOE(001501183,012)【高松】「この肉体は、戦線のために鍛えたものではありません。そもそも戦線に加わる前にこの肉体は仕上がっていました」R
	【@音無】「へー…どうして？」R
	
	@bs(tm0111_01)
	KOE(001501185,012)【高松】「それは…遠い昔話です」R

	@bs(tm0409)
	
	止まりそうだった乾布摩擦の手が、また忙しく動き出す。R
	その昔話を聞き出すには場所も時間もあまりにも悪い。R
	
	@bs(tm0409_02)
	KOE(001501188,012)【高松】「でも、晒すのであれば、ここだー！という機会をずっと待ち続けていました」R
	【@音無】「あー、それで、ここだー！って思って、あそこで脱いじゃったんだ」R
	
	@bs(tm0411_05)
	KOE(001501190,012)【高松】「はい…」R;>>トーンを落として
	
	@bs
	
	少しの会話だったけど、ひたすら背中を洗っている高松が哀れに思えてきて、それ以上は何も喋らずに自分も髪を洗い始めた。R
	風呂を出る時にも、まだ背中を洗い続けている高松の姿があった。R
	
	@ネイキッド高松を見た=1
	@実績チェック
	
	@湯気消去
	@fade(bg_kuro, 25)

}else{
	
	@湯気
	@bg(ep88_bg025, 25)

	部屋に戻り、いつものように、一緒に風呂に入る。R
	
	@湯気消去
	@fade(bg_kuro, 25)

}

IF(@AB11やるっきゃ内藤さんを読み終えた){

	ジャージに着替えると、思わずダッシュしようとしていた。R
	【@音無】（く…もう部屋には内藤さんは待っていないんだ…）R
	その事実に気づき、項垂れる…。R
	【@音無】（この胸の痛みは間違いなく…失恋…）R
	憂鬱とした足取りになる…。R
	
	@移動(ep99_bg003)	;－－－部屋
	@日向服装=@ジャージ

}elseIF(@AB12斉藤一族の余韻に浸る){

	ジャージに着替え、部屋に戻る途中。R
	【@音無】（あ、もう部屋には『斉藤一族』は待っていないんだ…）R
	その事実に気づく。R
	【@音無】（あれ…この胸に穴が空いたような気持ちはなんだろう…）R
	まるで、失恋でもしたような、憂鬱とした足取りになる…。R

	@移動(ep99_bg003)	;－－－部屋
	@日向服装=@ジャージ
	
	IF(@もうイケチン見られない==1||@日向と風呂入るのが今後ない==1){

		GOTO #HEYA

	}
	
	@bs(hn0109_07)
	KOE(001501226,010)【@日向】「おい、どーした！？」R
	【@音無】「…えぇ…？」R
	【@音無】「…なにか…？」R
	
	@bs(hn0105)
	KOE(001501229,010)【@日向】「そのテンションのだだ下がり方だよっ！」R

		;;■■コメントアウト待避389■■

	【@音無】「…いや…」R
	【@音無】「…気にしないで…」R
	【@音無】「…くれ…」R
	
	@bs(hn0306)
	@横揺れ_弱
	KOE(001501253,010)【@日向】「すっげぇーー！！　気になりますからぁーー！！」R

	;－－－●↓ここまでにどれだけ突っ込んできたかのフラグが必要だよね…？R
	IF(@日向のツッコミを褒めた){

		【@音無】「…き…た…」R
		【@音無】「…日向の…」R
		【@音無】「…丁寧語ツッコミ…」R
		
		@bs(hn0110)
		KOE(001501261,010)【@日向】「全然嬉しそうじゃねぇーー！！」R

	}

	【@音無】「…すまん…日向…」R
	【@音無】「…今日は…このテンションのまま…」R
	【@音無】「…過ごさせてくれ…」R
	
	@bs(hn0208)
	KOE(001501268,010)【@日向】「あーあー、好きにすればいーよ」R
	
	@bs
	
}else{

	ジャージに着替え、部屋に戻る。R
	
	@移動(ep99_bg003)	;－－－部屋
	@日向服装=@ジャージ

}		// IF(@AB11やるっきゃ内藤さんを読み終えた==1) else


#HEYA

@日向服装 = @ジャージ

;;■■コメントアウト待避516■■

IF(@AB12斉藤一族の余韻に浸る){
	いつもなら読書の時間だが、何も借りていない。R
	【@音無】（余韻に浸るはずが…胸が苦しい…！！）R
	
	@fade(bg_kuro, 2)
	
	俺はベッドのシーツを引き裂くように爪で掻き、もだえ、耐え続けた。R
	眠りに落ちるまでに、少し時間がかかった…。R

}elseif(@AB11やるっきゃ内藤さんを読み終えた){

	いつもなら読書の時間だが、内藤さんはもういない。R
	【@音無】（この喪失感…胸にぽっかりと穴が空いたような感覚…思っていた以上に辛い…）R
	
	@fade(bg_kuro, 2)
	
	俺はベッドのシーツを引き裂くように爪で掻き、もだえ、耐え続けた。R
	眠りに落ちるまでに、少し時間がかかった…。R

}elseif(@AB11やるっきゃ内藤さん最終巻を残した){

	いつもなら読書の時間だが、内藤さんの最終巻はベッドの下だ。R

	【@音無】（どんな辛いことがあっても、内藤さんがベッドの下にいると思えば耐えられる…）R
	
	@fade(bg_kuro, 2)
	
	俺は内藤さんに包まれるような心地よさを感じながら、目を閉じて眠りに落ちた。R

}else{

	@bs(hn0101)
	KOE(000502426,010)【@日向】「じゃ、そろそろ寝るか」R

