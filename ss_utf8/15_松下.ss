@sys_com_disable
@MovieFadeIn = @On
@fade_all(evmt_0405, 4)
clear

@OMV_READY_BGM(ef_sr_mt00, Hajimari, @Off)
// 余韻
@timewait(1500)
@OMV_START_BGM(0, @OBJ_FADE)

if (@松下ルートクリアした == @On)	{
	$_L[0] = timewait_key(263000)
	if ($_L[0] != 0)	{
		@MovieFadeIn = @Off
		@bgm_stop(3000)
		@force_fade(bg_kuro, 7)
	}
}
else	{
	@timewait(263000)
}

// 余韻
@timewaitkey(5000)

@MovieFadeIn = @Off
@sys_com_enable


