;－－－●選んだ選択肢は消え、ひとつ残った場合は強制

// 誰かコード書けよ……なんでオレが………('A`)

@制御１ = 0
@制御２ = 1
@制御３ = 1
@制御４ = 1

while(@制御１<3){

	if(@制御１==0){			まずは何からやろうか…R

	}elseif(@制御１==1){	次はどうしようか…R

	}else{					そうだな、最後は……R

	}

