		麻雀,		@制御２,	//（@０１日麻雀を打った=1）
		鬼ごっこ,	@制御３,
		七並べ,		@制御４
	)@selbtn_log

	@bgm_play(m302, 1000, 1000)

	IF(@選択==0){		// (麻雀/鬼ごっこ/七並べ) 

		【@音無】「麻雀」R

