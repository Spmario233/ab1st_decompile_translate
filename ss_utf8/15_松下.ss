@@選択=SELBTN(@selbtn_s_3,
	空の色,
	海の色,
	説明不可能
)@selbtn_log
IF(@選択==0){		// (空の色/海の色/説明不可能) 

	【@音無】「空の色、とかじゃ？」R

	GOTO #SONOIRO

}ELSEIF(@選択==1){		// (空の色/海の色/説明不可能) 

	【@音無】「海の色、とかじゃ？」R

