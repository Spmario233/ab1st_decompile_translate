//	チェックシート修正。↓の選択肢「入隊」を加えてわかりやすくしました		西村
@@選択=SELBTN(@selbtn_s_2,
	入隊する,
	入隊しない
)@selbtn_log
IF(@選択==0){
	IF(@その気さらにあり==1){
		【@音無】「みんなのことは残念だけど、お前が居るんだったら、もちろん入るさ」R
		
