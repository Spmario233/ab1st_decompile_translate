	@face(mt0103)
	KOE(150001407,015)【松下】「おーし、いいぞ！」R

	@pcmch_play(0, @柔道受け身)// 効果音（地面に倒れる音/柔道の受け身。野外）
	@縦揺れ_弱

	どすん！R
	@face(mt0102)
	KOE(150001409,015)【松下】「今のも悪くない！」R

	@pcmch_play(0, @柔道受け身)// 効果音（地面に倒れる音/柔道の受け身。野外）
	@縦揺れ_弱

	どすん！R
	@face(mt0103)
	KOE(150001411,015)【松下】「慣れてきたな！」R

	@pcmch_play(0, @柔道受け身)// 効果音（地面に倒れる音/柔道の受け身。野外）
	@縦揺れ_弱

	どすん！R
	結果。R
	
	@bs(mt0202)
	KOE(150001414,015)【松下】「もう、お前は大丈夫だ。投げられても怪我をすることはない」R
	【@音無】「マジで！？」R
	@bs(mt0203)
	KOE(150001416,015)【松下】「ああ」R
	@bs(mt0102)
