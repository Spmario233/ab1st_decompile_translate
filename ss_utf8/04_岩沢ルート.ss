bgm.set_volume(175)		;;■音量調整

@sys_com_disable
@MovieFadeIn = @On
@fade_all(bg_siro, 5)
clear

@OMV_READY_BGM(ef_iw_letter00, M092, @Off, @On)
pcmch[0].ready(se_letter, volume_type=1)
// 余韻
@timewait(1250)
pcmch[0].resume
;@OMV_START_BGM(4280, @OBJ_FADE)
@OMV_START_BGM(4500, @OBJ_FADE)

if (@岩沢ルートクリアした == @On)	{
	$_L[0] = timewait_key(126166)
	if ($_L[0] != 0)	{
		@MovieFadeIn = @Off
		pcmch[0].stop(2000)
		@force_fade(bg_siro, 5)
	}
	else	{
		@force_fade(bg_siro, 5)
	}
}
else	{
	@timewait(126166)
	@force_fade(bg_siro, 5)
}

@MovieFadeIn = @Off
@sys_com_enable



/*
これを書いている時点で十分幸せだ。R
もう何も思い残すことはない。R
いつ消えてもおかしくない。R
それは今日かもしれないし、明日かもしれないし、明後日かもしれない。R
この指輪をお前の指にはめた瞬間かもしれない。R
ようは後は時間の問題だってことだ。R
そこでお願いだ。R
あたしが消え去った後には、何も残されないだろう。R
お腹の子も、神様があたしのために用意してくれた、いわばよりしろだ。R
命あるものはこの世界では生まれない。R
だから、今お前に残されているのはこの指輪だった手紙だけのはずだ。R
あたしはこの先ずっと、お前を縛っておきたくない。R
愛し合っていたのは真実だ。そこに嘘偽りはない。R
けど、この世界での時間は恐ろしいほどに長い。R
あたしという存在をひきずったまま暮らして欲しくないんだ。R
新しい出会いもたくさんあるだろう。R
別の誰かを愛することになるかもしれない。R
その邪魔をしたくないんだ。R
だから、今ここで、この手紙を破り捨ててほしい。R
そして一緒にあたしを忘れてほしい。R
それが願いだ。R
最後に。R
たくさんの幸せをありがとう。R
音無雅美R
*/

