	if ($_L[0] != 0)	{
		@MovieFadeIn = @Off
		@bgm_stop(3000)
		@force_fade(bg_kuro, 7)
	}
	else	{
		@force_fade(bg_kuro, 7)
	}
}
else	{
	@timewait(259000)
	@force_fade(bg_kuro, 7)
}

