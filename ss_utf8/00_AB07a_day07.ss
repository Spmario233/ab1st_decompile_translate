			KOE(001010449,010)【@日向】「おらおらーー！！」R
			【@音無】「だから、うはははははっ、やめろって、日向ぁ！！　うはははーー！！」R

			@キャッキャウフフ終了フェード
			
			switch(@日向とキャッキャウフフした){	;;この時点でMAX5
				case(0)	
					しばらくふたりでキャッキャウフフした。R
				case(1)	
					またふたりでキャッキャウフフした。R		;;元・@また日向とキャッキャウフフした=1
				case(2)	
					またふたりでキャッキャウフフした。R		;;元・@またも日向とキャッキャウフフした=1
