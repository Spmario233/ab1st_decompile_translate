			//}

			GOTO #IIHUNIKI

		}		// (お前には傍に居続けてほしい/その不安はわかる) 選択処理のケツ

	}else{		// not(@その気さらにあり==1)

		GOTO #SONOFUAN

	}		// IF(@その気さらにあり==1) else 処理のケツ

