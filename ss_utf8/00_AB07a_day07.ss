					いつものようにふたりでキャッキャウフフした。R	;;元・@さらに日向とキャッキャウフフした=1
				case(4)	
					いつものようにふたりでキャッキャウフフした。R	;;元・@かなり日向とキャッキャウフフした=1
				case(5)	
