@bgm_play(m118)

IF(@遊佐の出現１){

	IF(@歯が飛んでまともに話せない){
		
		@縦揺れ_弱
		
		【@音無】（また突如として現れやがった！）R

		IF(@遊佐現れた時に松下居る){
			【@音無】（松下五段に確認してみたいが、喋れない今は無理だ…）R
		}
		
		素直に野球場に向かおう。R

	}else{
		
		@縦揺れ_弱
		
		【@音無】「また突如として現れた！」R

		IF(@遊佐現れた時に松下居る){
			
			@bs_add(mt0101, 4)
			
			【@音無】「松下五段も見てたよな！？　いきなり現れたよな！？」R
			
			@bf(mt0106)
			KOE(001004784,015)【松下】「いきなり？　何が」R
			
			@bf(mt0102)
			KOE(001004785,015)【松下】「ああ、遊佐か。どうしたこんな奥地にまで」R
			
			@横揺れ_弱
			
			【@音無】「えぇーーーー！！　疑問浮かばねーの！？」R
			
			@bf(mt0108)
			KOE(001004787,015)【松下】「だから、何がだ？」R
			【@音無】「こいつが突然現れたことだよっ！！」R
			
			@bf(mt0206)
			KOE(001004789,015)【松下】「突然には現れないだろう」R
			
			@縦揺れ_弱
			
			【@音無】「えぇぇぇーー！！」R
			【@音無】「俺よりずっと前から居るのに、気づいていないなんて…」R
			
			@bf(ys0102)
			KOE(001004792,008)【遊佐】「試合開始寸前です。野球場まで駆けつけてください」R
			【@音無】「ちっ、わかったよ！」R
			
			@fade(bg_kuro, 25)
			
			ふたりを残して、走り去る。R

			//GOTO #OKURETESUMAN

		}else{

			@bs(ys0105)
			KOE(001004800,008)【遊佐】「突如としては現れていません。あなたが気づくのが遅いだけです。ちゃんと遠くから近づいてきています」R
			
			IF(@歯が飛んでまともに話せない){
			
				【@音無】「ほうなのは…」R
			
			}else{
			
				【@音無】「そうなのか…」R
			
			}
			
			まあ、いい。試合に向かおう。R

