			KOE(040006033,006)【関根】「明日から、あたしたちはマスクにグラサンかけなければいけないぐらいにやばい…」R
			
			@bf(ir0304_05@00d)
			KOE(040006034,007)【入江】@bc「それって、芸能人レベルじゃない？　あたしらは岩沢先輩やひさ子先輩並みには人気ないから、大丈夫だと思うよ？」@bf_c(3400, ir0306_04)R
			
			@bf(sk0410_09@00o)
			KOE(040006035,006)【関根】「わかってないな…みゆきちは…」R
			
			@bf(ir0301_04)
			KOE(040006036,007)【入江】「はあ」R
			
			@bs_set(-1, bs3_sk0107@21a, @pos_l + 40)
			@bs_set(-1, ir0301_04, @pos_r - 40)
			@wipe(0)
			@横揺れ_強(0, 0)
			KOE(040006037,006)【関根】「ようは、この男のオナペットにされたいかってことだよ！！」R

			@bs_set(-1, bs3_sk0107, @pos_l + 40)
			@bs_set(-1, ir0301_04, @pos_r - 40)
			@wipe(0)
			
			すごいワードが関根の口から飛び出した。R
			
			@bs_set(-1, bs3_sk0107, @pos_l + 40)
			@bs_set(-1, ir0304@13, @pos_r - 40)
			@wipe(0)
			
			KOE(040006039,007)【入江】「おな…ぺっと…？」R
			が、入江には伝わらない。R
			
			@bs_set(-1, sk0108@00d, @pos_l + 40)
			@bs_set(-1, ir0304@13, @pos_r - 40)
			@wipe(0)
			KOE(040006041,006)【関根】「っ！！」R
			
			@bs(bs2_sk0409@00a, ir)
			KOE(040006042,006)【関根】「すまない…今の言葉は忘れてくれ…。あたしはうぶなみゆきちが好きだったんだ…」R
			
			@bf(sk0408_06)
			KOE(040006043,006)【関根】「それをこの男のせいで、そのうぶが失われる危機だった…」R
			
			@bf(ir0301_04)
			KOE(040006044,007)【入江】「はあ…」R
			で、結局俺の立場はどうなったんだ？R

			@@選択=SELBTN(@selbtn_s_2,
				してると言い通す,
				冗談だったと告げる
			)@selbtn_log
			IF(@選択==0){		// (してると言い通す/冗談だったと告げる) 

				【@音無】「してる。し続ける」R
				
				@bf(sk0107@15)
				@横揺れ_強
				KOE(040006053,006)【関根】「うああぁぁぁぁぁぁぁぁーーーーーーーー！！」R
				
				@bf(ir0104)
				KOE(040006054,007)【入江】@bc「え、何？　そんな大きなリアクションされる意味があたし、わかってないんだけど…」@bf_c(2000, ir0106_04)R
				【@音無】「別に減るもんじゃないし、お前らに迷惑をかけてるわけでもないから、いいだろ？」R
				
				@bf(sk0108@00g, ir0104)
				KOE(040006056,006)【関根】「うっわー！　ガチだ！」R
				
				@bf(sk0109)
				KOE(040006057,006)【関根】@bc「そりゃ、お好きにどうぞ、としか返せない…」@bf_c(800, sk0103@00a)@bf_c(1200, sk0109)R
				【@音無】「納得してくれたなら、なによりだ」R
				
				@bf(sk0108_06)
				KOE(040006059,006)【関根】「そんな爽やかに下ネタをカミングアウトするとは…」R
				
				@bf(sk0110@00o)
				KOE(040006060,006)【関根】「まあ、いいです。まだ想定内です。あたしたちの楽しみはそこにはないので」R
				
				@bf(sk0105, ir0104)
				KOE(040006061,006)【関根】「というわけで、次は岩沢先輩とキスしてください」R

			}ELSE{	// IF(@選択==1){		// (してると言い通す/冗談だったと告げる) 

				【@音無】「冗談だよ」R
				そう答えておくほうが、面倒ごとが増えなくていい気がした。R
				
				@bs(sk0104@00a)
				KOE(040006069,006)【関根】「はあぁぁあーーーーーー！！　安心しました！」R
				どれだけ恐れてたんだよ…。R
				
				@bf(sk0105)
				KOE(040006071,006)【関根】「では、次はですね、岩沢先輩とキスしてください」R

			}

		}ELSE{	// IF(@選択==1){		// (してる/してない) してない

			【@音無】「すげえ言いがかりだな。してねーよ」R
			
			@bf(sk0106)
			KOE(040006081,006)【関根】「本当ですか！？」R
			
			@bs(sk, ir0104)
			【@音無】「本当だよ。ぶっちゃけ、お前らを俺は女として見ていない」R
			
			@bf(sk0108@00d)
			KOE(040006083,006)【関根】「そりゃ、みゆきちは貧乳ですけどぉーー！！」R
			
			@bs(sk, ir0304_05@10)
			@横揺れ_弱
			KOE(040006084,007)【入江】「えぇ！？　どうしてそんなこと男の人の前で、ぶっちゃけられてるの！？」R
			
			@bf(sk0101_06)
			KOE(040006085,006)【関根】「だって、貧乳じゃん」R
			
			@bf(ir0305@00b)
			KOE(040006086,007)【入江】「そうかもしれないけど、どうして音無さんを前にして言うの！？」R			// ■■■■ あだ名の場合つっこまなくていいの？（西
			
			@bf(sk0410_01, ir0303)
			KOE(040006087,006)【関根】「岩沢先輩もひさ子先輩も、いい感じのおっぱいの大きさだ。だから、こいつはそのふたりの組み合わせで、妄想して楽しむことが出来る」R
			
			@bf(sk0106@00a)
			KOE(040006088,006)【関根】「でも、あたしらは、みゆきちが貧乳なため、その対象にならない！」R
			
			@bf(ir0305_04)
			KOE(040006089,007)【入江】「しおりんが言ってること、さっぱりわからないよ…」R
			
			@bs(ir0306)
			KOE(040006090,007)【入江】「そして残ったのは、あたしが貧乳だと音無さんに知られたという事実だけ…」R			// ■■■■ あだ名の場合つっこまなくていいの？（西
			入江が泣きそうなぐらい落ち込んでいた。R
			
			@入江が貧乳だと知った=1
			@実績チェック

			@@選択=SELBTN(@selbtn_m_2,
				胸の大きさなんてどうでもいい,
				やはり大きいに限る
			)@selbtn_log
			IF(@選択==0){		// (胸の大きさなんてどうでもいい/やはり大きいに限る) 

				【@音無】「胸の大きさなんてどうでもいい」R
				
				@bs(sk0109, ir0104)
				KOE(040006099,006)【関根】「え！？　だったら、あたしたちもあなたのおかずに…」R
				【@音無】「何のこと言ってんのか、わかんねーよ…」R
				
				@bs(bs3_sk0406_03)
				KOE(040006101,006)【関根】「詳しく言いましょうか？」R
				【@音無】「やめてくれ。どうせ下ネタだろ？」R
				
				@集中線開始
				@bf(sk0107)
				@横揺れ_強
				KOE(040006103,006)【関根】「お前から下ネタを振った癖に、それはないだろぉぉーー！！」R

				@集中線終了
				@bf(sk0107)
				
				確かに。R
				【@音無】「今の会話は忘れてくれ」R
				
				@bf(bs2_sk0110_09@00a)
				KOE(040006106,006)【関根】「ふぅぅーーー…」R
				すごく長いため息をつかれる。R
				
				@bs(sk, ir0101)
				
				【@音無】「で、俺はどうすればいいんだ？」R
				
				@bf(sk0105)
				KOE(040006109,006)【関根】「次はですね、岩沢先輩とキスしてください」R

			}ELSE{	// IF(@選択==1){		// (胸の大きさなんてどうでもいい/やはり大きいに限る) 

				【@音無】「やはり大きいに限る」R
				
				@bf(ir0105@00b)
				KOE(040006116,007)【入江】「やっぱりぃ…」R
				【@音無】「でも、大きすぎるのもなんだか魅力を感じない」R
				
				@bs(sk0107@06@00g, ir0106_03)
				KOE(040006118,006)【関根】「さじ加減が難しい奴だなぁーー！！」R
				
				@bf(sk0406)
				KOE(040006119,006)【関根】「でも、岩沢先輩の胸なら許容範囲、と」R

				@@選択=SELBTN(@selbtn_s_2,
					理想的だ,
					やや物足りない
				)@selbtn_log
				IF(@選択==0){		// (理想的だ/やや物足りない) 

					【@音無】「理想的だ」R
					
					@bf(sk0104@11g, ir0106_03)
					KOE(040006127,006)【関根】「よーーーしぃぃっ！！」R
					関根が元気づく。R

				}ELSE{	// IF(@選択==1){		// (理想的だ/やや物足りない) 

					【@音無】「やや物足りない」R
					
					@bf(sk0107@00o, ir0106_03)
					KOE(040006133,006)【関根】「やや物足りないなら、お前が揉んでやって理想的な大きさにすればいいだけだろぉーー！！」R
					【@音無】「まあ、乳腺を直接刺激すると、大きくなるって話は聞いたことあるな」R
					
					@bf(sk0108@00g)
					KOE(040006135,006)【関根】「なんだ、その医学的根拠のあるような言い方はぁーーー！！」R

					IF(@音無最初の記憶を思い出した==0){

						【@音無】「いや、記憶戻ってないから、自分でもよくわからない」R

					}else{

						【@音無】「まあ、生前医者を目指してたから、一応」R
						
						@bf(sk0107@09@00d)
						KOE(040006141,006)【関根】「知らなかったよ！！」R

					}
					
					@bf(sk0110@00a)
					KOE(040006144,006)【関根】「まあ、いいです」R
					こほん、とひとつ咳をして一息置く。R

				}		// (理想的だ/やや物足りない) 

				@bf(sk0105, ir0104)
				KOE(040006149,006)【関根】「では、次はですね、岩沢先輩とキスしてください」R

			}		// (胸の大きさなんてどうでもいい/やはり大きいに限る) 

		}		// (してる/してない) 

		GOTO #UHYAA

	}ELSE{	// IF(@選択==1){		// (言えない/Ｈなこと) 

		【@音無】「Ｈなこと」R
		
		@bf(sk0107)
		@横揺れ_強
		KOE(040006164,006)【関根】「直球で来たああぁーーーーーー！！」R

		GOTO #ATASHITO

	}		// (言えない/Ｈなこと) 

}

#OWARIZ28

@bgm_stop(2000)
