	@@選択=SELBTN(@selbtn_s_2,
		ちなみに関根は？,
		ちなみに入江は？
	)@selbtn_log
	IF(@選択==0){

		【@音無】「ちなみに関根は？」R
		
		@bf(iw0209_08)
		KOE(040005644,004)【岩沢】「関根かー。最後に加入したのが、あいつだからなー」R
		
		@bf(iw0107_02)
		KOE(040005645,004)【岩沢】「当時で言えば、ぶっちゃけ下手くそだったよ」R
		
		@bf(iw0109_01)
